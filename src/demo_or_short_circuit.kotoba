(ns demo-or-short-circuit)

;; `spin` never returns -- it exists only to prove `or`'s first (truthy)
;; argument short-circuits the second: if `(spin 0)` were actually
;; evaluated, `main` would never return (and a fuel-limited run would trap
;; on :fuel-exhausted instead of yielding 7).
(defn spin [x]
  (spin x))

(defn main []
  (or 7 (spin 0)))
