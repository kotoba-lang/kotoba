;; ADR-2607180900 L2: bare string literal on a string-head host op lowers to
;; (str-ptr s) (str-len s). Full sha256-hex ABI still needs out-buffer params
;; after the input head — this fixture documents the sugar only (see
;; guest_maturity_l2_test for the structural assertion). For a runnable
;; hash guest use demo_actor_host_sha256.kotoba (explicit memory ABI).
(ns demo-string-host-sugar)

(defn main []
  (sha256-hex ""))