(ns demo-case-multi-test)

;; `(case 2 (1 2 3) 100 (4 5 6) 200 0)`: a list in test position matches if
;; the dispatch value equals ANY of its elements (Clojure's `case`
;; semantics). 2 is a member of `(1 2 3)`, so `main` returns 100.
(defn main []
  (case 2
    (1 2 3) 100
    (4 5 6) 200
    0))
