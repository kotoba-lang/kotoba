;; demo_kbb_fs_report.kotoba — kbb v0.1 proof-of-concept (ADR-2607182430 in the
;; com-junkawasaki/root superproject): a minimal single-file port of the
;; "read repo file(s), compute a small count, write/print a report" pattern
;; shared by several outer-monorepo nbb ops scripts (e.g.
;; scripts/verify-no-babashka.cljs, scripts/check-foundation-deps.cljs,
;; scripts/langchain-store-adoption-scan.cljs all: read file content(s) ->
;; classify/count -> report a number). Those scripts recurse over a whole
;; directory tree; this `.kotoba` guest reads exactly ONE file because kbb
;; v0.1's fs-read/fs-write ops (kotoba.host-providers/default-handlers) take
;; a single literal path each -- there is no directory-listing host-import
;; op yet. This is a deliberate v0.1 scope reduction, not an oversight.
;;
;; Reads src/demo_kbb_fixture.txt (relative to the `kotoba run` invocation's
;; cwd, exactly like a real ops script resolves paths against the caller's
;; cwd, not its own script location), counts its bytes, and writes that
;; count as a decimal string to demo_kbb_report.txt -- a REAL round trip
;; through kotoba.host-providers/default-handlers' now-real fs-read/fs-write
;; handlers (previously 0-returning stubs), guarded by a --policy granting
;; exactly :fs/app-data (the one capability both ops share), scoped to
;; exactly these two paths.
(ns demo-kbb-fs-report)

(defn main []
  (let [content (fs-read "src/demo_kbb_fixture.txt")
        n (count content)
        _written (fs-write "demo_kbb_report.txt" (str n))]
    n))
