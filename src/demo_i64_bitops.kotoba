(ns demo-i64-bitops)

;; Same as demo_bitops.kotoba but the i64 family (i64and/i64or/i64xor/
;; i64shl/i64shr) -- virtio's feature bitset is 64 bits wide, so the i32
;; family alone isn't enough. Same arithmetic: sum 34.

(defn ^:i64 main []
  (let [a (i64and (i64 6) (i64 3))
        b (i64or (i64 6) (i64 3))
        c (i64xor (i64 6) (i64 3))
        d (i64shl (i64 1) (i64 4))
        e (i64shr (i64 16) (i64 2))]
    (i64+ a b c d e)))
