(ns demo-kgraph)

(defn main []
  (let [_status (kgraph-assert! (str-ptr "[1 :name \"Aoi\"]") (str-len "[1 :name \"Aoi\"]"))
        buf (alloc 64)]
    (kgraph-query (str-ptr "{:find [?v] :where [[1 :name ?v]]}")
                  (str-len "{:find [?v] :where [[1 :name ?v]]}")
                  buf 64)))
