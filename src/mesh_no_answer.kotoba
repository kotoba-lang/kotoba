;; mesh_no_answer.kotoba — a mesh_node.clj test fixture: an assert-only
;; guest that never calls kgraph-query, so `dispatch`'s "written" byte
;; count is 0 and the route answers HTTP 204 (ran successfully, nothing to
;; answer with) rather than 200 -- the one `dispatch`/`handler` branch
;; `mesh_drama_profile.kotoba` (which always queries) can't reach.
(ns mesh-no-answer)

(defn main []
  (let [_h (kgraph-assert! (str-ptr "[1 :handle \"no-answer.example\"]")
                           (str-len "[1 :handle \"no-answer.example\"]"))]
    0))
