(ns demo-i64-if)

;; Regression fixture: `if` with i64-typed branches -- same underlying bug
;; as demo_f32_if.kotoba (compile-wasm-expr's `if` hardcoded the WASM `if`
;; block's result-type byte to i32 regardless of the branches' real type),
;; just for i64 instead of f32. No prior fixture exercised an i64-typed
;; `if` either, so this path was equally unverified.

(defn ^:i64 main []
  (if 1
    (i64 42)
    (i64 0)))
