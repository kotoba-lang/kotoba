(ns demo-and-short-circuit)

;; `spin` never returns -- it exists only to prove `and`'s first (falsy)
;; argument short-circuits the second: if `(spin 0)` were actually
;; evaluated, `main` would never return (and a fuel-limited run would trap
;; on :fuel-exhausted instead of yielding 0).
(defn spin [x]
  (spin x))

(defn main []
  (and 0 (spin 0)))
