;; mesh_drama_profile.kotoba — ADR-2607082400's first cljc-ported mesh app.
;;
;; Ports minidrama's ON-MESH `drama-profile` component
;; (orgs/etzhayyim/com-etzhayyim-minidrama/mesh/drama_profile.clj, a
;; kotoba-clj/WASM-Component guest kotoba-server hosts) to `.kotoba`, run
;; by `kotoba.wasm-exec` (com.dylibso.chicory) instead. Chosen as the FIRST
;; port because it is the split-of-duties "thin, non-censorable" half of
;; minidrama's mesh surface (ADR-2607071500): it only asserts + serves the
;; actor's already-public identity facts (handle/did/registry) — no
;; DramaGovernor-gated decision ever touches this component.
;;
;; kqe-assert!/kqe-query (kotoba-server's mesh vocabulary) has no analog in
;; kototama's actor:host ABI (crypto/http/llm/log — a different vocabulary,
;; ADR-2607082400). kgraph-assert!/kgraph-query IS the same concept under
;; kotoba-lang/kotoba's OWN in-memory EAVT graph (the language's kgraph,
;; ADR-2606271600 note in CLAUDE.md: "旧称KQEは現行実装ではkgraphに改称")
;; — reusing it here, rather than inventing a duplicate capability in
;; kototama, is exactly what ADR-2607022700 ("no semantic authority
;; duplication") requires.
(ns mesh-drama-profile)

(defn main []
  (let [_h (kgraph-assert! (str-ptr "[1 :handle \"minidrama.aozora.app\"]")
                           (str-len "[1 :handle \"minidrama.aozora.app\"]"))
        _d (kgraph-assert! (str-ptr "[1 :did \"did:key:z6MkfF8hVc4xtEdDudV1jJiyTtQDdmYBEXrhzGGaqYsHv16b\"]")
                           (str-len "[1 :did \"did:key:z6MkfF8hVc4xtEdDudV1jJiyTtQDdmYBEXrhzGGaqYsHv16b\"]"))
        _r (kgraph-assert! (str-ptr "[1 :registry \"aozora.appview.creator-actors\"]")
                           (str-len "[1 :registry \"aozora.appview.creator-actors\"]"))
        buf (alloc 128)]
    (kgraph-query (str-ptr "{:find [?v] :where [[1 :handle ?v]]}")
                  (str-len "{:find [?v] :where [[1 :handle ?v]]}")
                  buf 128)))
