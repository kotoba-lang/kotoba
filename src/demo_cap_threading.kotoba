(ns demo-cap-threading)

(defn ^{:i64 true :effects #{:host/ledger-append}} inner
  [^{:cap :host/ledger-append} c ^:i64 code]
  (host-i64-roundtrip-with c code))

(defn ^{:i64 true :effects #{:host/ledger-append}} outer
  [^{:cap :host/ledger-append} c ^:i64 code]
  (inner c (i64+ code (i64 1))))

(defn ^{:i64 true :effects #{:host/ledger-append}} main []
  (let [cap (cap-acquire :host/ledger-append "ledger:main")]
    (outer cap (i64 41))))
