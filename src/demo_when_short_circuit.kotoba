(ns demo-when-short-circuit)

;; `spin` never returns -- it exists only to prove `when`'s falsy test
;; short-circuits its body: if `(spin 0)` were actually evaluated, `main`
;; would never return (and a fuel-limited run would trap on
;; :fuel-exhausted instead of yielding 0).
(defn spin [x]
  (spin x))

(defn main []
  (when 0
    (spin 0)))
