{:kotoba.independent-review-package/version 1
 :target {:repository "kotoba-lang/kotoba"
          :baseline-commit "09191ab3d247f36353475fd1669588ef5bad1f70"
          :qualification-report "qualification/q8-report.edn"
          :threat-model "../compiler/docs/threat-model.md"}
 :independence
 {:reviewer-must-not-be-maintainer-of ["kotoba-lang/kotoba" "kotoba-lang/compiler"]
  :required-attestation true
  :conflicts-must-be-disclosed true}
 :review-areas
 [{:id :source-admission
   :attacks [:reader-eval :macro-expansion :host-interop :path-confusion
             :malformed-edn :resource-exhaustion]}
  {:id :artifact-verification
   :attacks [:resealed-mutation :kir-byte-divergence :target-confusion
             :effect-closure-bypass :signature-confusion :receipt-replay]}
  {:id :capability-boundary
   :attacks [:ambient-authority :wildcard-scope :scope-confusion
             :revocation-race :forged-handle :same-language-provider-bypass]}
  {:id :native-isolation
   :attacks [:filesystem :network :process :raw-syscall :memory-corruption
             :fuel-bypass :wall-timeout-bypass]}
  {:id :backend-parity
   :attacks [:acceptance-drift :result-drift :effect-drift :diagnostic-drift]}]
 :required-output
 {:path "qualification/independent-review-findings.edn"
  :severities #{:critical :high :medium :low :informational}
  :dispositions #{:open :fixed :accepted-risk :not-reproducible}
  :required-finding-keys
  #{:id :area :severity :title :reproduction :affected-commit :disposition :evidence}
  :promotion-requires
  [:independent-attestation :all-review-areas-covered
   :critical-and-high-findings-closed :evidence-paths-resolve]}}
