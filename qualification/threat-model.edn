{:kotoba.threat-model/version 1
 :as-of "2026-07-23"
 :profile :grade-a-candidate
 :scope #{:kotoba :kototama :aiueos :kotoba-lang :kotobase
          :kotobase.net :composed-deployment}
 :assets
 [{:id :asset/source :classification :integrity}
  {:id :asset/package :classification :integrity}
  {:id :asset/component :classification :integrity}
  {:id :asset/signing-keys :classification :secret}
  {:id :asset/block-key :classification :secret}
  {:id :asset/private-data :classification :confidential}
  {:id :asset/tenant-authority :classification :confidential}
  {:id :asset/audit-receipts :classification :integrity}
  {:id :asset/availability :classification :operational}]
 :actors
 [{:id :actor/user :trust :authenticated}
  {:id :actor/operator :trust :privileged}
  {:id :actor/release-authority :trust :privileged}
  {:id :actor/edge :trust :untrusted-until-origin-verified}
  {:id :actor/guest :trust :hostile}
  {:id :actor/dependency :trust :untrusted}
  {:id :actor/tenant :trust :mutually-hostile}
  {:id :actor/network :trust :hostile}
  {:id :actor/storage-provider :trust :honest-but-curious}]
 :trust-boundaries
