  {:id :boundary/compiler-artifact :from :kotoba-lang :to :kotoba}
  {:id :boundary/package-admission :from :actor/dependency :to :kotoba}
  {:id :boundary/component-tender :from :actor/guest :to :kototama}
  {:id :boundary/host-import :from :kototama :to :aiueos}
  {:id :boundary/hardware :from :aiueos :to :physical-device}
  {:id :boundary/data-plane :from :actor/tenant :to :kotobase}
  {:id :boundary/edge-origin :from :actor/edge :to :kotobase.net}
  {:id :boundary/public-storage :from :kotoba :to :actor/storage-provider}
  {:id :boundary/release :from :actor/release-authority
   :to :composed-deployment}]
 :threats
