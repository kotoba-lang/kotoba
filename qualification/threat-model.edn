   :assets #{:asset/tenant-authority}
   :boundaries #{:boundary/edge-origin}
   :controls #{:control/origin-assertion}}
  {:id :T-tamper-source :category :tampering
   :assets #{:asset/source :asset/package :asset/component}
   :boundaries #{:boundary/source-reader :boundary/compiler-artifact
                 :boundary/package-admission}
   :controls #{:control/content-pins :control/signatures
               :control/normative-conformance}}
  {:id :T-repudiate-effect :category :repudiation
   :assets #{:asset/audit-receipts}
   :boundaries #{:boundary/component-tender :boundary/host-import}
   :controls #{:control/receipts :control/anchor-relayer}}
  {:id :T-disclose-storage :category :information-disclosure
   :assets #{:asset/private-data :asset/block-key}
   :boundaries #{:boundary/public-storage}
   :controls #{:control/sealed-egress :control/key-lifecycle}}
  {:id :T-cross-tenant :category :information-disclosure
   :assets #{:asset/private-data :asset/tenant-authority}
   :boundaries #{:boundary/data-plane :boundary/edge-origin}
   :controls #{:control/abac :control/scoped-capability}}
  {:id :T-resource-exhaustion :category :denial-of-service
   :assets #{:asset/availability}
   :boundaries #{:boundary/source-reader :boundary/component-tender
                 :boundary/data-plane}
   :controls #{:control/parser-bounds :control/runtime-bounds}}
  {:id :T-ambient-authority :category :elevation-of-privilege
   :assets #{:asset/tenant-authority :asset/private-data}
   :boundaries #{:boundary/package-admission :boundary/component-tender
                 :boundary/host-import}
   :controls #{:control/scoped-capability :control/no-wildcard}}
  {:id :T-side-channel :category :side-channel
   :assets #{:asset/signing-keys :asset/block-key :asset/private-data}
   :boundaries #{:boundary/host-import :boundary/hardware}
   :controls #{:control/side-channel-profile}}
  {:id :T-supply-chain :category :supply-chain
   :assets #{:asset/source :asset/package :asset/component}
   :boundaries #{:boundary/release :boundary/package-admission}
   :controls #{:control/sbom-provenance :control/signatures}}
  {:id :T-key-loss-compromise :category :recovery
   :assets #{:asset/signing-keys :asset/block-key :asset/availability}
   :boundaries #{:boundary/release :boundary/public-storage}
   :controls #{:control/key-lifecycle :control/restore-drill}}
  {:id :T-malicious-hardware-input :category :tampering
   :assets #{:asset/private-data :asset/availability}
   :boundaries #{:boundary/hardware}
   :controls #{:control/iommu :control/device-admission}}]
