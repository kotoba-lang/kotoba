{
  "lexicon": 1,
  "id": "ai.gftd.apps.kotoba.graph.sparql",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Execute auxiliary SPARQL SELECT, ASK, DESCRIBE, or CONSTRUCT over the primary Kotoba distributed Datomic/Datom graph.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["query"],
          "properties": {
            "query": { "type": "string" },
            "graph": { "type": "string" },
            "remotePeer": {
              "type": "string",
              "description": "Optional host:port or /ip4/<addr>/tcp/<port> kotoba-ipfs peer used to resolve a remote graph IPNS head and DAG-CBOR/Prolly blocks."
            },
            "remoteIpnsName": {
              "type": "string",
              "description": "Optional IPNS name override for SPARQL reads. Defaults to the graph canonical k51-kotoba-{graph} head."
            },
            "asOf": {
              "type": "string",
              "description": "Optional Datomic as-of transaction CID. Reads the graph DB at the end of this transaction."
            },
            "since": {
              "type": "string",
              "description": "Optional Datomic since transaction CID. Reads facts strictly after this transaction."
            },
            "cacaoB64": { "type": "string" },
            "presentation": {
              "type": "object",
              "required": ["@context", "id", "type"],
              "properties": {
                "@context": { "type": "array", "items": { "type": "string" } },
                "id": { "type": "string" },
                "type": { "type": "array", "items": { "type": "string" } },
                "holder": { "type": "string" },
                "verifiableCredential": { "type": "array", "items": { "type": "object" } },
                "proof": {
                  "type": "object",
                  "required": ["type", "proofPurpose", "verificationMethod", "proofValue"],
                  "properties": {
                    "type": { "type": "string" },
                    "cryptosuite": { "type": "string" },
                    "proofPurpose": { "type": "string" },
                    "verificationMethod": { "type": "string" },
                    "created": { "type": "string" },
                    "proofValue": { "type": "string" },
                    "challenge": { "type": "string" },
                    "domain": { "type": "string" }
                  }
                }
              }
            },
            "limit": { "type": "integer", "minimum": 1, "maximum": 100000 },
            "maxHops": { "type": "integer", "minimum": 0, "maximum": 16 }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["ok", "form", "queryEngine", "primaryQuery", "auxiliaryQuery", "storageModel", "elapsedMs"],
          "properties": {
            "ok": { "type": "boolean" },
            "form": {
              "type": "string",
              "knownValues": ["select", "ask", "describe", "construct"]
            },
            "queryEngine": {
              "type": "string",
              "knownValues": ["datomic"],
              "description": "Primary query engine backing this auxiliary SPARQL response."
            },
            "primaryQuery": {
              "type": "string",
              "knownValues": ["ai.gftd.apps.kotoba.datomic.q"],
              "description": "Primary Datomic/Datalog query procedure over the Datom SSoT."
            },
            "auxiliaryQuery": {
              "type": "string",
              "knownValues": ["ai.gftd.apps.kotoba.graph.sparql"],
              "description": "This auxiliary SPARQL query procedure over the same Datom SSoT."
            },
            "storageModel": {
              "type": "string",
              "knownValues": ["ipld-dag-cbor-prolly-tree"],
              "description": "Distributed storage/index model read by this query."
            },
            "result": { "type": "boolean" },
            "basisT": {
              "type": "string",
              "description": "Datomic basis transaction CID for distributed, as-of, since, or remote SPARQL reads."
            },
            "count": { "type": "integer", "minimum": 0 },
            "maxHops": { "type": "integer", "minimum": 0, "maximum": 16 },
            "elapsedMs": { "type": "integer", "minimum": 0 },
            "quads": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["graph", "subject", "predicate", "object"],
                "properties": {
                  "graph": { "type": "string" },
                  "subject": { "type": "string" },
                  "predicate": { "type": "string" },
                  "object": {
                    "type": "object",
                    "properties": {
                      "cid": { "type": "string" },
                      "text": { "type": "string" },
                      "int": { "type": "integer" },
                      "float": { "type": "number" },
                      "bool": { "type": "boolean" },
                      "raw": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
