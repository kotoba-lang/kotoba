{
  "lexicon": 1,
  "id": "ai.gftd.apps.kotoba.datomic.q",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Datomic Datalog query against a Kotoba distributed Datom graph. Supports EDN query forms, inputs, :as-of/:since transaction bases, history queries, pull expressions, rules, aggregates, fulltext relation bindings, :keys/:strs/:syms map returns as rows_map_edn and rows_map_json, and CACAO or Verifiable Presentation read authorization.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph", "query_edn"],
          "properties": {
            "graph": { "type": "string" },
            "query_edn": { "type": "string" },
            "inputs_edn": { "type": "array", "items": { "type": "string" } },
            "as_of": { "type": "string" },
            "since": { "type": "string" },
            "history": { "type": "boolean" },
            "cacao_b64": { "type": "string" },
            "presentation": { "type": "unknown" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph", "rows_edn"],
          "properties": {
            "graph": { "type": "string" },
            "basis_t": { "type": "string" },
            "rows_edn": {
              "type": "array",
              "items": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "rows_map_edn": {
              "type": "array",
              "items": { "type": "string" }
            },
            "rows_map_json": {
              "type": "array",
              "items": {
                "type": "object",
                "description": "A Datomic :keys/:strs/:syms row map. Keys are the projected map keys; values are EDN strings preserving Datomic values.",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
