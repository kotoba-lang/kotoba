{
  "lexicon": 1,
  "id": "ai.gftd.apps.kotoba.datomic.datoms",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Return Datomic datoms(index, components...) from a Kotoba distributed Datom graph.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph", "index"],
          "properties": {
            "graph": { "type": "string" },
            "index": {
              "type": "string",
              "description": "Datomic index name. Supported values: :eavt, :aevt, :avet, :vaet, :tea."
            },
            "components_edn": { "type": "array", "items": { "type": "string" } },
            "as_of": { "type": "string" },
            "since": { "type": "string" },
            "cacao_b64": { "type": "string" },
            "presentation": {
              "type": "object",
              "required": ["@context", "id", "type"],
              "properties": {
                "@context": { "type": "array", "items": { "type": "string" } },
                "id": { "type": "string" },
                "type": { "type": "array", "items": { "type": "string" } },
                "holder": { "type": "string" },
                "verifiableCredential": { "type": "array", "items": { "type": "object" } },
                "proof": {
                  "type": "object",
                  "required": ["type", "proofPurpose", "verificationMethod", "proofValue"],
                  "properties": {
                    "type": { "type": "string" },
                    "cryptosuite": { "type": "string" },
                    "proofPurpose": { "type": "string" },
                    "verificationMethod": { "type": "string" },
                    "created": { "type": "string" },
                    "proofValue": { "type": "string" },
                    "challenge": { "type": "string" },
                    "domain": { "type": "string" }
                  }
                }
              }
            },
            "limit": { "type": "integer", "minimum": 0 }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph", "index", "datom_count", "datoms"],
          "properties": {
            "graph": { "type": "string" },
            "index": {
              "type": "string",
              "description": "Datomic index name used for the returned ordering. Supported values: :eavt, :aevt, :avet, :vaet, :tea."
            },
            "basis_t": { "type": "string" },
            "datom_count": { "type": "integer", "minimum": 0 },
            "datoms": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["e", "a", "v_edn", "t", "added"],
                "properties": {
                  "e": { "type": "string" },
                  "a": { "type": "string" },
                  "v_edn": { "type": "string" },
                  "t": {
                    "type": "string",
                    "description": "Transaction CID for this Datom."
                  },
                  "added": { "type": "boolean" }
                }
              }
            }
          }
        }
      }
    }
  }
}
