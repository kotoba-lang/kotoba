{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.graph.query",
  "defs": {
    "main": {
      "type": "query",
      "description": "Read SPO quads from the primary Kotoba distributed Datomic/Datom graph using graph:query capability for private graphs. Full Datomic/Datalog evaluation is exposed by com.etzhayyim.apps.kotoba.datomic.q; SPARQL is an auxiliary query surface.",
      "parameters": {
        "type": "params",
        "required": ["graph"],
        "properties": {
          "graph": { "type": "string" },
          "subject": { "type": "string" },
          "predicate": { "type": "string" },
          "rules": { "type": "string" },
          "cacao_b64": { "type": "string" },
          "limit": { "type": "integer", "minimum": 1, "maximum": 1000 }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph", "queryEngine", "primaryQuery", "auxiliaryQuery", "storageModel", "count", "quads"],
          "properties": {
            "graph": { "type": "string" },
            "queryEngine": {
              "type": "string",
              "knownValues": ["datomic"],
              "description": "Primary query engine for this graph read surface."
            },
            "primaryQuery": {
              "type": "string",
              "description": "NSID of the primary Datomic/Datalog query endpoint."
            },
            "auxiliaryQuery": {
              "type": "string",
              "description": "NSID of the auxiliary SPARQL query endpoint over the same Datom graph."
            },
            "storageModel": {
              "type": "string",
              "knownValues": ["ipld-dag-cbor-prolly-tree"],
              "description": "Distributed storage/index model behind this query surface."
            },
            "count": { "type": "integer", "minimum": 0 },
            "limit": { "type": "integer", "minimum": 1, "maximum": 1000 },
            "truncated": { "type": "boolean" },
            "note": { "type": "string" },
            "quads": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["graph", "subject", "predicate", "object"],
                "properties": {
                  "graph": {
                    "type": "array",
                    "items": { "type": "integer", "minimum": 0, "maximum": 255 }
                  },
                  "subject": {
                    "type": "array",
                    "items": { "type": "integer", "minimum": 0, "maximum": 255 }
                  },
                  "predicate": { "type": "string" },
                  "object": { "type": "object" }
                }
              }
            }
          }
        }
      }
    }
  }
}
