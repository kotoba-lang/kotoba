{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.vault.get",
  "defs": {
    "main": {
      "type": "query",
      "description": "Read an operator-trusted private vault blob by multibase CID. This endpoint requires operator authorization; public block.get does not serve vault blobs.",
      "parameters": {
        "type": "params",
        "required": ["cid"],
        "properties": {
          "cid": {
            "type": "string",
            "maxLength": 512,
            "description": "Private vault multibase CID returned by vault.put."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["cid", "data_b64"],
          "properties": {
            "cid": {
              "type": "string",
              "description": "Private vault multibase CID that was read."
            },
            "data_b64": {
              "type": "string",
              "description": "Base64-encoded private vault blob bytes."
            }
          }
        }
      }
    }
  }
}
