{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.vault.put",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Store an operator-trusted private vault blob by CID. This endpoint requires operator authorization. Vault blobs are not served by public block.get.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["data_b64"],
          "properties": {
            "data_b64": {
              "type": "string",
              "maxLength": 10485760,
              "description": "Base64-encoded private vault blob bytes."
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["cid", "size"],
          "properties": {
            "cid": {
              "type": "string",
              "description": "Private vault CID for retrieval through vault.get."
            },
            "size": {
              "type": "integer",
              "minimum": 0,
              "description": "Decoded blob size in bytes."
            }
          }
        }
      }
    }
  }
}
