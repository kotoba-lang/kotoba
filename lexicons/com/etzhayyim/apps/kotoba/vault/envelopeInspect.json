{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.vault.envelopeInspect",
  "defs": {
    "main": {
      "type": "query",
      "description": "Inspect non-secret envelope manifest metadata, including recipient ids, wrap algorithms, and readable current or stale status. This endpoint requires operator authorization. Wrapped DEKs and plaintext are never returned. Deleted manifests are reported as gone when a cleanup tombstone is retained. Malformed or unreadable current pointers are reported as unknown.",
      "parameters": {
        "type": "params",
        "required": ["manifest_cid"],
        "properties": {
          "manifest_cid": {
            "type": "string",
            "maxLength": 512,
            "description": "CID of the envelope manifest to inspect."
          },
          "ct_cid": {
            "type": "string",
            "maxLength": 512,
            "description": "Optional expected ciphertext CID. If present, it must match the manifest before metadata is returned."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "ct_cid",
            "manifest_cid",
            "current_status",
            "version",
            "content_alg",
            "aad_b64",
            "recipients",
            "wraps"
          ],
          "properties": {
            "ct_cid": {
              "type": "string",
              "maxLength": 512,
              "description": "Ciphertext CID referenced by the manifest."
            },
            "manifest_cid": {
              "type": "string",
              "maxLength": 512,
              "description": "Inspected envelope manifest CID."
            },
            "current_manifest_cid": {
              "type": "string",
              "maxLength": 512,
              "description": "Readable current manifest pointer for this ciphertext CID, when known by the node."
            },
            "current_status": {
              "type": "string",
              "knownValues": ["current", "stale", "unknown"],
              "description": "One of current, stale, or unknown. Unknown includes a missing, malformed, or unreadable current pointer."
            },
            "version": {
              "type": "integer",
              "minimum": 0,
              "description": "Envelope manifest version."
            },
            "content_alg": {
              "type": "string",
              "knownValues": ["AES-256-GCM"],
              "maxLength": 11,
              "description": "Content encryption algorithm label."
            },
            "aad_b64": {
              "type": "string",
              "maxLength": 87384,
              "description": "Base64-encoded associated data authenticated by the content encryption."
            },
            "recipients": {
              "type": "array",
              "maxLength": 1024,
              "items": { "type": "string", "minLength": 1, "maxLength": 512 },
              "description": "Recipient ids present in the manifest."
            },
            "wraps": {
              "type": "array",
              "maxLength": 1024,
              "description": "Non-secret recipient wrap metadata.",
              "items": {
                "type": "object",
                "required": ["recipient", "wrap_alg"],
                "properties": {
                  "recipient": { "type": "string", "minLength": 1, "maxLength": 512 },
                  "wrap_alg": {
                    "type": "string",
                    "knownValues": ["AES-256-GCM-KW"],
                    "maxLength": 64
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
