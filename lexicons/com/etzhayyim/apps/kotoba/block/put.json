      "description": "Store a content-addressed IPLD block and return its CID.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["data_b64"],
          "properties": {
            "data_b64": { "type": "string" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["cid"],
          "properties": {
            "cid": {
              "type": "string",
              "description": "Content-addressed CID for the stored IPLD/DAG-CBOR block."
            }
          }
        }
      }
    }
  }
