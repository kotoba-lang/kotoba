{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.block.get",
  "defs": {
    "main": {
      "type": "query",
      "description": "Fetch a content-addressed IPLD/DAG-CBOR block by CID.",
      "parameters": {
        "type": "params",
        "required": ["cid"],
        "properties": {
          "cid": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["cid", "data_b64"],
          "properties": {
            "cid": {
              "type": "string",
              "description": "Content-addressed CID for the returned IPLD/DAG-CBOR block."
            },
            "data_b64": {
              "type": "string",
              "description": "Base64-encoded raw block bytes."
            }
          }
        }
      }
    }
  }
}
