{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.commit.store",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Publish a graph commit through the content-addressed BlockStore commit path.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph", "author", "seq"],
          "properties": {
            "graph": { "type": "string" },
            "author": { "type": "string" },
            "seq": { "type": "integer", "minimum": 0 },
            "cacao_b64": { "type": "string" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["cid"],
          "properties": {
            "cid": {
              "type": "string",
              "description": "CID of the newly stored graph commit."
            }
          }
        }
      }
    }
  }
}
