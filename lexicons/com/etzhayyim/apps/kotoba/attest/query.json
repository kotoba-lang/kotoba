{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.attest.query",
  "defs": {
    "main": {
      "type": "query",
      "description": "Query Kotoba attestation Verifiable Credential records by entity or attester DID.",
      "parameters": {
        "type": "params",
        "properties": {
          "entity_did": { "type": "string" },
          "attester_did": { "type": "string" },
          "limit": { "type": "integer", "minimum": 1, "maximum": 100 }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["claims", "total"],
          "properties": {
            "claims": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "claim_cid",
                  "credential_cid",
                  "credential_id",
                  "credential_type",
                  "credential_wire_format",
                  "credential_data_model",
                  "credential_status",
                  "entity_did",
                  "claim_type",
                  "attester_did",
                  "stake_mkoto",
                  "ts_unix"
                ],
                "properties": {
                  "claim_cid": { "type": "string" },
                  "credential_cid": { "type": "string" },
                  "credential_id": { "type": "string" },
                  "credential_type": { "type": "string" },
                  "credential_wire_format": { "type": "string" },
                  "credential_data_model": { "type": "string" },
                  "credential_status": { "type": "string" },
                  "entity_did": { "type": "string" },
                  "claim_type": { "type": "string" },
                  "attester_did": { "type": "string" },
                  "stake_mkoto": { "type": "integer", "minimum": 0 },
                  "ts_unix": { "type": "integer", "minimum": 0 }
                }
              }
            },
            "total": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
