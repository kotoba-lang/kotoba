{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.attest.challenge",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Challenge an existing Kotoba attestation claim.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["claim_cid", "challenger_did", "reason"],
          "properties": {
            "claim_cid": { "type": "string" },
            "challenger_did": { "type": "string" },
            "reason": { "type": "string" },
            "cacao_b64": { "type": "string" },
            "auth_presentation": {
              "type": "object",
              "required": ["@context", "id", "type", "proof"],
              "properties": {
                "@context": { "type": "array", "items": { "type": "string" } },
                "id": { "type": "string" },
                "type": { "type": "array", "items": { "type": "string" } },
                "holder": { "type": "string" },
                "verifiableCredential": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "proof": {
                  "type": "object",
                  "required": ["type", "proofPurpose", "verificationMethod", "proofValue"],
                  "properties": {
                    "type": { "type": "string" },
                    "cryptosuite": { "type": "string" },
                    "proofPurpose": { "type": "string" },
                    "verificationMethod": { "type": "string" },
                    "created": { "type": "string" },
                    "proofValue": { "type": "string" },
                    "challenge": { "type": "string" },
                    "domain": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["status", "challenge_cid", "commit_cid", "ipns_name", "ipns_sequence"],
          "properties": {
            "status": { "type": "string", "knownValues": ["challenged"] },
            "challenge_cid": { "type": "string" },
            "commit_cid": { "type": "string" },
            "ipns_name": { "type": "string" },
            "ipns_sequence": { "type": "integer" }
          }
        }
      }
    }
  }
}
