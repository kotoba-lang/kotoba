{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.datomic.sync",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Return the current distributed Datomic IPNS head and whether it includes an optional target transaction CID. When remote_peer is supplied, materialize the remote DAG-CBOR/Prolly blocks and IPNS record into the local node.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "graph"
          ],
          "properties": {
            "graph": {
              "type": "string"
            },
            "tx": {
              "type": "string"
            },
            "remote_peer": {
              "type": "string",
              "description": "Optional host:port or /ip4/<addr>/tcp/<port> kotoba-ipfs peer used to resolve and sync the graph IPNS head and DAG-CBOR/Prolly blocks."
            },
            "remote_ipns_name": {
              "type": "string",
              "description": "Optional IPNS name override for remote reads. Defaults to the graph canonical k51-kotoba-{graph} head."
            },
            "cacao_b64": {
              "type": "string"
            },
            "presentation": {
              "type": "object",
              "required": [
                "@context",
                "id",
                "type"
              ],
              "properties": {
                "@context": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "id": {
                  "type": "string"
                },
                "type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "holder": {
                  "type": "string"
                },
                "verifiableCredential": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                },
                "proof": {
                  "type": "object",
                  "required": [
                    "type",
                    "proofPurpose",
                    "verificationMethod",
                    "proofValue"
                  ],
                  "properties": {
                    "type": {
                      "type": "string"
                    },
                    "cryptosuite": {
                      "type": "string"
                    },
                    "proofPurpose": {
                      "type": "string"
                    },
                    "verificationMethod": {
                      "type": "string"
                    },
                    "created": {
                      "type": "string"
                    },
                    "proofValue": {
                      "type": "string"
                    },
                    "challenge": {
                      "type": "string"
                    },
                    "domain": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "graph",
            "commit_cid",
            "ipns_name",
            "ipns_sequence",
            "reached"
          ],
          "properties": {
            "graph": {
              "type": "string"
            },
            "basis_t": {
              "type": "string"
            },
            "commit_cid": {
              "type": "string"
            },
            "ipns_name": {
              "type": "string"
            },
            "ipns_sequence": {
              "type": "integer"
            },
            "target_tx": {
              "type": "string"
            },
            "reached": {
              "type": "boolean"
            },
            "synced_block_count": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    }
  }
}
