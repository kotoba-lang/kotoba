{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.datomic.q",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Datomic Datalog query against a Kotoba distributed Datom graph. Supports EDN query forms, inputs, :as-of/:since transaction bases, history queries, pull expressions, rules, Datomic aggregates including median/variance/stddev, fulltext relation bindings, :keys/:strs/:syms map returns as rows_map_edn and rows_map_json, optional remote kotoba-ipfs/IPNS peer reads, and CACAO or Verifiable Presentation read authorization.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph", "query_edn"],
          "properties": {
            "graph": { "type": "string" },
            "query_edn": { "type": "string" },
            "inputs_edn": { "type": "array", "items": { "type": "string" } },
            "as_of": { "type": "string" },
            "since": { "type": "string" },
            "history": { "type": "boolean" },
            "remote_peer": {
              "type": "string",
              "description": "Optional host:port or /ip4/<addr>/tcp/<port> kotoba-ipfs peer used to resolve the graph IPNS head and DAG-CBOR/Prolly blocks."
            },
            "remote_ipns_name": {
              "type": "string",
              "description": "Optional IPNS name override for remote reads. Defaults to the graph canonical k51-kotoba-{graph} head."
            },
            "cacao_b64": { "type": "string" },
            "presentation": {
              "type": "object",
              "required": ["@context", "id", "type"],
              "properties": {
                "@context": { "type": "array", "items": { "type": "string" } },
                "id": { "type": "string" },
                "type": { "type": "array", "items": { "type": "string" } },
                "holder": { "type": "string" },
                "verifiableCredential": { "type": "array", "items": { "type": "object" } },
                "proof": {
                  "type": "object",
                  "required": ["type", "proofPurpose", "verificationMethod", "proofValue"],
                  "properties": {
                    "type": { "type": "string" },
                    "cryptosuite": { "type": "string" },
                    "proofPurpose": { "type": "string" },
                    "verificationMethod": { "type": "string" },
                    "created": { "type": "string" },
                    "proofValue": { "type": "string" },
                    "challenge": { "type": "string" },
                    "domain": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph", "rows_edn"],
          "properties": {
            "graph": { "type": "string" },
            "basis_t": { "type": "string" },
            "rows_edn": {
              "type": "array",
              "items": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "rows_map_edn": {
              "type": "array",
              "items": { "type": "string" }
            },
            "rows_map_json": {
              "type": "array",
              "items": {
                "type": "object",
                "description": "A Datomic :keys/:strs/:syms row map. Keys are the projected map keys; values are EDN strings preserving Datomic values.",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
