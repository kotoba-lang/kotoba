{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.datomic.with",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Apply Datomic tx data to a Kotoba distributed Datom DB value without committing a new IPNS head.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph", "tx_edn"],
          "properties": {
            "graph": { "type": "string" },
            "tx_edn": { "type": "string" },
            "as_of": { "type": "string" },
            "since": { "type": "string" },
            "remote_peer": { "type": "string" },
            "remote_ipns_name": { "type": "string" },
            "cacao_b64": { "type": "string" },
            "presentation": {
              "type": "object",
              "required": ["@context", "id", "type"],
              "properties": {
                "@context": { "type": "array", "items": { "type": "string" } },
                "id": { "type": "string" },
                "type": { "type": "array", "items": { "type": "string" } },
                "holder": { "type": "string" },
                "verifiableCredential": { "type": "array", "items": { "type": "object" } },
                "proof": {
                  "type": "object",
                  "required": ["type", "proofPurpose", "verificationMethod", "proofValue"],
                  "properties": {
                    "type": { "type": "string" },
                    "cryptosuite": { "type": "string" },
                    "proofPurpose": { "type": "string" },
                    "verificationMethod": { "type": "string" },
                    "created": { "type": "string" },
                    "proofValue": { "type": "string" },
                    "challenge": { "type": "string" },
                    "domain": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "status",
            "graph",
            "tx_cid",
            "tempids",
            "tx_data",
            "db_after_datoms"
          ],
          "properties": {
            "status": { "type": "string" },
            "graph": { "type": "string" },
            "db_before_basis_t": { "type": "string" },
            "db_after_basis_t": { "type": "string" },
            "tx_cid": { "type": "string" },
            "tempids": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "tx_data": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["e", "a", "v_edn", "t", "added"],
                "properties": {
                  "e": { "type": "string" },
                  "a": { "type": "string" },
                  "v_edn": { "type": "string" },
                  "t": { "type": "string" },
                  "added": { "type": "boolean" }
                }
              }
            },
            "db_after_datoms": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["e", "a", "v_edn", "t", "added"],
                "properties": {
                  "e": { "type": "string" },
                  "a": { "type": "string" },
                  "v_edn": { "type": "string" },
                  "t": { "type": "string" },
                  "added": { "type": "boolean" }
                }
              }
            }
          }
        }
      }
    }
  }
}
