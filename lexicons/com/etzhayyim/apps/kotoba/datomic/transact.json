{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.datomic.transact",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Append Datomic transaction data to a Kotoba distributed Datom graph.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph", "tx_edn"],
          "properties": {
            "graph": { "type": "string" },
            "tx_edn": { "type": "string" },
            "ipns_name": {
              "type": "string",
              "description": "Optional distributed mutable head name for the write. Defaults to the graph canonical k51-kotoba-{graph} IPNS head."
            },
            "cacao_b64": { "type": "string" },
            "presentation": {
              "type": "object",
              "required": ["@context", "id", "type"],
              "properties": {
                "@context": { "type": "array", "items": { "type": "string" } },
                "id": { "type": "string" },
                "type": { "type": "array", "items": { "type": "string" } },
                "holder": { "type": "string" },
                "verifiableCredential": { "type": "array", "items": { "type": "object" } },
                "proof": {
                  "type": "object",
                  "required": ["type", "proofPurpose", "verificationMethod", "proofValue"],
                  "properties": {
                    "type": { "type": "string" },
                    "cryptosuite": { "type": "string" },
                    "proofPurpose": { "type": "string" },
                    "verificationMethod": { "type": "string" },
                    "created": { "type": "string" },
                    "proofValue": { "type": "string" },
                    "challenge": { "type": "string" },
                    "domain": { "type": "string" }
                  }
                }
              }
            },
            "expected_parent": { "type": "string" },
            "cacao_proof_cid": { "type": "string" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "status",
            "graph",
            "tx_cid",
            "commit_cid",
            "ipns_name",
            "ipns_sequence",
            "ipns_valid_until",
            "index_roots",
            "datom_count",
            "journal_cids",
            "tempids",
            "datoms"
          ],
          "properties": {
            "status": { "type": "string" },
            "graph": { "type": "string" },
            "tx_cid": { "type": "string" },
            "commit_cid": { "type": "string" },
            "auth_proof_cid": { "type": "string" },
            "ipns_name": { "type": "string" },
            "ipns_sequence": { "type": "integer", "minimum": 0 },
            "ipns_valid_until": { "type": "string" },
            "index_roots": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "datom_count": { "type": "integer", "minimum": 0 },
            "journal_cids": {
              "type": "array",
              "items": { "type": "string" }
            },
            "tempids": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "datoms": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["e", "a", "v_edn", "t", "added"],
                "properties": {
                  "e": { "type": "string" },
                  "a": { "type": "string" },
                  "v_edn": { "type": "string" },
                  "t": { "type": "string" },
                  "added": { "type": "boolean" }
                }
              }
            }
          }
        }
      }
    }
  }
}
