{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.atproto.repo.write",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Project an AT Protocol repo write into Kotoba Datoms, preserving AT URI, record CID, and DAG-CBOR CID metadata when present.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph", "uri"],
          "properties": {
            "graph": { "type": "string" },
            "uri": { "type": "string" },
            "operation": { "type": "string", "knownValues": ["create", "update", "delete"] },
            "cid": { "type": "string" },
            "record": { "type": "object" },
            "cacao_b64": { "type": "string" },
            "auth_presentation": {
              "type": "object",
              "required": ["@context", "id", "type"],
              "properties": {
                "@context": { "type": "array", "items": { "type": "string" } },
                "id": { "type": "string" },
                "type": { "type": "array", "items": { "type": "string" } },
                "holder": { "type": "string" },
                "verifiableCredential": { "type": "array", "items": { "type": "object" } },
                "proof": {
                  "type": "object",
                  "required": ["type", "proofPurpose", "verificationMethod", "proofValue"],
                  "properties": {
                    "type": { "type": "string" },
                    "cryptosuite": { "type": "string" },
                    "proofPurpose": { "type": "string" },
                    "verificationMethod": { "type": "string" },
                    "created": { "type": "string" },
                    "proofValue": { "type": "string" },
                    "challenge": { "type": "string" },
                    "domain": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "status",
            "graph",
            "entity_cid",
            "tx_cid",
            "commit_cid",
            "ipns_name",
            "ipns_sequence",
            "ipns_valid_until",
            "index_roots",
            "datom_count",
            "assert_count",
            "retract_count",
            "journal_cids"
          ],
          "properties": {
            "status": { "type": "string" },
            "graph": { "type": "string" },
            "entity_cid": { "type": "string" },
            "tx_cid": { "type": "string" },
            "commit_cid": { "type": "string" },
            "auth_proof_cid": { "type": "string" },
            "ipns_name": { "type": "string" },
            "ipns_sequence": { "type": "integer", "minimum": 0 },
            "ipns_valid_until": { "type": "string" },
            "index_roots": { "type": "object" },
            "datom_count": { "type": "integer", "minimum": 0 },
            "assert_count": { "type": "integer", "minimum": 0 },
            "retract_count": { "type": "integer", "minimum": 0 },
            "journal_cids": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
