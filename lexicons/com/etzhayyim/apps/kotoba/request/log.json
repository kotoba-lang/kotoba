{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.request.log",
  "defs": {
    "main": {
      "type": "query",
      "description": "Query the operator-only Kotoba request audit log.",
      "parameters": {
        "type": "params",
        "properties": {
          "path_prefix": {
            "type": "string",
            "maxLength": 1024,
            "description": "Filter by request path prefix; control characters are rejected."
          },
          "limit": { "type": "integer", "minimum": 1, "maximum": 100 }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["entries", "total"],
          "properties": {
            "entries": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["request_cid", "method", "path", "ts_unix"],
                "properties": {
                  "request_cid": { "type": "string" },
                  "method": { "type": "string" },
                  "path": { "type": "string" },
                  "ts_unix": { "type": "integer", "minimum": 0 }
                }
              }
            },
            "total": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
