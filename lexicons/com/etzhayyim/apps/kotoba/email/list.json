{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.email.list",
  "defs": {
    "main": {
      "type": "query",
      "description": "List encrypted email metadata for one owner DID.",
      "parameters": {
        "type": "params",
        "required": ["owner_did"],
        "properties": {
            "owner_did": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512,
              "pattern": "^did:[!-~]+$",
              "description": "DID of the mailbox owner."
            },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200
          },
          "offset": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10000
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["emails", "total", "offset", "limit"],
          "properties": {
            "emails": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["cid", "date", "message_id"],
                "properties": {
                  "cid": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "pattern": "^[!-~]+$"
                  },
                  "date": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 64,
                    "pattern": "^[!-~]+$"
                  },
                  "message_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 998,
                    "pattern": "^[!-~]+$"
                  },
                  "enc": { "type": "string", "knownValues": ["signal:v1"] },
                  "recipient_device": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128,
                    "pattern": "^[!-~]+$"
                  }
                }
              }
            },
            "total": { "type": "integer", "minimum": 0 },
            "offset": { "type": "integer", "minimum": 0, "maximum": 10000 },
            "limit": { "type": "integer", "minimum": 1, "maximum": 200 }
          }
        }
      }
    }
  }
}
