{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.email.send",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Deliver zero-access Signal-sealed email envelopes to recipient inboxes.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["senderDid", "recipients"],
          "properties": {
            "senderDid": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512,
              "pattern": "^did:[!-~]+$",
              "description": "DID of the authenticated sender."
            },
            "threadId": {
              "type": "string",
              "maxLength": 256,
              "pattern": "^[!-~]*$"
            },
            "recipients": {
              "type": "array",
              "minLength": 1,
              "maxLength": 256,
              "description": "One SignalMessage per recipient device. A request must not include duplicate recipientDid + deviceId pairs.",
              "items": {
                "type": "object",
                "required": [
                  "messageType",
                  "senderDid",
                  "recipientDid",
                  "deviceId",
                  "ciphertextEnvelope",
                  "timestamp"
                ],
                "properties": {
                  "messageType": {
                    "type": "string",
                    "knownValues": ["directMessage", "groupMessage", "receipt"],
                    "description": "Signal message type. groupMessage requires groupId; directMessage and receipt must leave groupId absent."
                  },
                  "senderDid": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 512,
                    "pattern": "^did:[!-~]+$"
                  },
                  "recipientDid": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 512,
                    "pattern": "^did:[!-~]+$"
                  },
                  "deviceId": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128,
                    "pattern": "^[!-~]+$"
                  },
                  "groupId": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "pattern": "^[!-~]+$",
                    "description": "Required for groupMessage and absent otherwise."
                  },
                  "ciphertextEnvelope": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 1048576,
                    "pattern": "^[!-~]+$"
                  },
                  "timestamp": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 64,
                    "pattern": "^[!-~]+$"
                  },
                  "ephemeralKey": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 512,
                    "pattern": "^[!-~]+$"
                  },
                  "oneTimePrekeyId": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 4294967295
                  }
                }
              }
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["status", "count", "delivered"],
          "properties": {
            "status": { "type": "string", "knownValues": ["ok"] },
            "count": { "type": "integer", "minimum": 0 },
            "delivered": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["recipientDid", "emailCid", "bodyCid", "commitCid"],
                "properties": {
                  "recipientDid": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 512,
                    "pattern": "^did:[!-~]+$"
                  },
                  "emailCid": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "pattern": "^[!-~]+$"
                  },
                  "bodyCid": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "pattern": "^[!-~]+$"
                  },
                  "commitCid": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "pattern": "^[!-~]+$"
                  }
                }
              }
            },
            "deliveredSoFar": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["recipientDid", "emailCid", "bodyCid", "commitCid"],
                "properties": {
                  "recipientDid": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 512,
                    "pattern": "^did:[!-~]+$"
                  },
                  "emailCid": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "pattern": "^[!-~]+$"
                  },
                  "bodyCid": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "pattern": "^[!-~]+$"
                  },
                  "commitCid": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "pattern": "^[!-~]+$"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
