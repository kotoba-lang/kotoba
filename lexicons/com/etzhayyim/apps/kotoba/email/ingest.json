{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.email.ingest",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Manually ingest and encrypt one raw RFC 2822 email message.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["owner_did", "raw_b64"],
          "properties": {
            "owner_did": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512,
              "pattern": "^did:[!-~]+$",
              "description": "DID of the mailbox owner."
            },
            "raw_b64": {
              "type": "string",
              "minLength": 1,
              "maxLength": 35651584,
              "description": "Standard-base64 raw RFC 2822 message; decoded message is capped at 26214400 bytes."
            },
            "thread_id": {
              "type": "string",
              "maxLength": 256,
              "pattern": "^[!-~]*$"
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["status", "email_cid", "commit_cid", "ipns_name", "ipns_sequence"],
          "properties": {
            "status": { "type": "string", "knownValues": ["ok"] },
            "email_cid": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "pattern": "^[!-~]+$"
            },
            "commit_cid": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "pattern": "^[!-~]+$"
            },
            "ipns_name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "pattern": "^[!-~]+$"
            },
            "ipns_sequence": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
