{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.kotoba.email.read",
  "defs": {
    "main": {
      "type": "query",
      "description": "Read one encrypted email for an owner DID.",
      "parameters": {
        "type": "params",
        "required": ["owner_did", "email_cid"],
        "properties": {
          "owner_did": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512,
            "pattern": "^did:[!-~]+$",
            "description": "DID of the mailbox owner."
          },
          "email_cid": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "pattern": "^[!-~]+$",
            "description": "Email CID; must contain only visible ASCII characters."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["email_cid", "message_id", "from", "to", "date", "thread_id"],
          "properties": {
            "email_cid": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "pattern": "^[!-~]+$"
            },
            "message_id": {
              "type": "string",
              "minLength": 1,
              "maxLength": 998,
              "pattern": "^[!-~]+$"
            },
            "from": { "type": "string", "maxLength": 4096, "pattern": "^[!-~]*$" },
            "to": { "type": "string", "maxLength": 4096, "pattern": "^[!-~]*$" },
            "subject": { "type": "string", "maxLength": 998, "pattern": "^[!-~]*$" },
            "date": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "pattern": "^[!-~]+$"
            },
            "thread_id": {
              "type": "string",
              "maxLength": 256,
              "pattern": "^[!-~]*$"
            },
            "body": { "type": "string" },
            "enc": { "type": "string", "knownValues": ["signal:v1"] },
            "signalMessage": {
              "type": "object",
              "required": [
                "messageType",
                "senderDid",
                "recipientDid",
                "deviceId",
                "ciphertextEnvelope",
                "timestamp"
              ],
              "properties": {
                "messageType": {
                  "type": "string",
                  "knownValues": ["directMessage", "groupMessage", "receipt"],
                  "description": "Signal message type. groupMessage requires groupId; directMessage and receipt must leave groupId absent."
                },
                "senderDid": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 512,
                  "pattern": "^did:[!-~]+$"
                },
                "recipientDid": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 512,
                  "pattern": "^did:[!-~]+$"
                },
                "deviceId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128,
                  "pattern": "^[!-~]+$"
                },
                "groupId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "pattern": "^[!-~]+$",
                  "description": "Required for groupMessage and absent otherwise."
                },
                "ciphertextEnvelope": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 1048576,
                  "pattern": "^[!-~]+$"
                },
                "timestamp": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 64,
                  "pattern": "^[!-~]+$"
                },
                "ephemeralKey": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 512,
                  "pattern": "^[!-~]+$"
                },
                "oneTimePrekeyId": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 4294967295
                }
              }
            }
          }
        }
      }
    }
  }
}
