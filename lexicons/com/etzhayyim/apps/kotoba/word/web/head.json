{
  "defs": {
    "main": {
      "description": "Fetch a URL and report status / content type (host restricted by net cap). [caps: net:example.com] [executor: Http:https://example.com]",
      "output": {
        "encoding": "application/json",
        "schema": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "properties": {
            "body_bytes": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            },
            "content_type": {
              "type": "string"
            },
            "status": {
              "format": "uint16",
              "maximum": 65535,
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "status",
            "content_type",
            "body_bytes"
          ],
          "title": "WebHeadOutput",
          "type": "object"
        }
      },
      "parameters": {
        "properties": {
          "url": {
            "description": "URL to fetch. The host must be covered by the word's `net:` cap.",
            "type": "string"
          }
        },
        "required": [
          "url"
        ],
        "type": "params"
      },
      "type": "query"
    }
  },
  "id": "com.etzhayyim.apps.kotoba.word.web.head",
  "lexicon": 1
}
