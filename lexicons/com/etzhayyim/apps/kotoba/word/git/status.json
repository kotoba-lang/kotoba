{
  "defs": {
    "main": {
      "description": "Structured `git status` of a local repository (wraps the real git binary). [caps: proc:git] [executor: Process:git]",
      "output": {
        "encoding": "application/json",
        "schema": {
          "$defs": {
            "GitFile": {
              "properties": {
                "path": {
                  "type": "string"
                },
                "status": {
                  "description": "Two-letter porcelain status code (e.g. \" M\", \"??\").",
                  "type": "string"
                }
              },
              "required": [
                "status",
                "path"
              ],
              "type": "object"
            }
          },
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "properties": {
            "branch": {
              "type": [
                "string",
                "null"
              ]
            },
            "clean": {
              "type": "boolean"
            },
            "files": {
              "items": {
                "$ref": "#/$defs/GitFile"
              },
              "type": "array"
            }
          },
          "required": [
            "clean",
            "files"
          ],
          "title": "GitStatusOutput",
          "type": "object"
        }
      },
      "parameters": {
        "properties": {
          "dir": {
            "description": "Path to the repository working tree.",
            "type": "string"
          }
        },
        "required": [
          "dir"
        ],
        "type": "params"
      },
      "type": "query"
    }
  },
  "id": "com.etzhayyim.apps.kotoba.word.git.status",
  "lexicon": 1
}
