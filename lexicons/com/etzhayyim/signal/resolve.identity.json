{
  "lexicon": 1,
  "id": "com.etzhayyim.signal.resolve.identity",
  "defs": {
    "main": {
      "type": "query",
      "description": "Resolve and verify the DID-signed Signal identity binding for a DID.",
      "parameters": {
        "type": "params",
        "required": ["did"],
        "properties": {
          "did": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^did:[!-~]+$" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["did", "signalIdentityKey", "signalDhKey", "signalRegistrationId", "createdAt", "signature", "verified", "verificationMethod"],
          "properties": {
            "did": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^did:[!-~]+$" },
            "signalIdentityKey": { "type": "string", "minLength": 43, "maxLength": 43, "pattern": "^[A-Za-z0-9_-]+$" },
            "signalDhKey": { "type": "string", "minLength": 43, "maxLength": 43, "pattern": "^[A-Za-z0-9_-]+$" },
            "signalRegistrationId": { "type": "integer", "minimum": 0, "maximum": 16383 },
            "createdAt": {
              "type": "string",
              "minLength": 20,
              "maxLength": 20,
              "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
            },
            "signature": { "type": "string", "minLength": 86, "maxLength": 86, "pattern": "^[A-Za-z0-9_-]+$" },
            "verified": { "type": "boolean" },
            "verificationMethod": { "type": "string", "minLength": 1, "maxLength": 512 }
          }
        }
      }
    }
  }
}
