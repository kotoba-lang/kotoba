{
  "lexicon": 1,
  "id": "com.etzhayyim.signal.register.prekeys",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Register a canonical Signal identity key and X3DH pre-key bundle for one DID device.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["did", "deviceId", "identityKey", "prekeyBundle"],
          "properties": {
            "did": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^did:[!-~]+$" },
            "deviceId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9._-]+$"
            },
            "identityKey": { "type": "ref", "ref": "#identityKey" },
            "prekeyBundle": { "type": "ref", "ref": "#prekeyBundle" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["status", "did"],
          "properties": {
            "status": { "type": "string", "knownValues": ["ok"] },
            "did": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^did:[!-~]+$" }
          }
        }
      }
    },
    "identityKey": {
      "type": "object",
      "required": ["signing", "dh"],
      "properties": {
        "signing": { "type": "array", "length": 32, "items": { "type": "integer", "minimum": 0, "maximum": 255 } },
        "dh": { "type": "array", "length": 32, "items": { "type": "integer", "minimum": 0, "maximum": 255 } }
      }
    },
    "prekeyBundle": {
      "type": "object",
      "required": ["did", "device_id", "identity_key", "signed_prekey", "signed_prekey_id", "signed_prekey_sig"],
      "properties": {
        "did": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^did:[!-~]+$" },
        "device_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "identity_key": { "type": "ref", "ref": "#identityKey" },
        "signed_prekey": { "type": "array", "length": 32, "items": { "type": "integer", "minimum": 0, "maximum": 255 } },
        "signed_prekey_id": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "signed_prekey_sig": { "type": "array", "length": 64, "items": { "type": "integer", "minimum": 0, "maximum": 255 } },
        "one_time_prekey": { "type": "array", "length": 32, "items": { "type": "integer", "minimum": 0, "maximum": 255 } },
        "one_time_prekey_id": { "type": "integer", "minimum": 0, "maximum": 4294967295 }
      }
    }
  }
}
