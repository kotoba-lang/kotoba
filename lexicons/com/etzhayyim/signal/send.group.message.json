{
  "lexicon": 1,
  "id": "com.etzhayyim.signal.send.group.message",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Publish one canonical Signal SenderKey group message.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["groupId", "senderDid", "senderKeyMessage"],
          "properties": {
            "groupId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9._-]+$"
            },
            "senderDid": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^did:[!-~]+$" },
            "senderKeyMessage": { "type": "ref", "ref": "#senderKeyMessage" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["status", "messageId", "groupId"],
          "properties": {
            "status": { "type": "string", "knownValues": ["ok"] },
            "messageId": { "type": "string", "minLength": 1, "maxLength": 256, "pattern": "^[!-~]+$" },
            "groupId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9._-]+$"
            }
          }
        }
      }
    },
    "senderKeyMessage": {
      "type": "object",
      "required": ["group_id", "sender_did", "chain_id", "n", "ciphertext", "signature"],
      "properties": {
        "group_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "sender_did": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^did:[!-~]+$" },
        "chain_id": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "n": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "ciphertext": { "type": "array", "minLength": 28, "maxLength": 262144, "items": { "type": "integer", "minimum": 0, "maximum": 255 } },
        "signature": { "type": "array", "length": 64, "items": { "type": "integer", "minimum": 0, "maximum": 255 } }
      }
    }
  }
}
