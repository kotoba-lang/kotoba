{
  "lexicon": 1,
  "id": "com.etzhayyim.signal.get.prekey.bundle",
  "defs": {
    "main": {
      "type": "query",
      "description": "Resolve a validated canonical X3DH pre-key bundle for a DID device.",
      "parameters": {
        "type": "params",
        "required": ["did"],
        "properties": {
          "did": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^did:[!-~]+$" },
          "deviceId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9._-]+$"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["did", "deviceId", "identityKey", "bundle"],
          "properties": {
            "did": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^did:[!-~]+$" },
            "deviceId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9._-]+$"
            },
            "identityKey": { "type": "ref", "ref": "com.etzhayyim.signal.register.prekeys#identityKey" },
            "bundle": { "type": "ref", "ref": "com.etzhayyim.signal.register.prekeys#prekeyBundle" }
          }
        }
      }
    }
  }
}
