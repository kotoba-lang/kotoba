{
  "lexicon": 1,
  "id": "com.etzhayyim.signal.distribute.sender.key",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Deliver an encrypted SenderKey distribution envelope through a recipient's 1:1 Signal inbox.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["recipientDid", "recipientDevice", "signalMessage"],
          "properties": {
            "recipientDid": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^did:[!-~]+$" },
            "recipientDevice": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9._-]+$"
            },
            "signalMessage": {
              "type": "ref",
              "ref": "com.etzhayyim.signal.send.message#signalMessage",
              "description": "Signal message envelope carrying the SenderKey distribution. The server requires messageType=directMessage and recipientDid/deviceId to match recipientDid/recipientDevice."
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["status", "messageId"],
          "properties": {
            "status": { "type": "string", "knownValues": ["ok"] },
            "messageId": { "type": "string", "minLength": 1, "maxLength": 256, "pattern": "^[!-~]+$" }
          }
        }
      }
    }
  }
}
