{
  "lexicon": 1,
  "id": "com.etzhayyim.signal.publish.identity",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Publish a DID-signed binding to the canonical Signal identity keys for that DID.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["did", "signalIdentityKey", "signalDhKey", "signalRegistrationId", "createdAt", "signature"],
          "properties": {
            "did": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^did:[!-~]+$" },
            "signalIdentityKey": { "type": "string", "minLength": 43, "maxLength": 43, "pattern": "^[A-Za-z0-9_-]+$", "description": "base64url-no-pad Ed25519 public key, 32 decoded bytes." },
            "signalDhKey": { "type": "string", "minLength": 43, "maxLength": 43, "pattern": "^[A-Za-z0-9_-]+$", "description": "base64url-no-pad X25519 public key, 32 decoded bytes." },
            "signalRegistrationId": { "type": "integer", "minimum": 0, "maximum": 16383 },
            "createdAt": {
              "type": "string",
              "minLength": 20,
              "maxLength": 20,
              "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
              "description": "UTC RFC3339 timestamp with seconds precision, e.g. 2026-06-01T00:00:00Z."
            },
            "signature": { "type": "string", "minLength": 86, "maxLength": 86, "pattern": "^[A-Za-z0-9_-]+$", "description": "base64url-no-pad Ed25519 signature, 64 decoded bytes." }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["status", "did", "verifiedOnPublish"],
          "properties": {
            "status": { "type": "string", "knownValues": ["ok"] },
            "did": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^did:[!-~]+$" },
            "verifiedOnPublish": { "type": "boolean" }
          }
        }
      }
    }
  }
}
