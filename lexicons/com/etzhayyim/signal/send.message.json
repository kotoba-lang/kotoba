{
  "lexicon": 1,
  "id": "com.etzhayyim.signal.send.message",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Publish one canonical Signal message envelope to a recipient device inbox.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["signalMessage"],
          "properties": {
            "signalMessage": { "type": "ref", "ref": "#signalMessage" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["status", "messageId"],
          "properties": {
            "status": { "type": "string", "knownValues": ["ok"] },
            "messageId": { "type": "string", "minLength": 1, "maxLength": 256, "pattern": "^[!-~]+$" }
          }
        }
      }
    },
    "signalMessage": {
      "type": "object",
      "required": ["messageType", "senderDid", "recipientDid", "deviceId", "ciphertextEnvelope", "timestamp"],
      "properties": {
        "messageType": {
          "type": "string",
          "knownValues": ["directMessage", "groupMessage", "receipt"],
          "description": "When messageType=groupMessage, the server requires groupId; for directMessage or receipt, groupId must be absent."
        },
        "senderDid": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^did:[!-~]+$" },
        "recipientDid": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^did:[!-~]+$" },
        "deviceId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "groupId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._-]+$",
          "description": "groupId is required when messageType=groupMessage and must be absent otherwise."
        },
        "ciphertextEnvelope": {
          "type": "string",
          "minLength": 1,
          "maxLength": 262144,
          "pattern": "^[!-~]+$"
        },
        "timestamp": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[!-~]+$" },
        "ephemeralKey": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^[!-~]+$" },
        "oneTimePrekeyId": { "type": "integer", "minimum": 0, "maximum": 4294967295 }
      }
    }
  }
}
