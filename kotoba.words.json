{
  "version": 1,
  "root": "com.etzhayyim.apps.kotoba.word",
  "words": [
    {
      "nsid": "com.etzhayyim.apps.kotoba.word.git.status",
      "description": "Structured `git status` of a local repository (wraps the real git binary).",
      "mode": "query",
      "caps": [
        "proc:git"
      ],
      "input": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "dir": {
            "description": "Path to the repository working tree.",
            "type": "string"
          }
        },
        "required": [
          "dir"
        ],
        "title": "GitStatusInput",
        "type": "object"
      },
      "output": {
        "$defs": {
          "GitFile": {
            "properties": {
              "path": {
                "type": "string"
              },
              "status": {
                "description": "Two-letter porcelain status code (e.g. \" M\", \"??\").",
                "type": "string"
              }
            },
            "required": [
              "status",
              "path"
            ],
            "type": "object"
          }
        },
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "branch": {
            "type": [
              "string",
              "null"
            ]
          },
          "clean": {
            "type": "boolean"
          },
          "files": {
            "items": {
              "$ref": "#/$defs/GitFile"
            },
            "type": "array"
          }
        },
        "required": [
          "clean",
          "files"
        ],
        "title": "GitStatusOutput",
        "type": "object"
      },
      "executor": {
        "kind": "process",
        "ref": "git"
      }
    },
    {
      "nsid": "com.etzhayyim.apps.kotoba.word.math.add",
      "description": "Add two numbers.",
      "mode": "query",
      "caps": [],
      "input": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "a": {
            "format": "double",
            "type": "number"
          },
          "b": {
            "format": "double",
            "type": "number"
          }
        },
        "required": [
          "a",
          "b"
        ],
        "title": "AddInput",
        "type": "object"
      },
      "output": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "sum": {
            "format": "double",
            "type": "number"
          }
        },
        "required": [
          "sum"
        ],
        "title": "AddOutput",
        "type": "object"
      },
      "executor": {
        "kind": "closure",
        "ref": "inline"
      }
    },
    {
      "nsid": "com.etzhayyim.apps.kotoba.word.text.echo",
      "description": "Echo the input text back.",
      "mode": "query",
      "caps": [],
      "input": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "text": {
            "type": "string"
          }
        },
        "required": [
          "text"
        ],
        "title": "EchoInput",
        "type": "object"
      },
      "output": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "text": {
            "type": "string"
          }
        },
        "required": [
          "text"
        ],
        "title": "EchoInput",
        "type": "object"
      },
      "executor": {
        "kind": "closure",
        "ref": "inline"
      }
    },
    {
      "nsid": "com.etzhayyim.apps.kotoba.word.web.head",
      "description": "Fetch a URL and report status / content type (host restricted by net cap).",
      "mode": "query",
      "caps": [
        "net:example.com"
      ],
      "input": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "url": {
            "description": "URL to fetch. The host must be covered by the word's `net:` cap.",
            "type": "string"
          }
        },
        "required": [
          "url"
        ],
        "title": "WebHeadInput",
        "type": "object"
      },
      "output": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "body_bytes": {
            "format": "uint",
            "minimum": 0,
            "type": "integer"
          },
          "content_type": {
            "type": "string"
          },
          "status": {
            "format": "uint16",
            "maximum": 65535,
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "status",
          "content_type",
          "body_bytes"
        ],
        "title": "WebHeadOutput",
        "type": "object"
      },
      "executor": {
        "kind": "http",
        "ref": "https://example.com"
      }
    }
  ]
}
