                       (if (= tag 67) 1 (if (= tag 69) 2 -1))
                       (if (or (= phase 1) (= phase 2))
                         (if (= tag 90) 3 -1) -1))]
      (if (or (< declared 4) (> total remaining) (< next-phase 0)
              (= (pg-message-valid? message-ptr total) 0)
              (and (= tag 69) (= (pg-error-response-valid? message-ptr total) 0))
              (and (= tag 90) (= (pg-ready-for-query? message-ptr total) 0)))
        0
        (if (= total remaining)
          (if (= next-phase 3) 1 0)
          (if (= next-phase 3)
            0
            (pg-copy-in-final-valid-from? response-ptr response-len
                                          (+ offset total) next-phase)))))))

(defn pg-copy-out-valid [^:i64 channel query-ptr query-len
                          out-ptr out-cap meta-ptr meta-cap]
  (let [header (alloc 5)
        tag (byte-store! header 0 81)
        frame-len (+ query-len 5)
        len (pg-store-i32-be! (+ header 1) frame-len)
        zero (alloc 1)
        z (byte-store! zero 0 0)
        w0 (transport-write channel header 5)
        w1 (transport-write channel query-ptr query-len)
        w2 (transport-write channel zero 1)
        read-count (if (and (= w0 5) (= w1 query-len) (= w2 1))
                     (pg-read-until-ready channel out-ptr out-cap 0) -1)]
    (if (and (> read-count 0)
             (= (pg-copy-out-result-valid-from? out-ptr read-count 0 0) 1)
             (= (pg-result-write-meta! out-ptr read-count meta-ptr meta-cap) 7))
      read-count -1)))

(defn pg-copy-out [^:i64 channel query-ptr query-len
                    out-ptr out-cap meta-ptr meta-cap]
  (if (= (pg-query-text-valid? query-ptr query-len) 1)
    (pg-copy-out-valid channel query-ptr query-len
                       out-ptr out-cap meta-ptr meta-cap)
    -1))

(defn pg-copy-in-valid [^:i64 channel query-ptr query-len data-ptr data-len
                         out-ptr out-cap meta-ptr meta-cap]
  (let [query-header (alloc 5)
        qtag (byte-store! query-header 0 81)
        qlen (pg-store-i32-be! (+ query-header 1) (+ query-len 5))
        zero (alloc 1)
        z (byte-store! zero 0 0)
        q0 (transport-write channel query-header 5)
        q1 (transport-write channel query-ptr query-len)
        q2 (transport-write channel zero 1)
        first-five (if (and (= q0 5) (= q1 query-len) (= q2 1))
                     (pg-read-exact channel out-ptr 5 0) -1)
        declared (if (= first-five 5) (pg-message-length out-ptr 5) -1)
        first-total (+ declared 1)
        first-read (if (and (>= declared 4) (<= first-total out-cap))
                     (pg-read-exact channel out-ptr first-total 5) -1)
        first-tag (if (= first-read first-total) (mem-byte-at out-ptr 0) -1)]
    (if (= first-tag 69)
      (let [read-count (pg-read-until-ready channel out-ptr out-cap first-total)]
        (if (and (> read-count first-total)
                 (= (pg-copy-in-final-valid-from? out-ptr read-count 0 0) 1)
                 (= (pg-result-write-meta! out-ptr read-count meta-ptr meta-cap) 7))
          read-count -1))
      (if (and (= first-tag 71)
               (= (pg-copy-response-valid? out-ptr first-total 71) 1))
        (let [data-header (alloc 5)
              dtag (byte-store! data-header 0 100)
              dlen (pg-store-i32-be! (+ data-header 1) (+ data-len 4))
              done (alloc 5)
              ctag (byte-store! done 0 99)
              clen (pg-store-i32-be! (+ done 1) 4)
              w0 (transport-write channel data-header 5)
              w1 (transport-write channel data-ptr data-len)
              w2 (transport-write channel done 5)
              read-count (if (and (= w0 5) (= w1 data-len) (= w2 5))
                           (pg-read-until-ready channel out-ptr out-cap 0) -1)]
          (if (and (> read-count 0)
                   (= (pg-copy-in-final-valid-from? out-ptr read-count 0 0) 1)
                   (= (pg-result-write-meta! out-ptr read-count meta-ptr meta-cap) 7))
            read-count -1))
        -1))))

(defn pg-copy-in [^:i64 channel query-ptr query-len data-ptr data-len
                   out-ptr out-cap meta-ptr meta-cap]
  (if (and (= (pg-query-text-valid? query-ptr query-len) 1)
           (>= data-len 0) (<= data-len 4096))
    (pg-copy-in-valid channel query-ptr query-len data-ptr data-len
                      out-ptr out-cap meta-ptr meta-cap)
    -1))

(defn pg-batch-items-end [batch-ptr batch-len item-count index offset]
  (if (>= index item-count)
    offset
    (if (> (+ offset 2) batch-len)
      -1
      (let [name-len (pg-i16-be (+ batch-ptr offset))
            name-offset (+ offset 2)
            params-len-offset (+ name-offset name-len)]
        (if (or (> (+ params-len-offset 2) batch-len)
                (= (pg-statement-name-valid? (+ batch-ptr name-offset)
                                             name-len) 0))
          -1
          (let [params-len (pg-i16-be (+ batch-ptr params-len-offset))
                params-offset (+ params-len-offset 2)
                next-offset (+ params-offset params-len)]
            (if (or (> next-offset batch-len) (> params-len 4096)
                    (= (pg-bind-params-valid? (+ batch-ptr params-offset)
                                             params-len) 0))
              -1
              (pg-batch-items-end batch-ptr batch-len item-count
                                  (+ index 1) next-offset))))))))

(defn pg-batch-valid? [batch-ptr batch-len item-count]
  (if (and (> item-count 0) (<= item-count 8)
           (> batch-len 0) (<= batch-len 8192)
           (= (pg-batch-items-end batch-ptr batch-len item-count 0 0)
              batch-len)) 1 0))

(defn pg-batch-write-items [^:i64 channel batch-ptr item-count index offset]
  (if (>= index item-count)
    1
    (let [name-len (pg-i16-be (+ batch-ptr offset))
          name-ptr (+ batch-ptr offset 2)
          params-len-offset (+ offset 2 name-len)
          params-len (pg-i16-be (+ batch-ptr params-len-offset))
          params-ptr (+ batch-ptr params-len-offset 2)
          next-offset (+ params-len-offset 2 params-len)
          zero (alloc 1)
          z (byte-store! zero 0 0)
          bind-header (alloc 5)
          btag (byte-store! bind-header 0 66)
          blen (pg-store-i32-be! (+ bind-header 1)
                                 (+ 6 name-len params-len))
          execute (alloc 10)
          etag (byte-store! execute 0 69)
          elen (pg-store-i32-be! (+ execute 1) 9)
          ezero (byte-store! execute 5 0)
          emax (pg-store-i32-be! (+ execute 6) 0)
          w0 (transport-write channel bind-header 5)
          w1 (transport-write channel zero 1)
          w2 (transport-write channel name-ptr name-len)
          w3 (transport-write channel zero 1)
          w4 (transport-write channel params-ptr params-len)
          w5 (transport-write channel execute 10)]
      (if (and (= w0 5) (= w1 1) (= w2 name-len) (= w3 1)
               (= w4 params-len) (= w5 10))
        (pg-batch-write-items channel batch-ptr item-count
                              (+ index 1) next-offset)
        0))))

(defn pg-execute-batch-valid [^:i64 channel batch-ptr batch-len item-count
                               out-ptr out-cap meta-ptr meta-cap]
  (let [written (pg-batch-write-items channel batch-ptr item-count 0 0)
        sync (alloc 5)
        stag (byte-store! sync 0 83)
        slen (pg-store-i32-be! (+ sync 1) 4)
        sync-written (if (= written 1) (transport-write channel sync 5) -1)
        read-count (if (= sync-written 5)
                     (pg-read-until-ready channel out-ptr out-cap 0) -1)]
    (if (> read-count 0)
      (let [valid (pg-extended-result-valid-from? out-ptr read-count 0 0)
            error-kind (pg-query-result-has-error-from? out-ptr read-count 0)]
        (if (and (= valid 1)
                 (or (= error-kind 1)
                     (and (= error-kind 0)
                          (= (pg-result-count-tag-from out-ptr read-count 0 50 0)
                             item-count)
                          (= (pg-result-count-tag-from out-ptr read-count 0 67 0)
                             item-count)))
                 (= (pg-result-write-meta! out-ptr read-count meta-ptr meta-cap) 7))
          read-count -1))
      -1)))

(defn pg-execute-batch [^:i64 channel batch-ptr batch-len item-count
                         out-ptr out-cap meta-ptr meta-cap]
  (if (= (pg-batch-valid? batch-ptr batch-len item-count) 1)
    (pg-execute-batch-valid channel batch-ptr batch-len item-count
                            out-ptr out-cap meta-ptr meta-cap)
    -1))

(defn pg-session-reset [^:i64 channel out-ptr out-cap meta-ptr meta-cap]
  (let [rolled-back (pg-query-state-valid
                     channel (str-ptr "ROLLBACK") (str-len "ROLLBACK")
                     out-ptr out-cap meta-ptr meta-cap)]
    (if (and (> rolled-back 0) (= (mem-byte-at meta-ptr 0) 0))
      (let [discarded (pg-query-state-valid
                       channel (str-ptr "DISCARD ALL") (str-len "DISCARD ALL")
                       out-ptr out-cap meta-ptr meta-cap)]
        (if (and (> discarded 0) (= (mem-byte-at meta-ptr 0) 0)) discarded -1))
      -1)))

(defn main [] 0)
