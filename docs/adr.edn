[{:db/id -1, :docs.adr/schema 1, :docs.adr/updated "2026-07-02", :docs.adr/adrs "[{:id :adr-kotoba-wasm-clj-execution, :file \"ADR-kotoba-wasm-clj-execution.md\", :title \"kotoba wasm actually executes — JVM Clojure runtime (com.dylibso.chicory) + kgraph store\", :status :accepted, :date \"2026-07-02\", :topics #{:kgraph :clojure :host-import :chicory :capability :eavt :cli :datalog :wasm}, :note \"kotoba.runtime/wasm-binary は既に構造的に正しい WASM MVP バイナリを生成していたが、\\n   実際に実行するコードがどこにも無かった(テストはバイト形状のみ検証)。新設\\n   kotoba.wasm-exec(com.dylibso.chicory、純JVM、ネイティブツールチェイン不要)で\\n   compile→check→emit→実行の輪を閉じ、新規 CLI `kotoba wasm run` を追加。あわせて\\n   host-import 面 kqe(Kotoba Query Engine、書き込み op を含むのに read-only を思わせる\\n   誤解を招く名前)を kgraph(EAVT グラフストア、kotoba.kgraph)へ改称\\n   (kotoba-core-contracts #1 / kotoba-selfhost-contracts #1 / kotoba-lang #10 と対)。\"} {:id :adr-tensor-artifacts-ipld-raw-leaves, :file \"ADR-tensor-artifacts-ipld-raw-leaves.md\", :title \"Tensor artifacts as IPLD raw leaves — CID/IPLD を維持した CPU/LLM 分散推論のデータ面\", :status :proposed, :date \"2026-07-02\", :topics #{:gguf :arrow :bitswap :num-clj :cid :zstd :mmap :tensor :kv-cache :inference :llm :dedup :ipld :dag-cbor :tensor-parallel :raw-leaf}, :note \"Control plane は DAG-CBOR/CIDv1 を維持し、テンソル実体だけを quant-block 整列の IPLD raw leaf (0x55) + dag-cbor manifest に分解する。モデル同一性は :kotodama/digest (SHA-256 hex) から manifest CID へ。shard 配布は kotoba.net.bitswap の want-list に還元。KV-cache/activation などホットパスは content-address せず libp2p QUIC 上の raw frame。Arrow IPC は columnar バッチ I/O 限定で frame=raw leaf として IPLD と両立。圧縮はトランスポート層のみ・CID は非圧縮 byte に対して計算。\"} {:id :adr-kotoba-eda-web-semiconductor-app, :file \"ADR-kotoba-eda-web-semiconductor-app.md\", :title \"kotoba EDA — 半導体開発を web で完結する clj/kami/murakumo/LLM 統合アプリ\", :status :proposed, :date \"2026-06-29\", :topics #{:eda :signoff :datom :clojure :cid :webgpu :kami-engine :verification :murakumo :kotoba-clj :pdk :llm :cljc :datalog :semiconductor}, :artifacts [\"docs/eda/index.html\" \"docs/eda/kotoba_eda_core.cljc\" \"docs/eda/kotoba_eda_formats.cljc\" \"docs/eda/kotoba_eda_runner.cljc\" \"docs/eda/eda_file_formats.edn\" \"docs/eda/eda_coverage_schema.edn\" \"docs/eda/eda_runner_adapters.edn\" \"docs/eda/kotoba_eda_murakumo.cljc\" \"docs/eda/kotoba_eda_ui.cljc\" \"docs/eda/eda_murakumo_job.edn\" \"docs/eda/runner_host.clj\" \"docs/eda/kami_render_ir.edn\" \"docs/eda/source.html\" \"docs/ADR-kotoba-eda-web-semiconductor-app.edn\"], :note \"Defines kotoba EDA as a browser-first semiconductor development surface inside kotoba-lang: .kotoba/.cljc for EDA IR/generators/workflow, kami engine for schematic/layout/waveform visualization, murakumo for EDA jobs and inference, and LLMs as proposal-only reviewers behind policy/risk gates.\"} {:id :adr-kotoba-shell-aiueos-safety-clj, :file \"ADR-kotoba-shell-aiueos-safety-clj.md\", :title \"kotoba-shell: Tauri の kotoba/clj 版と aiueos / kototama の責務分離\", :status :accepted-in-progress, :date \"2026-06-28\", :topics #{:macos :clojurescript :windows :notarization :clojure :codesigning :tauri :kototama :release :capability :aiueos :kotoba-clj :safe-clj :smartscreen :desktop :mobile :shell :wasm}, :note \"Defines kotoba-shell as the app shell / WebView / native capability provider / packager layer. As of 2026-07-01, implementation authority is split to kotoba-lang/shell with EDN-first gates for native-host, app scaffold/build, release connect/verify/sign/submit, updater publish, store request/status with Java HTTP auth, distribution plan, API freeze/compat, Tauri-plugin compatibility, device-farm schedule/run-log, and shell shim removal from kotoba-lang/kotoba.\"} {:id :adr-june-stabilization-gate, :file \"ADR-june-stabilization-gate.md\", :title \"June stabilization gate before public launch (defer go-to-market to July)\", :status :accepted-in-progress, :date \"2026-06-23\", :topics #{:availability :stability :release :ops :go-to-market :deploy}, :note \"June = stabilize kotoba / kotobase.net / etzhayyim.com (uptime, health, restart, cold-tier). Public spread (Bluesky thread T + the rest of the GTM funnel) deferred to July, gated on the three surfaces being stably up. Records canonical repo = github.com/com-junkawasaki/kotoba (stale etzhayyim/… refs in README to reconcile). Launch trigger is operational, not calendar.\"} {:id :adr-research-paper-arxiv, :file \"ADR-research-paper-arxiv.md\", :title \"arXiv research paper — a grounded LaTeX system description under docs/paper\", :status :accepted-r0, :date \"2026-06-22\", :topics #{:latex :docs :paper :arxiv}, :artifacts [\"docs/paper/kotoba.tex\" \"docs/paper/references.bib\" \"docs/paper/arxiv.yaml\" \"docs/paper/README.md\"], :note \"Derived, grounded artifact (downstream of code + ADRs, like the README). LaTeX source is canonical; PDF is an out-of-band build, not checked in. Primary cs.DB, cross-list cs.DC + cs.CR.\"} {:id :adr-001-five-axis, :file \"ADR-001-five-axis-distributed-redesign.md\", :title \"Five-axis distributed redesign (authority / ordering / availability / conflict / transport)\", :status :accepted-phased, :date \"2026-06\", :topics #{:transport :availability :distributed :consensus}} {:date \"2026-06-17\", :realises \"GROWTH-DECENTRALIZATION.edn p6\", :extends :adr-001-five-axis, :file \"ADR-002-stake-to-replicate.md\", :crate \"crates/kotoba-dht\", :title \"Stake-to-replicate: a bonded, reputation-weighted replica membrane\", :note \"Wires existing primitives (NeighborhoodBlockStore / AvailabilityChallenge→verify_proof / SettlementBatch / Mishmar observation / witness quorum) into a replica membrane gated by an observed on-chain bond, with non-transferable reputation as preference only. Respects the Mishmar read+verify-only boundary (no on-chain signing/custody/settlement in kotoba). Separates collateral (slashable) from reputation (non-transferable, decaying).\", :topics #{:availability :distributed :sybil :economics :replication :mishmar}, :status :accepted-phased, :id :adr-002-stake-to-replicate} {:id :adr-clojure-wasm, :file \"ADR-clojure-wasm.md\", :title \"Clojure-on-WASM for kotoba (kotoba-clj)\", :status :accepted, :date \"2026-06-09\", :crate \"crates/kotoba-clj\", :topics #{:clojure :compiler :edn :wasm}, :note \"Clojure/EDN-subset → wasm-bytes compiler (guest programs). Browser JS packaging is now host-adapter owned after the Kotoba/CLJC migration.\"} {:id :adr-turn-relay, :file \"ADR-turn-relay.md\", :title \"Pure-Rust TURN relay for real-media calls (kotoba-turn)\", :status :accepted-core-done, :date \"2026-06-09\", :crate \"crates/kotoba-turn\", :topics #{:webrtc :realtime :turn :nat-traversal}, :note \"Socket-free RFC 8656 core done; UDP/TCP listener shell pending. Reusable rendezvous primitive for any future browser WebRTC plane (see :adr-browser-cid-query §2 持ち合い).\"} {:id :adr-sealed-cold-tier, :file \"ADR-sealed-cold-tier.md\", :title \"Sealed cold tier: AES-256-GCM block envelopes for everything that leaves the node\", :status :accepted-host-adapter-owned, :date \"2026-06-11\", :topics #{:cold-tier :privacy :crypto :storage}} {:id :adr-kotoba-word, :file \"ADR-kotoba-word.md\", :title \"kotoba-word — agent-callable words with a root registry\", :status :accepted, :date \"2026-06-10\", :topics #{:registry :agents}} {:id :adr-ci-coverage, :file \"ADR-ci-coverage.md\", :title \"CI + coverage measurement for the kotoba workspace\", :status :accepted-implemented, :date \"2026-06\", :topics #{:tooling :coverage :ci}} {:date \"2026-06-13\", :follow-ups [{:id :ipns-head-signed-endpoint, :what \"server XRPC returning the member-signed IpnsRecord for a graph so the head is gateway-untrusted end-to-end\", :status :done, :impl \"GET /xrpc/com.etzhayyim.apps.kotoba.ipns.head?graph=<cid> (xrpc::ipns_head); lexicon ipns/head.json; e2e ipns_head_resolves_signed_record_for_committed_graph\"} {:id :wasm-commit-index-roots, :what \"wasm accessor commit-CID → index_roots so the EAVT root is derived from the verified head, not server-asserted via datomic.sync\", :status :done, :impl \"KotobaNode.commitIndexRoots(commit_cid, bytes) (kotoba-wasm Node::commit_index_roots — CID-verified wasm-safe partial decode); kotoba.node/hydrate-and-query-verified! now derives EAVT root from the verified head, datomic.sync dropped from that path; native test commit_index_roots_extracts_roots_from_verified_block + wasm32 build green\"} {:id :cljs-port-lower-modules, :what \"port kotoba-blocks.js / kotoba-idb.js to ClojureScript (kotoba.blocks / kotoba.idb); cljs entry layer (kotoba.ipns / kotoba.node) lands first\", :status :done, :impl \"Historical kotoba.idb/kotoba.blocks/kotoba.node browser prototype retired from this repo; adapter repo must re-establish equivalent gates.\"} {:id :browser-write-path, :what \"trustless browser write: block.put push + ipns.publish (member-signed head advance); authority = signature over a key-derived name, CAS on sequence\", :status :done, :impl \"POST /xrpc/com.etzhayyim.apps.kotoba.ipns.publish (xrpc::ipns_publish — require_verified_signature + registry CAS; stale→409 unsigned→401); lexicon ipns/publish.json; cljs kotoba.write/publish! (block.put loop + ipns.publish); e2e ipns_publish_advances_head_and_round_trips_via_ipns_head\", :note \"takeover-proof only for sovereign/DID-scoped graphs (name binds to key); shared graph heads still go through CACAO-gated datomic.transact\"}], :file \"ADR-browser-cid-query-vs-p2p.md\", :title \"Browser query is CID-addressed: read needs reachability, not peers\", :supersedes-framing :browser-libp2p-mesh, :topics #{:host-adapter :browser :cid :ipns :p2p :query}, :status :accepted, :id :adr-browser-cid-query, :impl {:read-plane {:status :retired-from-this-repo, :note \"Former kotoba-wasm browser/shadow-cljs implementation removed; read-plane packaging is host-adapter owned.\"}, :p2p-plane {:status :deferred, :reason \"availability/liveness only — 持ち合い / live-push / provider-discovery; not a query-correctness requirement\"}}}]"}]