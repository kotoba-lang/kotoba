;; GROWTH-DECENTRALIZATION.edn
;; kotoba の分散型としての成長戦略 — Bitcoin / Ethereum / Holochain との対比
;; 2026-06-17 / 既存設計(ADR-001, SOCIAL-CAPITAL-LEDGER, SECURITY-ARCHITECTURE,
;; kotoba-evm, kotoba-dht, kotoba-custody)に接地して整理したもの。
;; 結論先出し: kotoba は「Bitcoin にする」べきではない。Holochain 型の土台を
;; 深め、Ethereum からは"アンカリングとプログラム可能な権限"だけを借り、
;; Bitcoin からは"信用中立性と偽造不能なコスト"の規律だけを借りる。

{:meta
 {:doc      "kotoba decentralization growth strategy"
  :date     "2026-06-17"
  :status   :draft-for-discussion
  :grounded-in [:ADR-001-five-axis
                :SOCIAL-CAPITAL-LEDGER
                :SECURITY-ARCHITECTURE
                :ADR-browser-cid-query-vs-p2p
                :crate/kotoba-evm :crate/kotoba-dht :crate/kotoba-custody
                :crate/kotoba-auth :crate/kotoba-net]}

 ;; ──────────────────────────────────────────────────────────────────────
 ;; 0. いま kotoba はどこに立っているか（3アーキタイプへの写像）
 ;; ──────────────────────────────────────────────────────────────────────
 :current-position
 {:one-liner
  "エージェント中心(source chain + DID/CACAO)の Merkle-CRDT 分散DB。
   合意は「全体一致」ではなく「共有された物理法則(validation hook)」で取る。"
  :closest-cousin :holochain
  :already-has
  [{:capability "agent-centric source chain + DID"      :crate :kotoba-dht  :ref :SourceChain/Warrant}
   {:capability "Merkle-CRDT 収束(順序非依存ProllyTree)" :crate :kotoba-graph :ref :ADR-001/merge}
   {:capability "因果順序(HLC) + 多親DAG"                :crate :kotoba-datomic :ref :ADR-001/phase-1-2}
   {:capability "権限委譲(CACAO capability chain depth-2)" :crate :kotoba-auth}
   {:capability "コンテンツ流通(IPFS cold + libp2p + DHT)" :crate [:kotoba-store :kotoba-net :kotoba-dht]}
   {:capability "外部チェーンへのアンカリング(Base)"      :crate :kotoba-evm :ref :SECURITY/R2a}
   {:capability "鍵の分散保管 t-of-N + slash 可能な責任"  :crate :kotoba-custody :ref :SECURITY/R3}
   {:capability "経済層: 非譲渡・減衰する社会資本"        :ref [:SOCIAL-CAPITAL-LEDGER :moyai :mishmar]}]
  :explicitly-not
  ["グローバルなPoW/全体合意の単一台帳(ADR-001 が明示的に非採用)"
   "投機可能なネイティブトークン(社会資本は非譲渡・無利回り・減衰)"]}

 ;; ──────────────────────────────────────────────────────────────────────
 ;; 1. 3システムは"何を共有するか"が根本的に違う — ここが設計の分かれ目
 ;; ──────────────────────────────────────────────────────────────────────
 :what-is-shared
 {:bitcoin   {:shared "単一グローバル台帳の全順序" :consensus :nakamoto-pow
              :cost "全ノードが全状態を複製・O(n)合意" :sybil :proof-of-work}
  :ethereum  {:shared "単一グローバル状態機械(world computer)" :consensus :pos
              :cost "L1合意ボトルネック→L2へ退避" :sybil :stake}
  :holochain {:shared "検証ルールのみ(DNA=共有された物理法則)" :consensus :none-agent-centric
              :cost "状態はエージェント+DHTにシャード化" :sybil :membrane+validation}
  :kotoba    {:shared "検証ルール(:db.validate/* + WASM validator)= shared physics"
              :consensus :none-merkle-crdt-convergence
              :cost "owner-rooted graph 単位でシャード化、必要時のみ外部アンカー"
              :sybil :moyai-poc+mishmar-bond}
  :takeaway
  "kotoba は既に Holochain 側(共有するのはルールだけ)を選択済み。
   よってグローバル合意層を後付けしてはいけない。成長 = この選択を深め、
   「全体一致が本当に要る一点(価値確定・反二重発行・slash)」だけ外部チェーンに委ねる。"}

 ;; ──────────────────────────────────────────────────────────────────────
 ;; 2. 各システムから"何を借り、何を借りないか"
 ;; ──────────────────────────────────────────────────────────────────────
 :selective-borrowing
 {:from-holochain   ;; ← 土台。最大限に深める
  {:borrow   ["agent-centric sovereignty(各DIDが自分のsource chainの主権者)"
              "validation-as-shared-physics(DNAパッケージ化)"
              "validating DHT authorities(近傍が検証義務を負う)"
              "グローバル合意なしの水平スケール"]
   :status   :core-identity
   :action   "validation rule を「DNA」として版管理・配布可能にし、第三者が
              app固有の shared physics を載せて kotoba ノードを立てられるように。"}

  :from-ethereum    ;; ← 道具として選択的に。基盤にはしない
  {:borrow   ["アンカリング/チェックポイント(価値を持つgraph headをBaseへ確定)"
              "プログラム可能な権限・経済(CACAO capability ≈ 制限付き権限)"
              "stake/slash の規律(Mishmar bond = skin in the game)"]
   :avoid    ["EVMをL0実行基盤にする(kotobaのWASM Component Modelが既に実行層)"
              "全状態をオンチェーン化する(コスト・主権を壊す)"]
   :status   :selective
   :action   "kotoba-evm AnchorBridge を「価値確定レイヤ」として明示。
              通常のクエリ/書き込みはオフチェーンのまま、確定だけ低頻度に錨を打つ。"}

  :from-bitcoin     ;; ← 哲学だけ。機構は借りない
  {:borrow   ["credible neutrality(運営者でも履歴を黙って書き換えられない: 既にR2)"
              "偽造不能なコスト(membershipにコストを持たせsybil耐性)"
              "scarcity/discipline(基盤層を増やしすぎない最小主義)"]
   :avoid    ["PoWマイニング" "全順序の単一台帳" "投機的ネイティブコイン"]
   :status   :philosophy-only
   :action   "「コストある参加」を Mishmar bond(stake-to-replicate)で表現。
              ただし評判(social capital)は非譲渡のまま — 金融化と分離する。"}}

 ;; ──────────────────────────────────────────────────────────────────────
 ;; 3. 軸ごとの現状→目標（ADR-001 の五軸を成長視点で拡張）
 ;; ──────────────────────────────────────────────────────────────────────
 :axes
 [{:axis :authority
   :now "owner DID per graph + CACAO委譲。多writerはADR-001で着手"
   :goal "多council/多writer。権限はcapabilityで最小化、検証で守る"
   :grow ["validation hook(phase3)を本線化" "council署名のparams版管理"]}
  {:axis :ordering
   :now "in-graph全順序 + HLC因果(phase1)"
   :goal "cross-graph因果firehose。価値確定のみ外部アンカーで全順序"
   :grow ["HLC firehoseを既定化" "確定対象graphだけBaseアンカー"]}
  {:axis :availability
   :now "single-holder既定(owner node + B2)"
   :goal "宣言的レプリケーション(min_replicas/pin_peers)をDHTが強制"
   :grow ["ADR-001 phase4(pin contract)を出荷" "pin報酬=Mishmar retainer"]
   :critical? true}
  {:axis :sybil-and-membership
   :now "moyai proof-of-contribution + 社会資本(非譲渡・減衰)"
   :goal "stake-to-replicate bond(slashで担保)。評判と担保を分離"
   :grow ["Mishmar bondでノード参加にコスト" "unreceipted release→slash(R3d)を実運用"]
   :critical? true}
  {:axis :finality
   :now "author-signed CommitDag + Baseへのaudit head anchor(R2a)"
   :goal "価値を持つgraph headの定期チェックポイント=客観的確定点"
   :grow ["AnchorBridge.commitRootを「finality」として公開API化"]}
  {:axis :economics
   :now "社会資本=非譲渡・無利回り・減衰(反金融化)。retainerはMishmar"
   :goal "現状維持が正解。外部資産は「担保/ストレージ対価」にのみ使う"
   :grow ["L0評判トークンは作らない(明示的non-goal)"
          "支払いが要る所(pin retainer/bond)だけ外部チェーン資産"]}
  {:axis :networking
   :now "libp2p QUIC/Noise/GossipSub + DHT(opt-in)"
   :goal "公開bootstrap/discovery網 + ワンコマンド参加"
   :grow ["bootstrapノード運用" "kotoba join 一発でレプリカ参加"]}
  {:axis :light-clients
   :now "browser IndexedDB store + CID-query(ADR-browser-cid-query)"
   :goal "フルノード不要でエンドユーザが検証できる軽量クライアント"
   :grow ["browser CID-queryをSDK化" "AT Protocol連携で既存clientから読む"]}
  {:axis :governance
   :now "Council attested params(social/capital/params/active)"
   :goal "単一owner→多writer→federated council→アンカーされたparams"
   :grow ["params変更をBaseに錨打ち" "早すぎるDAOトークン投票は避ける"]
   :anti-pattern "tokenholder投票によるガバナンス(評判と主権を金融化する)"}]

 ;; ──────────────────────────────────────────────────────────────────────
 ;; 4. 段階的ロードマップ（ADR-001 の phase1–5 を継承し phase6+ を追加）
 ;; ──────────────────────────────────────────────────────────────────────
 :roadmap
 {:inherited-from-ADR-001
  [[:p1 "HLC clock" :done?]
   [:p2 "多親DAG + Merkle-CRDT merge" :in-progress]
   [:p3 "validation hook(:db.validate/* + WASM)"]
   [:p4 "宣言的レプリケーション(DHT pin contract)" :critical
        :status :done   ;; kotoba-dht replication::{ReplicationPolicy, audit_replication,
                                   ;;   replication_plan(enforcement decision)} + NeighborhoodBlockStore::
                                   ;;   replication_status。ADR-002 min_bond_mkoto を ReplicationPolicy に統合。
                                   ;;   server: node.status に replication ブロック露出済。per-graph policy store
                                   ;;   (ReplicationPolicyStore)実装済。live audit runner(dht_audit::{audit_epoch,
                                   ;;   audit_epoch_dyn}: HttpProofFetcher 越しに実 HTTP 監査→SettlementIntentSink、
                                   ;;   実 TCP テスト緑)実装済。audit_epoch_dyn は KotobaState::block_store
                                   ;;   (Arc<dyn BlockStore+Send+Sync>)を直接受ける(coercion seam 無しを確認)。
                                   ;;   peer 発見: 公開 dht.info(node_id 広告)+ resolve_endpoints(URL→NodeId)。
                                   ;;   定期 spawn 配線済: build_router で AuditLoopConfig::from_env() opt-in
                                   ;;   (KOTOBA_DHT_AUDIT_INTERVAL_SECS + _PEERS、default off)→ spawn_audit_loop が
                                   ;;   毎tick 自ブロックを peers に challenge→tally ログ。owed retainer は
                                   ;;   KotobaState.dht_audit_sink 経由で node.status に露出。p4 end-to-end 完了。
        ]
   [:p5 "non-datomic pointer-chains(replayable streams)"]]
  :new
  [[:p6 "stake-to-replicate: Mishmar bondでノード参加にコスト、slash実運用"
        :unlocks "sybil耐性のある複数独立オペレータ"
        :adr :adr-002-stake-to-replicate]   ;; 設計ADR執筆済 (docs/ADR-002-stake-to-replicate.md, proposed)
   [:p7 "公開bootstrap/discovery網 + `kotoba join` ワンコマンド参加"
        :unlocks "他者graphを実際に複製する独立ノードの増加"
        :status :started   ;; discovery primitive: 公開 dht.info(node_id)+ resolve_endpoints(URL→NodeId)。
                           ;; bootstrap 中核: merge_bootstrap_peers(known, discovered)=正規化+dedup+sort+http絞り(pure)。
                           ;; 残: peer roster の保持/広告(トポロジ露出はrole-gated設計判断)+ kotoba join CLI 配線。
        ]
   [:p8 "finality anchoring: 価値を持つgraph headの定期チェックポイントをBaseへ"
        :unlocks "客観的確定点・反二重発行(必要な一点だけ全体合意)"
        :status :done   ;; kotoba-evm anchor: 書き込み側(commit_root_calldata)+ 読み取り側
                                    ;; verify_finality/root_hash_of + committer_of_calldata/decode_address_result/
                                    ;; finality_from_call_result + finality_summary。server mishmar_observe::
                                    ;; {observe_finality, observe_finalities} が JsonRpcTransport 越し eth_call
                                    ;; (committerOf)→FinalityStatus(ReqwestRpc で実 Base、fake テスト緑)。
                                    ;; 定期 spawn 配線済: FinalityLoopConfig::from_env() opt-in + spawn_finality_loop が
                                    ;; 毎tick graph heads を観測→KotobaState.finality_summary→node.status finality ブロック。
                                    ;; read+verify 境界遵守(tx 提出は relayer)。p8 end-to-end 完了。
        ]
   [:p9 "DNAパッケージング: validation ruleを版管理・配布。第三者がapp固有
         shared physicsで自ノードを立てられる(Holochain hApp相当)"
        :unlocks "エコシステム/サードパーティ参入"
        :status :loadable-done   ;; kotoba-dht dna::DnaManifest → dna_id()=content-address。enforcement:
                                 ;; validation::{PhysicsRule, validate_tx, 組込 AllowedAttributes/ForbiddenAttribute/
                                 ;; MaxTxSize}。bridge: RuleSpec(直列化形, content_cid/into_rule)+ load_rules(dna, fetch)
                                 ;; が CID から RuleSpec を解決→PhysicsRule(integrity 検査: 改竄 blob は CID 不一致で拒否)。
                                 ;; manifest→fetch→RuleSpec→PhysicsRule→validate_tx が e2e でテスト緑。
                                 ;; 単一エントリ enforce(dna, fetch, tx)=load_rules+validate_tx(load 失敗自体が拒否)。
                                 ;; pure・決定的。enforcement は既に transact 配線済(server dna_integrity:
                                 ;; IntegrityRuleset を EDN tx に検証、ADR-2606112000)。dna_integrity::dna_id() 追加で
                                 ;; 既存 ruleset も content-address 化(graph非依存・順序非依存=「同DNA id=同physics=同network」)。
                                 ;; 2層: dna_integrity=配線済enforcement / kotoba_dht DnaManifest=content-addressed配布。
                                 ;; 残: EDN datalog/WASM RuleSpec variant + 2層の統合(任意)。
        ]
   [:p10 "light client SDK: browser CID-query + AT Proto連携で非フルノード検証"
        :unlocks "エンドユーザ採用"
        :status :trust-core   ;; 信頼の核を canonical 化: kotoba-core KotobaCid::verifies(bytes)=content-address
                              ;; 再検証 + unverified_blocks(responses)= 信頼できない gateway 応答のうち改竄分を列挙
                              ;; (空=fetch 全体を信頼可)。kotoba-wasm BlockCache::insert_verified を verifies に寄せDRY。
                              ;; 既存: browser CID-query/IPNS署名head(ADR-browser-cid-query)。残: SDK 化 + AT Proto 連携。
        ]
   [:p11 "cross-graph causal firehose + 相互運用ブリッジ"
        :unlocks "アプリ間のデータ流通"
        :status :hlc-canonical   ;; ADR-001 phase1 基盤: kotoba-core hlc::Hlc(phys_ms<<16|counter)を pure 化
                                 ;; send(local stamp)+ recv(peer merge, 古典 HLC 受信規則=ADR-001 が deferred した
                                 ;; "observed peer HLC merge")+ 比較(=因果順序)+ 分解。datomic の inline next_hlc と
                                 ;; 同パッキング。datomic next_hlc は Hlc::send に委譲(単一の真実)。firehose 順序:
                                 ;; causal_sort_by(hlc昇順+tiebreak)+ causal_merge_dedup(多graph stream を interleave+
                                 ;; 重複排除)= 全replica 同一の決定的 cross-graph 順序。残: server firehose を本順序へ寄せる。
        ]
   [:p12 "ガバナンス分散: 多council + アンカーされたparams変更"
        :unlocks "運営者非依存の持続"
        :status :pointer-done   ;; kotoba-dht governance::{ParamVersion(content-addressed id), ratify(counting),
                               ;; Attestation+verify_and_ratify(実 ed25519: 偽造/別msg/非member/重複を排除),
                               ;; ActiveParams(params/active ポインタ: 署名検証済 quorum で ratify 時のみ前進、
                               ;; history 記録、未 ratify は不変、current 再活性は no-op)}。実鍵テスト緑。
                               ;; 残: Base アンカー観測(p8 verify_finality を ParamVersion.id に適用)で客観的確定。
        ]]
  :sequencing-rationale
  "可用性(p4)→コストある参加(p6)→参加容易化(p7)の順が要。p4なしのp6/p7は
   「複製責任のないノード」を増やすだけ。finality(p8)はp4/p6が揃ってから。"}

