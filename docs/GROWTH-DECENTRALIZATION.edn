 :next-actions
 [{:do "ADR-001 phase4(pin contract)を最優先で出荷" :owner :core :horizon :now}
  {:do "Mishmar bond=stake-to-replicateの設計ADRを書く(評判と担保の分離を明記)" :horizon :now}
