  {:metric "cross-agentで検証通過したtransaction数"             :why "shared physicsの実効性"}
  {:metric "slashが機能した(または抑止した)不正release件数"       :why "アカウンタビリティの実証"}
  {:metric "サードパーティDNA/アプリ数"                          :why "エコシステム成長"}]

