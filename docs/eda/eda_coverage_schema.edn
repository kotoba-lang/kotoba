{:schema 1
 :id :kotoba.eda/coverage-schema
 :updated "2026-06-29"
 :datoms
 [{:db/ident :eda.coverage/id
   :db/valueType :db.type/keyword
   :db/cardinality :db.cardinality/one
   :doc "Coverage metric id, e.g. :coverage/rtl-unit or :coverage/timing-corners."}
  {:db/ident :eda.coverage/source
   :db/valueType :db.type/keyword
   :db/cardinality :db.cardinality/one
   :doc "Coverage source: :source/stage-model, :source/artifact-summary, :source/runner-result."}
  {:db/ident :eda.coverage/tool
   :db/valueType :db.type/keyword
   :db/cardinality :db.cardinality/one
   :doc "Tool or runner that produced the evidence."}
  {:db/ident :eda.coverage/status
   :db/valueType :db.type/keyword
   :db/cardinality :db.cardinality/one
   :doc "Coverage status: :pass, :pending, :failed, :blocked, :not-applicable."}
  {:db/ident :eda.coverage/score
   :db/valueType :db.type/long
   :db/cardinality :db.cardinality/one
   :doc "0-100 coverage score."}
  {:db/ident :eda.coverage/evidence-cid
   :db/valueType :db.type/string
   :db/cardinality :db.cardinality/one
   :doc "CID of runner output, artifact summary, waveform, or report that supports the score."}
  {:db/ident :eda.coverage/findings
   :db/valueType :db.type/ref
   :db/cardinality :db.cardinality/many
   :doc "Linked report finding datoms."}]
 :metrics
 [{:eda.coverage/id :coverage/rtl-unit
   :eda.coverage/category :simulation
   :eda.coverage/required-for [:mrl/engineering-ready :mrl/pilot-ready :mrl/release-ready]}
  {:eda.coverage/id :coverage/formal-smoke
   :eda.coverage/category :verification
   :eda.coverage/required-for [:mrl/pilot-ready :mrl/release-ready]}
  {:eda.coverage/id :coverage/mixed-signal
   :eda.coverage/category :simulation
   :eda.coverage/required-for [:mrl/pilot-ready :mrl/release-ready]}
  {:eda.coverage/id :coverage/timing-corners
   :eda.coverage/category :signoff
   :eda.coverage/required-for [:mrl/pilot-ready :mrl/release-ready]}
  {:eda.coverage/id :coverage/power-activity
   :eda.coverage/category :signoff
   :eda.coverage/required-for [:mrl/pilot-ready :mrl/release-ready]}
  {:eda.coverage/id :coverage/drc-lvs
   :eda.coverage/category :signoff
   :eda.coverage/required-for [:mrl/release-ready]}
  {:eda.coverage/id :coverage/ate-pattern
   :eda.coverage/category :manufacturing-test
   :eda.coverage/required-for [:mrl/release-ready]}]}
