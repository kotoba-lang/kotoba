{:source-paths ["."]
 ;; kotoba_eda_app.cljs is a flat, single-segment namespace (kotoba-eda-app)
 ;; in this directory — see kotoba_eda_build.clj's docstring for why (the
 ;; page's source.html viewer fetches files by flat name relative to this
 ;; dir, so nothing here lives under a namespace-matching src/ tree).
 :dependencies [[reagent "1.2.0"]]
 :builds
 {:app {:target :browser
        :output-dir "resources"
        :modules {:main {:init-fn kotoba-eda-app/init!}}}}}
