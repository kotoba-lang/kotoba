{:paths ["."]
 ;; Local build tooling for regenerating docs/eda/index.html from CLJC
 ;; (kotoba_eda_ui.cljc + kotoba_eda_style.cljc) via kotoba-lang/html +
 ;; kotoba-lang/css. Not part of the parent repo's main deps.edn — this is a
 ;; standalone build classpath scoped to this directory.
 :deps {io.github.kotoba-lang/html {:local/root "../../../html"}
        io.github.kotoba-lang/css {:local/root "../../../css"}}
 :aliases
 {:build {:main-opts ["-e" "(load-file \"kotoba_eda_build.clj\") (kotoba.eda.build/-main)"]}
  :test {:main-opts ["-e" "(load-file \"kotoba_eda_selftest.clj\")"]}}}
