{:paths ["."]
 ;; Local build tooling for regenerating docs/eda/index.html from CLJC
 ;; (kotoba_eda_ui.cljc + kotoba_eda_style.cljc) via the kotoba-lang design
 ;; system (kotoba-ui + appkit — see kotoba-ui/docs/agent-guide.md) +
 ;; kotoba-lang/css. `:paths ["."]` + single-segment namespaces
 ;; (`kotoba-eda-ui`, not `kotoba.eda.ui`) make every local file here
 ;; `require`-able without moving them out of this flat directory, which
 ;; source.html's source viewer depends on.
 ;;
 ;; kotoba-ui / appkit / css / html are :local/root siblings of this repo's
 ;; checkout (orgs/kotoba-lang/*); kotoba-ui itself pins shitsuke /
 ;; liquid-glass-ui as its own :local/root siblings.
 ;;
 ;; The interactive app (kotoba_eda_app.cljs, reagent) is compiled via
 ;; shadow-cljs, which now reads THIS deps.edn for its classpath
 ;; (shadow-cljs.edn `:deps {:aliases [:cljs]}`) so the cljs build sees the
 ;; same kotoba-ui/appkit hiccup components as the JVM page build:
 ;;   npm install && npx shadow-cljs release app   (see shadow-cljs.edn,
 ;;   package.json — outputs resources/main.js)
 ;;   clojure -M:build                             (embeds resources/main.js
 ;;   into index.html)
 ;; This is the one exception to kotoba-lang's usual zero-npm convention in
 ;; this repo, scoped to this directory only.
 ;;
 ;; Not part of the parent repo's main deps.edn — this is a standalone build
 ;; classpath scoped to this directory.
 :deps {io.github.kotoba-lang/html {:local/root "../../../html"}
        io.github.kotoba-lang/css {:local/root "../../../css"}
        io.github.kotoba-lang/kotoba-ui {:local/root "../../../kotoba-ui"}
        io.github.kotoba-lang/appkit {:local/root "../../../appkit"}}
 :aliases
 {:build {:main-opts ["-m" "kotoba-eda-build"]}
  :test {:main-opts ["-m" "kotoba-eda-selftest"]}
  ;; shadow-cljs classpath extras (the JVM aliases never need these).
  :cljs {:extra-deps {thheller/shadow-cljs {:mvn/version "3.4.11"}
                      reagent/reagent {:mvn/version "1.2.0"}}}}}
