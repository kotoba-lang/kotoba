{:schema 1
 :id :kotoba.eda/runner-adapters
 :updated "2026-06-29"
 :contract
 {:mode :host-or-murakumo
  :browser "Browser creates EDN job plans only; it never executes local EDA tools."
  :host "Host runner receives EDN, checks policy, materializes CID artifacts, executes whitelisted commands, then emits report datoms."
  :outputs [:eda.run/complete :eda.parser/summary :eda.report/finding :eda.artifact/ingest]}
 :adapters
 [{:eda.runner/id :runner/verilator-lint
   :eda.runner/name "Verilator lint"
   :eda.runner/software :sw/verilator
   :eda.runner/formats [:rtl/verilog :rtl/systemverilog]
   :eda.runner/operation :op/lint
   :eda.runner/command ["verilator" "--lint-only" "--Wall" "$inputs"]
   :eda.runner/outputs [:report/generic]
   :eda.runner/policy {:network :deny :filesystem :workspace-only :writes false :license :open-source}}
  {:eda.runner/id :runner/verilator-vcd
   :eda.runner/name "Verilator simulation scaffold"
   :eda.runner/software :sw/verilator
   :eda.runner/formats [:rtl/verilog :rtl/systemverilog]
   :eda.runner/operation :op/simulate
   :eda.runner/command ["verilator" "--cc" "--trace" "$inputs"]
   :eda.runner/outputs [:wave/vcd :report/generic]
   :eda.runner/policy {:network :deny :filesystem :workspace-only :writes true :license :open-source}}
  {:eda.runner/id :runner/yosys-synth
   :eda.runner/name "Yosys synthesis"
   :eda.runner/software :sw/yosys
   :eda.runner/formats [:rtl/verilog :rtl/systemverilog]
   :eda.runner/operation :op/synthesize
   :eda.runner/command ["yosys" "-p" "read_verilog -sv $inputs; synth; stat; write_json out/netlist.json"]
   :eda.runner/outputs [:report/generic :eda.netlist/gate]
   :eda.runner/policy {:network :deny :filesystem :workspace-only :writes true :license :open-source}}
  {:eda.runner/id :runner/opensta-timing
   :eda.runner/name "OpenSTA timing"
   :eda.runner/software :sw/opensta
   :eda.runner/formats [:constraint/sdc :library/liberty :timing/sdf]
   :eda.runner/operation :op/analyze-timing
   :eda.runner/command ["sta" "-exit" "flow.tcl"]
   :eda.runner/outputs [:report/generic]
   :eda.runner/policy {:network :deny :filesystem :workspace-only :writes true :license :open-source}}
  {:eda.runner/id :runner/openroad-pnr
   :eda.runner/name "OpenROAD place and route"
   :eda.runner/software :sw/openroad
   :eda.runner/formats [:physical/lef :physical/def :constraint/sdc :library/liberty]
   :eda.runner/operation :op/route
   :eda.runner/command ["openroad" "flow.tcl"]
   :eda.runner/outputs [:physical/def :layout/gdsii :report/generic]
   :eda.runner/policy {:network :deny :filesystem :workspace-only :writes true :license :open-source}}
  {:eda.runner/id :runner/klayout-drc
   :eda.runner/name "KLayout DRC/layout summary"
   :eda.runner/software :sw/klayout
   :eda.runner/formats [:layout/gdsii :layout/oasis :pdk/rule-deck]
   :eda.runner/operation :op/drc
   :eda.runner/command ["klayout" "-b" "-r" "$rule_deck" "$layout"]
   :eda.runner/outputs [:report/generic]
   :eda.runner/policy {:network :deny :filesystem :workspace-only :writes true :license :open-source}}
  {:eda.runner/id :runner/netgen-lvs
   :eda.runner/name "Netgen LVS"
   :eda.runner/software :sw/netgen
   :eda.runner/formats [:analog/spice :analog/cdl :layout/gdsii]
   :eda.runner/operation :op/lvs
   :eda.runner/command ["netgen" "-batch" "lvs" "$layout_netlist" "$source_netlist" "setup.tcl"]
   :eda.runner/outputs [:report/generic]
   :eda.runner/policy {:network :deny :filesystem :workspace-only :writes true :license :open-source}}
  {:eda.runner/id :runner/ngspice
   :eda.runner/name "ngspice simulation"
   :eda.runner/software :sw/ngspice
   :eda.runner/formats [:analog/spice]
   :eda.runner/operation :op/simulate
   :eda.runner/command ["ngspice" "-b" "$inputs" "-o" "out/ngspice.log"]
   :eda.runner/outputs [:report/generic]
   :eda.runner/policy {:network :deny :filesystem :workspace-only :writes true :license :open-source}}]}
