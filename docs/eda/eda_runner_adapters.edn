[{:db/id -1, :eda.runner-adapters/schema 1, :eda.runner-adapters/id :kotoba.eda/runner-adapters, :eda.runner-adapters/updated "2026-06-29", :eda.runner-adapters/contract "{:mode :host-or-murakumo, :browser \"Browser creates EDN job plans only; it never executes local EDA tools.\", :host \"Host runner receives EDN, checks policy, materializes CID artifacts, executes whitelisted commands, then emits report datoms.\", :outputs [:eda.run/complete :eda.parser/summary :eda.report/finding :eda.artifact/ingest]}", :eda.runner-adapters/adapters "[#:eda.runner{:id :runner/verilator-lint, :name \"Verilator lint\", :software :sw/verilator, :formats [:rtl/verilog :rtl/systemverilog], :operation :op/lint, :command [\"verilator\" \"--lint-only\" \"--Wall\" \"$inputs\"], :outputs [:report/generic], :policy {:network :deny, :filesystem :workspace-only, :writes false, :license :open-source}} #:eda.runner{:id :runner/verilator-vcd, :name \"Verilator simulation scaffold\", :software :sw/verilator, :formats [:rtl/verilog :rtl/systemverilog], :operation :op/simulate, :command [\"verilator\" \"--cc\" \"--trace\" \"$inputs\"], :outputs [:wave/vcd :report/generic], :policy {:network :deny, :filesystem :workspace-only, :writes true, :license :open-source}} #:eda.runner{:id :runner/yosys-synth, :name \"Yosys synthesis\", :software :sw/yosys, :formats [:rtl/verilog :rtl/systemverilog], :operation :op/synthesize, :command [\"yosys\" \"-p\" \"read_verilog -sv $inputs; synth; stat; write_json out/netlist.json\"], :outputs [:report/generic :eda.netlist/gate], :policy {:network :deny, :filesystem :workspace-only, :writes true, :license :open-source}} #:eda.runner{:id :runner/opensta-timing, :name \"OpenSTA timing\", :software :sw/opensta, :formats [:constraint/sdc :library/liberty :timing/sdf], :operation :op/analyze-timing, :command [\"sta\" \"-exit\" \"flow.tcl\"], :outputs [:report/generic], :policy {:network :deny, :filesystem :workspace-only, :writes true, :license :open-source}} #:eda.runner{:id :runner/openroad-pnr, :name \"OpenROAD place and route\", :software :sw/openroad, :formats [:physical/lef :physical/def :constraint/sdc :library/liberty], :operation :op/route, :command [\"openroad\" \"flow.tcl\"], :outputs [:physical/def :layout/gdsii :report/generic], :policy {:network :deny, :filesystem :workspace-only, :writes true, :license :open-source}} #:eda.runner{:id :runner/klayout-drc, :name \"KLayout DRC/layout summary\", :software :sw/klayout, :formats [:layout/gdsii :layout/oasis :pdk/rule-deck], :operation :op/drc, :command [\"klayout\" \"-b\" \"-r\" \"$rule_deck\" \"$layout\"], :outputs [:report/generic], :policy {:network :deny, :filesystem :workspace-only, :writes true, :license :open-source}} #:eda.runner{:id :runner/netgen-lvs, :name \"Netgen LVS\", :software :sw/netgen, :formats [:analog/spice :analog/cdl :layout/gdsii], :operation :op/lvs, :command [\"netgen\" \"-batch\" \"lvs\" \"$layout_netlist\" \"$source_netlist\" \"setup.tcl\"], :outputs [:report/generic], :policy {:network :deny, :filesystem :workspace-only, :writes true, :license :open-source}} #:eda.runner{:id :runner/ngspice, :name \"ngspice simulation\", :software :sw/ngspice, :formats [:analog/spice], :operation :op/simulate, :command [\"ngspice\" \"-b\" \"$inputs\" \"-o\" \"out/ngspice.log\"], :outputs [:report/generic], :policy {:network :deny, :filesystem :workspace-only, :writes true, :license :open-source}}]"}]