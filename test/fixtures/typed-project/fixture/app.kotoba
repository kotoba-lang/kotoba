(ns fixture.app
  (:require [fixture.coverage :as coverage])
  (:export [main]))

(defn main
  []
  :i64
  (let [covered (typed-set [:set :keyword] :ready :reviewed)]
    (if (coverage/ready? covered)
      (if (string=? "Kotoba" "Kotoba")
        (+ 40 (coverage/covered-count (coverage/make-report)))
        1)
      0)))
