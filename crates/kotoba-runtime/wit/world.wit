/// kotoba:kais — Kotoba Instruction Set Architecture WIT package
///
/// WASM guest components import these interfaces to interact with the Kotoba host.
/// Any language compiling to WASM Component Model (Rust/Python/JS/Go/C) can use these.
///
/// Host function mapping:
///   kqe.*  → ASSERT(0x1) / RETRACT(0xD) / QUERY(0x2) frames
///   kse.*  → SEND(0x3) / RECV(0x4) frames
///   auth.* → CACAO delegation chain verification
///   llm.*  → CALL_FOREIGN(0xF) bridge to AgentGateway MCP
package kotoba:kais@0.1.0;

/// KQE (Kotoba Query Engine) — Datalog/legacy-quad read-write interface
interface kqe {
    /// Legacy graph projection of a Datom: graph + (entity, attribute, value).
    /// The host assigns transaction CID and Added when this is committed.
    record quad {
        graph:     string,
        subject:   string,
        predicate: string,
        /// CBOR-encoded QuadObject (Cid/Integer/Float/Text/Bytes/VectorF32/TensorCid)
        object-cbor: list<u8>,
    }

    /// ASSERT frame (0x1): append a Datom assertion through the legacy graph projection
    assert-quad: func(q: quad) -> result<_, string>;

    /// RETRACT frame (0xD): append a Datom retract tombstone through the legacy graph projection
    retract-quad: func(q: quad) -> result<_, string>;

    /// QUERY frame (0x2): evaluate Datalog program, return matching quads
    query: func(datalog-src: string) -> result<list<quad>, string>;

    /// SPO lookup: all Objects for (graph, subject, predicate)
    get-objects: func(graph: string, subject: string, predicate: string) -> list<list<u8>>;

    /// Read Commit CID for a named graph head
    get-head: func(graph-name: string) -> option<string>;

    /// Evaluate a set of Datalog rules against the current Datom projection snapshot.
    /// rules-cbor: CBOR-encoded list<DatalogRule> (ciborium serialised).
    /// Returns newly derived quads (subject/predicate from head relation).
    evaluate-rules: func(rules-cbor: list<u8>) -> result<list<quad>, string>;
}

/// KSE (Kotoba Stream Engine) — Journal topic publish/subscribe interface
interface kse {
    /// SEND frame (0x3): publish bytes to a KOTOBA topic
    /// Returns CID of the JournalEntry
    publish: func(topic: string, payload: list<u8>) -> result<string, string>;

    /// RECV frame (0x4): drain pending messages from a topic cursor
    /// Returns list of (topic, payload) pairs
    drain: func(topic-pattern: string, max-items: u32) -> result<list<tuple<string, list<u8>>>, string>;
}

/// Auth — DID/CACAO identity interface
interface auth {
    /// DID of the agent executing this WASM invocation
    current-did: func() -> string;

    /// Verify a CACAO delegation chain; returns delegator DID on success
    verify-cacao: func(cacao-cbor: list<u8>) -> result<string, string>;

    /// Check if current DID holds a capability resource URI
    has-capability: func(resource-uri: string, ability: string) -> bool;
}

/// LLM — CALL_FOREIGN(0xF) bridge to AgentGateway MCP / Vultr A16
interface llm {
    /// Text inference: model-cid is a Kotoba Vault blob CID for the GGUF/GGML
    infer: func(model-cid: string, prompt-bytes: list<u8>) -> result<list<u8>, string>;

    /// Dense embedding: returns VectorF32 as raw float bytes (little-endian IEEE 754)
    embed: func(model-cid: string, text: string) -> result<list<u8>, string>;

    /// Load a LoRA adapter CID and apply to current inference context
    load-lora: func(base-model-cid: string, lora-cid: string) -> result<_, string>;
}

/// EVM — CALL_FOREIGN(0xF) bridge to Ethereum JSON-RPC endpoints
/// Gas: all calls are CALL_FOREIGN class = 1000 gas each
interface evm {
    /// ABI-encoded view call (eth_call).
    /// calldata: ABI-encoded function selector + args.
    /// block-tag: "latest" | "finalized" | hex block number. None = "latest".
    eth-call: func(
        rpc-url:   string,
        to:        string,
        calldata:  list<u8>,
        block-tag: option<string>,
    ) -> result<list<u8>, string>;

    /// Read raw storage slot (eth_getStorageAt).
    /// slot: 32-byte hex string (0x-prefixed).
    eth-get-storage-at: func(
        rpc-url: string,
        address: string,
        slot:    string,
    ) -> result<list<u8>, string>;

    /// eth_getBalance → returns hex wei string (e.g. "0x1a8f...").
    eth-get-balance: func(
        rpc-url: string,
        address: string,
    ) -> result<string, string>;

    /// eth_chainId → hex chain id string (e.g. "0x1" mainnet, "0x2105" Base).
    eth-chain-id: func(
        rpc-url: string,
    ) -> result<string, string>;

    /// eth_blockNumber → hex latest block number string.
    eth-block-number: func(
        rpc-url: string,
    ) -> result<string, string>;

    /// eth_getCode → deployed bytecode at an address.
    /// Empty result means the address is an EOA (not a contract).
    /// block-tag: "latest" | "finalized" | hex block number. None = "latest".
    eth-get-code: func(
        rpc-url:   string,
        address:   string,
        block-tag: option<string>,
    ) -> result<list<u8>, string>;

    /// eth_getTransactionCount → account nonce as a hex string.
    eth-get-transaction-count: func(
        rpc-url:   string,
        address:   string,
        block-tag: option<string>,
    ) -> result<string, string>;

    /// eth_getTransactionReceipt → raw JSON receipt string (decode caller-side).
    /// Returns the JSON literal "null" when the tx is unknown / not yet mined.
    eth-get-transaction-receipt: func(
        rpc-url: string,
        tx-hash: string,
    ) -> result<string, string>;

    /// eth_getLogs → raw JSON array string of matching logs (decode caller-side).
    /// `filter-json` is a JSON object per the eth_getLogs filter spec, e.g.
    /// {"address":"0x..","topics":["0x.."],"fromBlock":"0x..","toBlock":"latest"}.
    eth-get-logs: func(
        rpc-url:     string,
        filter-json: string,
    ) -> result<string, string>;

    // ── ERC-20 read helpers (eth_call + ABI decode composed host-side) ────────
    // `token` / `holder` are 0x-prefixed hex addresses. These let WASM guests
    // read fungible-token state without re-implementing ABI codec on the guest.

    /// ERC-20 balanceOf → raw balance as a base-10 decimal string (no decimals
    /// applied; combine with erc20-decimals for human units).
    erc20-balance-of: func(
        rpc-url: string,
        token:   string,
        holder:  string,
    ) -> result<string, string>;

    /// ERC-20 totalSupply → base-10 decimal string.
    erc20-total-supply: func(
        rpc-url: string,
        token:   string,
    ) -> result<string, string>;

    /// ERC-20 decimals → token decimal precision.
    erc20-decimals: func(
        rpc-url: string,
        token:   string,
    ) -> result<u8, string>;

    /// ERC-20 symbol → ticker (handles dynamic-string and legacy bytes32 tokens).
    erc20-symbol: func(
        rpc-url: string,
        token:   string,
    ) -> result<string, string>;

    /// ERC-20 name → token name (handles dynamic-string and legacy bytes32).
    erc20-name: func(
        rpc-url: string,
        token:   string,
    ) -> result<string, string>;
}

/// Source chain append — write Invoke/Result/Infer entries to the agent's chain
interface chain {
    /// Append an Infer ChainEntry (LLM inference record)
    append-infer: func(
        model-cid:  string,
        prompt-cid: string,
        output-cid: string,
    ) -> result<string, string>;

    /// Read the latest chain head CID for current agent DID
    head-cid: func() -> option<string>;
}

/// KOTOBA world — imported by every WASM guest node program
///
/// Guest exports `run` to be called by the KotobaRuntime executor.
/// Context bytes (CBOR) carry the Invoke ChainEntry fields.
world kotoba-node {
    import kqe;
    import kse;
    import auth;
    import llm;
    import chain;
    import evm;
    import wasi:http/outgoing-handler@0.2.0;

    /// Entry point called by KotobaRuntime for each Invoke ChainEntry.
    /// ctx-cbor: CBOR-encoded InvokeContext { graph, session_cid, args }
    /// Returns: CBOR-encoded output or error string
    export run: func(ctx-cbor: list<u8>) -> result<list<u8>, string>;
}

/// KOTOBA UDF world — subset for RisingWave-style UDF programs
/// (stateless, no chain write, mirrors RisingWave Python UDF contract)
world kotoba-udf {
    import kqe;

    /// UDF entry: input rows as CBOR list<quad>, returns output rows
    export eval: func(rows: list<list<u8>>) -> result<list<list<u8>>, string>;
}

