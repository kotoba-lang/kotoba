;; Seed of a self-hosted safe Kotoba analyzer.
;;
;; Input CBOR shape:
;;   All top-level input maps carry {"abi": "kotoba.selfhost.safe-analyzer.v1"}.
;;   {"abi": "kotoba.selfhost.safe-analyzer.v1", "op": "kqe-assert!", "target": "graphA"}
;;   {"calls": [["kqe-assert!", "graphA"], ["llm-infer", "modelA"]]}
;;   {"forms": [["do", ["kqe-assert!", "graphA", "s", "p", "v"],
;;                     ["llm-infer", "modelA", "prompt"]]]}
;;   {"program": [{"name": "helper", "forms": [...]},
;;                {"name": "run", "forms": [["helper"]]}],
;;    "entry": "run"}
;;   {"program": [{"name": "helper", "forms": [...]},
;;                {"name": "run", "forms": [["helper"]]}]}
;;   {"program": [{"name": "run",
;;                 "body": [{"tag": "builtin", "op": "kqe-assert!",
;;                           "args": [{"tag": "str", "value": "graphA"}]}]}]}
;;   {"program": [{"name": "helper", "forms": [...], "declared": ["graph-write"]},
;;                {"name": "run", "forms": [["helper"]], "declared": []}],
;;    "check": "effects"}
;;   {"program": [{"name": "run", "forms": [["kqe-assert!", "graphA", "s", "p", "v"]]}],
;;    "check": "policy",
;;    "policy": {"graph-write": ["graphA"], "graph-read": [], "infer": [], "auth": "false"}}
;;   {"program": [{"name": "run", "forms": [...], "declared": ["graph-write"]}],
;;    "check": "admission",
;;    "policy": {"graph-write": ["graphA"], "graph-read": [], "infer": [], "auth": "false"}}
;;   {"program": [{"name": "run", "forms": [...]}],
;;    "check": "minimal-policy"}
;;   {"abi": "kotoba.selfhost.safe-analyzer.v1",
;;    "program": [{"name": "run", "forms": [...]}],
;;    "check": "unused-grants",
;;    "policy": {"graph-write": ["graphA", "graphB"], "graph-read": [], "infer": [], "auth": "false"}}
;;
;; Output CBOR shape:
;;   {"abi": "kotoba.selfhost.safe-analyzer.v1",
;;    "effect": "graph-write", "cap": "graph-write", "target": "graphA", "known": "true"}
;;   {"abi": "kotoba.selfhost.safe-analyzer.v1",
;;    "effects": ["graph-write", "infer"], "caps": ["graph-write", "infer"],
;;    "targets": ["graphA", "modelA"], "known": "true"}
;;
;; The Rust compiler prepends PRELUDE + CBOR_PRELUDE + CBOR_ENC_PRELUDE for tests.

(defn map-seek-reader [ctx key]
  (let [r (cbor-reader ctx)]
    (if (= (cbor-map-seek r key) 1) r 0)))

(defn map-text [ctx key]
  (let [r (cbor-reader ctx)]
    (if (= (cbor-map-seek r key) 1)
      (cbor-text r)
      "")))

(defn classify-effect [op]
  (cond
    (str-eq? op "kqe-assert!") "graph-write"
    (str-eq? op "kqe-retract!") "graph-write"
    (str-eq? op "kqe-get-objects") "graph-read"
    (str-eq? op "kqe-query") "graph-read"
    (str-eq? op "llm-infer") "infer"
    (str-eq? op "has-capability?") "auth"
    :else "pure"))

(defn classify-cap [op]
  (cond
    (str-eq? op "kqe-assert!") "graph-write"
    (str-eq? op "kqe-retract!") "graph-write"
    (str-eq? op "kqe-get-objects") "graph-read"
    (str-eq? op "kqe-query") "graph-read"
    (str-eq? op "llm-infer") "infer"
    (str-eq? op "has-capability?") "auth"
    :else "none"))

(defn known-op? [op]
  (if (str-eq? (classify-cap op) "none") "false" "true"))

(defn known-effect? [effect]
  (cond
    (str-eq? effect "graph-read") 1
    (str-eq? effect "graph-write") 1
    (str-eq? effect "infer") 1
    (str-eq? effect "auth") 1
    :else 0))

(defn vec-has-str? [v s]
  (loop [i 0]
    (if (>= i (vec-count v))
      0
      (if (str-eq? (vec-nth v i) s)
        1
        (recur (+ i 1))))))

(defn vec-add-unique! [v s]
  (if (vec-has-str? v s)
    v
    (vec-conj! v s)))

(defn encode-text-array! [b v]
  (cbor-enc-array-header! b (vec-count v))
  (loop [i 0]
    (if (>= i (vec-count v))
          b
      (do (cbor-enc-text! b (vec-nth v i))
          (recur (+ i 1))))))

(defn encode-abi! [b]
  (do (cbor-enc-text! b "abi")
      (cbor-enc-text! b "kotoba.selfhost.safe-analyzer.v1")))

(defn input-abi-ok? [ctx]
  (if (str-eq? (map-text ctx "abi") "kotoba.selfhost.safe-analyzer.v1") 1 0))

(defn encode-input-abi-error [ctx]
  (let [b (bytes-alloc 192)]
    (cbor-enc-map-header! b 4)
    (encode-abi! b)
    (cbor-enc-text! b "error")    (cbor-enc-text! b "input-abi-mismatch")
    (cbor-enc-text! b "expected") (cbor-enc-text! b "kotoba.selfhost.safe-analyzer.v1")
    (cbor-enc-text! b "got")      (cbor-enc-text! b (map-text ctx "abi"))
    (bytes-finish b)))

(defn analyze-calls [r]
  (let [n (cbor-read-arg r)
        effects (vec-make 8)
        caps (vec-make 8)
        targets (vec-make 16)]
    (loop [i 0 known 0]
      (if (>= i n)
        (let [b (bytes-alloc 256)]
          (cbor-enc-map-header! b 5)
          (encode-abi! b)
          (cbor-enc-text! b "effects") (encode-text-array! b effects)
          (cbor-enc-text! b "caps")    (encode-text-array! b caps)
          (cbor-enc-text! b "targets") (encode-text-array! b targets)
          (cbor-enc-text! b "known")   (cbor-enc-text! b (if known "true" "false"))
          (bytes-finish b))
        (let [call-n (cbor-read-arg r)
              op (cbor-text r)
              target (if (> call-n 1) (cbor-text r) "")
              effect (classify-effect op)
              cap (classify-cap op)
              next-known (if (str-eq? cap "none") known 1)]
          (if (> call-n 2)
            (loop [j 2] (if (>= j call-n) 0 (do (cbor-skip r) (recur (+ j 1))))))
          (if (str-eq? effect "pure") effects (vec-add-unique! effects effect))
          (if (str-eq? cap "none") caps (vec-add-unique! caps cap))
          (if (str-eq? target "") targets (vec-add-unique! targets target))
          (recur (+ i 1) next-known))))))

(defn target-op? [op]
  (cond
    (str-eq? op "kqe-assert!") 1
    (str-eq? op "kqe-retract!") 1
    (str-eq? op "kqe-get-objects") 1
    (str-eq? op "llm-infer") 1
    :else 0))

(defn note-op! [effects caps targets op target]
  (let [effect (classify-effect op)
        cap (classify-cap op)]
    (if (str-eq? effect "pure") effects (vec-add-unique! effects effect))
    (if (str-eq? cap "none") caps (vec-add-unique! caps cap))
    (if (str-eq? target "") targets (vec-add-unique! targets target))
    (if (str-eq? cap "none") 0 1)))

(defn note-resource-target! [graph-write-targets graph-read-targets infer-targets op target]
  (if (str-eq? target "")
    0
    (cond
      (or (str-eq? op "kqe-assert!") (str-eq? op "kqe-retract!"))
        (do (vec-add-unique! graph-write-targets target) 1)
      (str-eq? op "kqe-get-objects")
        (do (vec-add-unique! graph-read-targets target) 1)
      (str-eq? op "llm-infer")
        (do (vec-add-unique! infer-targets target) 1)
      :else 0)))

(defn control-op? [op]
  (cond
    (str-eq? op "") 1
    (str-eq? op "do") 1
    (str-eq? op "let") 1
    (str-eq? op "loop") 1
    (str-eq? op "if") 1
    (str-eq? op "fn") 1
    (str-eq? op "recur") 1
    (str-eq? op "make-closure") 1
    (str-eq? op "call-value") 1
    (str-eq? op "pure-builtin") 1
    :else 0))

(defn note-call! [calls op]
  (if (and (= (control-op? op) 0)
           (str-eq? (classify-cap op) "none"))
    (vec-add-unique! calls op)
    calls))

(defn function-key [name arity]
  (str name "#" (str-int arity)))

(defn note-call-arity! [calls op arity]
  (if (and (= (control-op? op) 0)
           (str-eq? (classify-cap op) "none"))
    (vec-add-unique! calls (function-key op arity))
    calls))

(defn inert-op? [op]
  (cond
    (str-eq? op "quote") 1
    (str-eq? op "var") 1
    (str-eq? op "comment") 1
    :else 0))

(defn subset-forbidden-op? [op]
  (cond
    (str-eq? op "eval") 1
    (str-eq? op "clojure.core/eval") 1
    (str-eq? op "read") 1
    (str-eq? op "clojure.core/read") 1
    (str-eq? op "read-string") 1
    (str-eq? op "clojure.core/read-string") 1
    (str-eq? op "load") 1
    (str-eq? op "load-string") 1
    (str-eq? op "load-file") 1
    (str-eq? op "load-reader") 1
    (str-eq? op "require") 1
    (str-eq? op "use") 1
    (str-eq? op "import") 1
    (str-eq? op "in-ns") 1
    (str-eq? op "refer") 1
    (str-eq? op "alias") 1
    (str-eq? op "create-ns") 1
    (str-eq? op "remove-ns") 1
    (str-eq? op "set!") 1
    (str-eq? op "binding") 1
    (str-eq? op "with-redefs") 1
    (str-eq? op "alter-var-root") 1
    (str-eq? op "intern") 1
    (str-eq? op "atom") 1
    (str-eq? op "swap!") 1
    (str-eq? op "swap-vals!") 1
    (str-eq? op "reset!") 1
    (str-eq? op "reset-vals!") 1
    (str-eq? op "compare-and-set!") 1
    (str-eq? op "volatile!") 1
    (str-eq? op "vswap!") 1
    (str-eq? op "vreset!") 1
    (str-eq? op "ref") 1
    (str-eq? op "ref-set") 1
    (str-eq? op "alter") 1
    (str-eq? op "commute") 1
    (str-eq? op "ensure") 1
    (str-eq? op "dosync") 1
    (str-eq? op "agent") 1
    (str-eq? op "send") 1
    (str-eq? op "send-off") 1
    (str-eq? op "send-via") 1
    (str-eq? op "add-watch") 1
    (str-eq? op "remove-watch") 1
    (str-eq? op "slurp") 1
    (str-eq? op "spit") 1
    (str-eq? op "print") 1
    (str-eq? op "println") 1
    (str-eq? op "pr") 1
    (str-eq? op "prn") 1
    (str-eq? op "printf") 1
    (str-eq? op "print-str") 1
    (str-eq? op "read-line") 1
    (str-eq? op "flush") 1
    (str-eq? op "with-out-str") 1
    (str-eq? op "rand") 1
    (str-eq? op "rand-int") 1
    (str-eq? op "rand-nth") 1
    (str-eq? op "shuffle") 1
    (str-eq? op "random-uuid") 1
    (str-eq? op "future") 1
    (str-eq? op "future-call") 1
    (str-eq? op "promise") 1
    (str-eq? op "deliver") 1
    (str-eq? op "pmap") 1
    (str-eq? op "pcalls") 1
    (str-eq? op "pvalues") 1
    (str-eq? op "locking") 1
    (str-eq? op "alloc") 1
    (str-eq? op "load64") 1
    (str-eq? op "store64!") 1
    (str-eq? op "load32") 1
    (str-eq? op "store32!") 1
    (str-eq? op "resolve") 1
    (str-eq? op "clojure.core/resolve") 1
    (str-eq? op "ns-resolve") 1
    (str-eq? op "find-var") 1
    (str-eq? op "gen-class") 1
    (str-eq? op "proxy") 1
    (str-eq? op "reify") 1
    (str-eq? op "new") 1
    (str-eq? op "defmacro") 1
    (str-eq? op "definline") 1
    :else 0))

(defn note-subset-denial! [subset-denials op]
  (if (subset-forbidden-op? op)
    (vec-add-unique! subset-denials op)
    subset-denials))

(defn source-host-interop-op? [op]
  (let [n (str-len op)]
    (if (= n 0)
      0
      (if (= (byte-at op 0) 46)
        1
        (if (and (> n 1) (= (byte-at op (- n 1)) 46))
          1
          0)))))

(defn note-source-subset-denial! [subset-denials kind op form]
  (if (or (subset-forbidden-op? op)
          (and (str-eq? kind "head") (source-host-interop-op? op)))
    (vec-add-unique! subset-denials (if (str-eq? form "") op form))
    subset-denials))

(defn read-source-subset-fact! [r subset-denials]
  (let [pair-count (cbor-read-arg r)]
    (loop [i 0 kind "" op "" form ""]
      (if (>= i pair-count)
        (note-source-subset-denial! subset-denials kind op form)
        (let [k (cbor-text r)]
          (cond
            (str-eq? k "kind")
              (recur (+ i 1) (cbor-text r) op form)
            (str-eq? k "op")
              (recur (+ i 1) kind (cbor-text r) form)
            (str-eq? k "form")
              (recur (+ i 1) kind op (cbor-text r))
            :else
              (do (cbor-skip r)
                  (recur (+ i 1) kind op form))))))))

(defn read-source-subset! [r subset-denials]
  (let [n (cbor-read-arg r)]
    (loop [i 0]
      (if (>= i n)
        subset-denials
        (do (if (= (cbor-major r) 5)
              (read-source-subset-fact! r subset-denials)
              (cbor-skip r))
            (recur (+ i 1)))))))

(defn type-numeric-op? [op]
  (cond
    (str-eq? op "+") 1
    (str-eq? op "-") 1
    (str-eq? op "*") 1
    (str-eq? op "/") 1
    (str-eq? op "mod") 1
    (str-eq? op "rem") 1
    (str-eq? op "inc") 1
    (str-eq? op "dec") 1
    (str-eq? op "abs") 1
    (str-eq? op "min") 1
    (str-eq? op "max") 1
    (str-eq? op "pos?") 1
    (str-eq? op "neg?") 1
    (str-eq? op "zero?") 1
    (str-eq? op "even?") 1
    (str-eq? op "odd?") 1
    (str-eq? op "bit-and") 1
    (str-eq? op "bit-or") 1
    (str-eq? op "bit-xor") 1
    (str-eq? op "bit-shift-left") 1
    (str-eq? op "bit-shift-right") 1
    (str-eq? op "double") 1
    (str-eq? op "int") 1
    (str-eq? op "Math/round") 1
    (str-eq? op "Math/floor") 1
    (str-eq? op "Math/ceil") 1
    (str-eq? op "Math/abs") 1
    (str-eq? op "Math/sqrt") 1
    :else 0))

(defn type-numeric-comparison-op? [op]
  (cond
    (str-eq? op "<") 1
    (str-eq? op ">") 1
    (str-eq? op "<=") 1
    (str-eq? op ">=") 1
    :else 0))

(defn note-type-denial! [type-denials op]
  (vec-add-unique! type-denials op))

;; Literal fact encoding returned by analyze-ast-typed-value!:
;;   0 = unknown/non-literal, 2 = numeric non-int literal,
;;   1000000000000 + len = string literal,
;;   3000000000000 + signed-int-value = integer literal.
(defn literal-kind [fact]
  (cond
    (= fact 2) 2
    (>= fact 2000000000000) 2
    (>= fact 1000000000000) 1
    :else 0))

(defn literal-string-len [fact] (- fact 1000000000000))
(defn literal-int-value [fact] (- fact 3000000000000))
(defn literal-int? [fact] (if (>= fact 2000000000000) 1 0))

(defn division-op? [op]
  (cond
    (str-eq? op "/") 1
    (str-eq? op "quot") 1
    (str-eq? op "mod") 1
    (str-eq? op "rem") 1
    :else 0))

(defn note-literal-type! [type-denials op idx fact]
  (let [req (type-req-for-op-arg op idx)
        actual (fact-type-name fact)]
    (do (if (and (not (str-eq? req ""))
                 (not (str-eq? actual ""))
                 (not (str-eq? req actual)))
          (note-type-denial! type-denials op))
        type-denials)))

(defn note-literal-value! [type-denials op idx first-fact fact]
  (do (if (and (division-op? op)
               (> idx 0)
               (= (literal-int? fact) 1)
               (= (literal-int-value fact) 0))
        (note-type-denial! type-denials op))
      (if (and (str-eq? op "bytes-alloc")
               (= idx 0)
               (= (literal-int? fact) 1)
               (< (literal-int-value fact) 0))
        (note-type-denial! type-denials op))
      (if (and (str-eq? op "byte-at")
               (= idx 1)
               (= (literal-kind first-fact) 1)
               (= (literal-int? fact) 1)
               (or (< (literal-int-value fact) 0)
                   (>= (literal-int-value fact) (literal-string-len first-fact))))
        (note-type-denial! type-denials op))
      type-denials))

(defn read-source-type-args! [r type-denials op]
  (let [n (cbor-read-arg r)]
    (loop [i 0 first-fact 0]
      (if (>= i n)
        type-denials
        (let [fact (read-cbor-signed-int r)]
          (note-literal-type! type-denials op i fact)
          (note-literal-value! type-denials op i first-fact fact)
          (recur (+ i 1) (if (= i 0) fact first-fact)))))))

(defn read-source-type-fact! [r type-denials]
  (let [pair-count (cbor-read-arg r)]
    (loop [i 0 op ""]
      (if (>= i pair-count)
        type-denials
        (let [k (cbor-text r)]
          (cond
            (str-eq? k "op")
              (recur (+ i 1) (cbor-text r))
            (str-eq? k "args")
              (do (read-source-type-args! r type-denials op)
                  (recur (+ i 1) op))
            :else
              (do (cbor-skip r)
                  (recur (+ i 1) op))))))))

(defn read-source-types! [r type-denials]
  (let [n (cbor-read-arg r)]
    (loop [i 0]
      (if (>= i n)
        type-denials
        (do (if (= (cbor-major r) 5)
              (read-source-type-fact! r type-denials)
              (cbor-skip r))
            (recur (+ i 1)))))))

(defn read-source-effect-fact! [r effects caps targets graph-write-targets graph-read-targets infer-targets]
  (let [pair-count (cbor-read-arg r)]
    (loop [i 0 op "" target ""]
      (if (>= i pair-count)
        (do (note-op! effects caps targets op target)
            (note-resource-target! graph-write-targets graph-read-targets infer-targets op target))
        (let [k (cbor-text r)]
          (cond
            (str-eq? k "op")
              (recur (+ i 1) (cbor-text r) target)
            (str-eq? k "target")
              (recur (+ i 1) op (cbor-text r))
            :else
              (do (cbor-skip r)
                  (recur (+ i 1) op target))))))))

(defn read-source-effects! [r effects caps targets graph-write-targets graph-read-targets infer-targets]
  (let [n (cbor-read-arg r)]
    (loop [i 0]
      (if (>= i n)
        effects
        (do (if (= (cbor-major r) 5)
              (read-source-effect-fact! r effects caps targets graph-write-targets graph-read-targets infer-targets)
              (cbor-skip r))
            (recur (+ i 1)))))))

(defn type-req-for-op-arg [op idx]
  (cond
    (or (type-numeric-op? op) (type-numeric-comparison-op? op)) "num"
    (and (or (str-eq? op "str-len") (str-eq? op "byte-at")) (= idx 0)) "str"
    (and (str-eq? op "byte-at") (= idx 1)) "num"
    (and (str-eq? op "bytes-alloc") (= idx 0)) "num"
    (and (str-eq? op "byte-append!") (= idx 0)) "bytes"
    (and (str-eq? op "byte-append!") (= idx 1)) "num"
    (or (str-eq? op "bytes-len") (str-eq? op "bytes-finish")) "bytes"
    (or (str-eq? op "has-capability?")
        (str-eq? op "llm-infer")
        (str-eq? op "kqe-assert!")
        (str-eq? op "kqe-retract!")
        (str-eq? op "kqe-get-objects")
        (str-eq? op "kqe-query")) "str"
    :else ""))

(defn fact-type-name [fact]
  (cond
    (= fact 5) "str"
    (= fact 4) "bytes"
    (= (literal-kind fact) 1) "str"
    (= (literal-kind fact) 2) "num"
    :else ""))

(defn type-fact-for-builtin-result [op]
  (cond
    (or (type-numeric-op? op)
        (str-eq? op "str-len")
        (str-eq? op "byte-at")
        (str-eq? op "bytes-len")
        (str-eq? op "has-capability?")) 2
    (str-eq? op "bytes-alloc") 4
    (or (str-eq? op "bytes-finish") (str-eq? op "llm-infer")) 5
    :else 0))

(defn local-type-fact [local-names local-facts local-limit name]
  (loop [i (- local-limit 1)]
    (if (< i 0)
      0
      (if (str-eq? (vec-nth local-names i) name)
        (vec-nth local-facts i)
        (recur (- i 1))))))

(defn type-join-fact [a b]
  (let [ta (fact-type-name a)
        tb (fact-type-name b)]
    (if (and (not (str-eq? ta "")) (str-eq? ta tb))
      (cond
        (str-eq? ta "str") 5
        (str-eq? ta "num") 2
        (str-eq? ta "bytes") 4
        :else 0)
      0)))

(defn concrete-type-mismatch? [a b]
  (let [ta (fact-type-name a)
        tb (fact-type-name b)]
    (and (not (str-eq? ta ""))
         (not (str-eq? tb ""))
         (not (str-eq? ta tb)))))

(defn note-param-type-req! [params type-param-reqs type-shadowed-params name req]
  (if (or (str-eq? req "")
          (= (vec-has-str? params name) 0)
          (vec-has-str? type-shadowed-params name))
    0
    (vec-add-unique! type-param-reqs (str name ":" req))))

(defn note-shadowed-param! [params type-shadowed-params name]
  (if (vec-has-str? params name)
    (vec-add-unique! type-shadowed-params name)
    type-shadowed-params))

(defn param-type-req [params reqs shadowed name]
  (if (vec-has-str? shadowed name)
    ""
    (let [num-key (str name ":num")
          str-key (str name ":str")
          bytes-key (str name ":bytes")
          has-num (vec-has-str? reqs num-key)
          has-str (vec-has-str? reqs str-key)
          has-bytes (vec-has-str? reqs bytes-key)]
      (cond
        (or (and has-num has-str)
            (and has-num has-bytes)
            (and has-str has-bytes)) ""
        has-num "num"
        has-str "str"
        has-bytes "bytes"
        :else ""))))

(defn call-literal-type-denies? [required actual]
  (and (not (str-eq? required ""))
       (not (str-eq? actual ""))
       (not (str-eq? required actual))))

(defn note-return-call-type-req! [type-call-arg-rows op req name arity]
  (if (or (str-eq? req "") (str-eq? name ""))
    0
    (let [row (vec-make 5)]
      (vec-conj! row "$ret")
      (vec-conj! row req)
      (vec-conj! row name)
      (vec-conj! row op)
      (vec-conj! row arity)
      (vec-conj! type-call-arg-rows row))))

(defn read-cbor-signed-int [r]
  (let [major (cbor-major r)
        arg (cbor-read-arg r)]
    (if (= major 1)
      (- -1 arg)
      arg)))

(defn skip-n! [r n]
  (loop [i 0]
    (if (>= i n)
      0
      (do (cbor-skip r)
          (recur (+ i 1))))))

(defn read-target-arg [r]
  (if (= (cbor-major r) 3)
    (cbor-text r)
    (do (cbor-skip r) "")))

(declare analyze-form-value!)

(defn analyze-binding-array! [r effects caps targets calls graph-write-targets graph-read-targets infer-targets]
  (let [n (cbor-read-arg r)]
    (loop [i 0 known 0]
      (if (>= i n)
        known
        (do (cbor-skip r)
            (recur (+ i 2)
                   (if (and (< (+ i 1) n)
                            (analyze-form-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets))
                     1
                     known)))))))

(defn analyze-form-array! [r effects caps targets calls graph-write-targets graph-read-targets infer-targets]
  (let [n (cbor-read-arg r)]
    (if (= n 0)
      0
      (let [op (if (= (cbor-major r) 3) (cbor-text r) "")
            has-target (if (and (> n 1) (target-op? op)) 1 0)
            target (if has-target (read-target-arg r) "")
            known (note-op! effects caps targets op target)
            start (if has-target 2 1)]
        (if (inert-op? op)
          (do (skip-n! r (- n 1)) 0)
          (do (note-call! calls op)
              (note-resource-target! graph-write-targets graph-read-targets infer-targets op target)
              (if (and (or (str-eq? op "let") (str-eq? op "loop")) (> n 1))
                (let [binding-known (analyze-binding-array! r effects caps targets calls graph-write-targets graph-read-targets infer-targets)]
                  (loop [i 2 any-known (if binding-known 1 known)]
                    (if (>= i n)
                      any-known
                      (recur (+ i 1)
                             (if (analyze-form-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets) 1 any-known)))))
                (if (and (str-eq? op "fn") (> n 1))
                  (do (cbor-skip r)
                      (loop [i 2 any-known known]
                        (if (>= i n)
                          any-known
                          (recur (+ i 1)
                                 (if (analyze-form-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets) 1 any-known)))))
                  (loop [i start any-known known]
                    (if (>= i n)
                      any-known
                      (recur (+ i 1)
                             (if (analyze-form-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets) 1 any-known))))))))))))

(defn analyze-form-value! [r effects caps targets calls graph-write-targets graph-read-targets infer-targets]
  (let [major (cbor-major r)]
    (cond
      (= major 4) (analyze-form-array! r effects caps targets calls graph-write-targets graph-read-targets infer-targets)
      (= major 5) (let [n (cbor-read-arg r)]
                    (loop [i 0 known 0]
                      (if (>= i n)
                        known
                        (do (cbor-skip r)
                            (recur (+ i 1)
                                   (if (analyze-form-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets) 1 known))))))
      :else (do (cbor-skip r) 0))))

(defn encode-summary [effects caps targets known]
  (let [b (bytes-alloc 256)]
    (cbor-enc-map-header! b 5)
    (encode-abi! b)
    (cbor-enc-text! b "effects") (encode-text-array! b effects)
    (cbor-enc-text! b "caps")    (encode-text-array! b caps)
    (cbor-enc-text! b "targets") (encode-text-array! b targets)
    (cbor-enc-text! b "known")   (cbor-enc-text! b (if known "true" "false"))
    (bytes-finish b)))

(defn analyze-forms-into! [r effects caps targets calls graph-write-targets graph-read-targets infer-targets]
  (let [n (cbor-read-arg r)]
    (loop [i 0 known 0]
      (if (>= i n)
        known
        (recur (+ i 1)
               (if (analyze-form-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets) 1 known))))))

(defn analyze-forms [r]
  (let [effects (vec-make 8)
        caps (vec-make 8)
        targets (vec-make 16)
        calls (vec-make 16)
        graph-write-targets (vec-make 16)
        graph-read-targets (vec-make 16)
        infer-targets (vec-make 16)]
    (encode-summary effects caps targets
                    (analyze-forms-into! r effects caps targets calls graph-write-targets graph-read-targets infer-targets))))

(declare analyze-ast-value!)

(defn analyze-ast-array! [r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params]
  (let [n (cbor-read-arg r)]
    (loop [i 0 known 0]
      (if (>= i n)
        known
        (recur (+ i 1)
               (if (analyze-ast-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params) 1 known))))))

(defn analyze-ast-bindings! [r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params]
  (let [n (cbor-read-arg r)]
    (loop [i 0 known 0]
      (if (>= i n)
        known
        (let [pair-count (cbor-read-arg r)]
          (recur (+ i 1)
                 (loop [j 0 inner-known known]
                   (if (>= j pair-count)
                     inner-known
                     (let [k (cbor-text r)]
                       (if (str-eq? k "name")
                         (do (note-shadowed-param! params type-shadowed-params (cbor-text r))
                             (recur (+ j 1) inner-known))
                         (if (str-eq? k "value")
                         (recur (+ j 1)
                                  (if (analyze-ast-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params) 1 inner-known))
                         (do (cbor-skip r)
                               (recur (+ j 1) inner-known)))))))))))))

(defn note-param-resource-target! [params shadowed-params graph-write-param-targets graph-read-param-targets infer-param-targets op name]
  (if (and (vec-has-str? params name)
           (= (vec-has-str? shadowed-params name) 0))
    (cond
      (or (str-eq? op "kqe-assert!") (str-eq? op "kqe-retract!"))
        (do (vec-add-unique! graph-write-param-targets name) 1)
      (str-eq? op "kqe-get-objects")
        (do (vec-add-unique! graph-read-param-targets name) 1)
      (str-eq? op "llm-infer")
        (do (vec-add-unique! infer-param-targets name) 1)
      :else 0)
    0))

(defn analyze-local-type-array! [r type-denials type-call-arg-rows local-names local-facts local-limit recur-start recur-limit]
  (if (= (cbor-major r) 4)
    (let [n (cbor-read-arg r)]
      (loop [i 0 last 0]
        (if (>= i n)
          last
          (recur (+ i 1) (analyze-local-type-value! r type-denials type-call-arg-rows local-names local-facts local-limit recur-start recur-limit)))))
    (do (cbor-skip r) 0)))

(defn analyze-local-type-binding! [r type-denials type-call-arg-rows local-names local-facts local-limit recur-start recur-limit]
  (if (= (cbor-major r) 5)
    (let [pair-count (cbor-read-arg r)]
      (loop [i 0 name "" fact 0]
        (if (>= i pair-count)
          (if (str-eq? name "")
            local-limit
            (do (vec-conj! local-names name)
                (vec-conj! local-facts fact)
                (+ local-limit 1)))
          (let [k (cbor-text r)]
            (cond
              (str-eq? k "name")
                (recur (+ i 1) (cbor-text r) fact)
              (str-eq? k "value")
                (recur (+ i 1) name (analyze-local-type-value! r type-denials type-call-arg-rows local-names local-facts local-limit recur-start recur-limit))
              :else
                (do (cbor-skip r)
                    (recur (+ i 1) name fact)))))))
    (do (cbor-skip r) local-limit)))

(defn analyze-local-type-bindings! [r type-denials type-call-arg-rows local-names local-facts local-limit recur-start recur-limit]
  (if (= (cbor-major r) 4)
    (let [n (cbor-read-arg r)]
      (loop [i 0 limit local-limit]
        (if (>= i n)
          limit
          (recur (+ i 1) (analyze-local-type-binding! r type-denials type-call-arg-rows local-names local-facts limit recur-start recur-limit)))))
    (do (cbor-skip r) local-limit)))

(defn analyze-local-type-builtin-args! [r type-denials type-call-arg-rows local-names local-facts local-limit recur-start recur-limit op]
  (if (= (cbor-major r) 4)
    (let [n (cbor-read-arg r)]
      (loop [i 0 first-fact 0]
        (if (>= i n)
          1
          (let [fact (analyze-local-type-value! r type-denials type-call-arg-rows local-names local-facts local-limit recur-start recur-limit)]
            (note-literal-type! type-denials op i fact)
            (note-literal-value! type-denials op i first-fact fact)
            (recur (+ i 1) (if (= i 0) fact first-fact))))))
    (do (cbor-skip r) 0)))

(defn analyze-local-type-call-args! [r type-denials type-call-arg-rows local-names local-facts local-limit recur-start recur-limit name]
  (if (= (cbor-major r) 4)
    (let [n (cbor-read-arg r)]
      (let [row (vec-make 8)]
        (vec-conj! row name)
        (loop [i 0]
          (if (>= i n)
            (do (vec-conj! type-call-arg-rows row) 1)
            (let [fact (analyze-local-type-value! r type-denials type-call-arg-rows local-names local-facts local-limit recur-start recur-limit)]
              (vec-conj! row (if (str-eq? (fact-type-name fact) "str") "str" ""))
              (recur (+ i 1)))))))
    (do (cbor-skip r) 0)))

(defn analyze-local-type-recur-args! [r type-denials type-call-arg-rows local-names local-facts local-limit recur-start recur-limit]
  (if (= (cbor-major r) 4)
    (let [n (cbor-read-arg r)]
      (loop [i 0]
        (if (>= i n)
          1
          (let [fact (analyze-local-type-value! r type-denials type-call-arg-rows local-names local-facts local-limit recur-start recur-limit)
                binding-idx (+ recur-start i)]
            (do (if (and (< binding-idx recur-limit)
                         (concrete-type-mismatch? (vec-nth local-facts binding-idx) fact))
                  (note-type-denial! type-denials "recur"))
                (recur (+ i 1)))))))
    (do (cbor-skip r) 0)))

(defn analyze-local-type-map! [r type-denials type-call-arg-rows local-names local-facts local-limit recur-start recur-limit]
  (let [pair-count (cbor-read-arg r)]
    (loop [i 0 tag "" op "" name "" fact 0 then-fact 0 else-fact 0 body-fact 0 scope-limit local-limit active-recur-start recur-start active-recur-limit recur-limit]
      (if (>= i pair-count)
        (cond
          (str-eq? tag "var") (local-type-fact local-names local-facts scope-limit name)
          (str-eq? tag "builtin") (type-fact-for-builtin-result op)
          (str-eq? tag "if") (type-join-fact then-fact else-fact)
          (or (str-eq? tag "do") (str-eq? tag "let") (str-eq? tag "loop")) body-fact
          :else fact)
          (let [k (cbor-text r)]
            (cond
              (str-eq? k "tag")
              (recur (+ i 1) (cbor-text r) op name fact then-fact else-fact body-fact scope-limit active-recur-start active-recur-limit)
            (str-eq? k "op")
              (recur (+ i 1) tag (cbor-text r) name fact then-fact else-fact body-fact scope-limit active-recur-start active-recur-limit)
            (str-eq? k "name")
              (recur (+ i 1) tag op (cbor-text r) fact then-fact else-fact body-fact scope-limit active-recur-start active-recur-limit)
            (str-eq? k "value")
              (cond
                (str-eq? tag "str")
                  (let [s (cbor-text r)]
                    (recur (+ i 1) tag op name (+ 1000000000000 (str-len s)) then-fact else-fact body-fact scope-limit active-recur-start active-recur-limit))
                (or (str-eq? tag "int") (str-eq? tag "float"))
                  (if (str-eq? tag "int")
                    (let [n (read-cbor-signed-int r)]
                      (recur (+ i 1) tag op name (+ 3000000000000 n) then-fact else-fact body-fact scope-limit active-recur-start active-recur-limit))
                    (do (cbor-skip r)
                        (recur (+ i 1) tag op name 2 then-fact else-fact body-fact scope-limit active-recur-start active-recur-limit)))
                :else
                  (do (analyze-local-type-value! r type-denials type-call-arg-rows local-names local-facts scope-limit active-recur-start active-recur-limit)
                      (recur (+ i 1) tag op name fact then-fact else-fact body-fact scope-limit active-recur-start active-recur-limit)))
            (str-eq? k "args")
              (if (str-eq? tag "builtin")
                (do (analyze-local-type-builtin-args! r type-denials type-call-arg-rows local-names local-facts scope-limit active-recur-start active-recur-limit op)
                    (recur (+ i 1) tag op name fact then-fact else-fact body-fact scope-limit active-recur-start active-recur-limit))
                (if (str-eq? tag "recur")
                  (do (analyze-local-type-recur-args! r type-denials type-call-arg-rows local-names local-facts scope-limit active-recur-start active-recur-limit)
                      (recur (+ i 1) tag op name fact then-fact else-fact body-fact scope-limit active-recur-start active-recur-limit))
                  (do (analyze-local-type-call-args! r type-denials type-call-arg-rows local-names local-facts scope-limit active-recur-start active-recur-limit name)
                      (recur (+ i 1) tag op name fact then-fact else-fact body-fact scope-limit active-recur-start active-recur-limit))))
            (str-eq? k "bindings")
              (if (or (str-eq? tag "let") (str-eq? tag "loop"))
                (let [start scope-limit
                      next-limit (analyze-local-type-bindings! r type-denials type-call-arg-rows local-names local-facts scope-limit active-recur-start active-recur-limit)]
                  (if (str-eq? tag "loop")
                    (recur (+ i 1) tag op name fact then-fact else-fact body-fact next-limit start next-limit)
                    (recur (+ i 1) tag op name fact then-fact else-fact body-fact next-limit active-recur-start active-recur-limit)))
                (do (cbor-skip r)
                    (recur (+ i 1) tag op name fact then-fact else-fact body-fact scope-limit active-recur-start active-recur-limit)))
            (str-eq? k "body")
              (if (or (str-eq? tag "do") (str-eq? tag "let") (str-eq? tag "loop"))
                (recur (+ i 1) tag op name fact then-fact else-fact (analyze-local-type-array! r type-denials type-call-arg-rows local-names local-facts scope-limit active-recur-start active-recur-limit) scope-limit active-recur-start active-recur-limit)
                (do (analyze-local-type-array! r type-denials type-call-arg-rows local-names local-facts scope-limit active-recur-start active-recur-limit)
                    (recur (+ i 1) tag op name fact then-fact else-fact body-fact scope-limit active-recur-start active-recur-limit)))
            (str-eq? k "cond")
              (do (analyze-local-type-value! r type-denials type-call-arg-rows local-names local-facts scope-limit active-recur-start active-recur-limit)
                  (recur (+ i 1) tag op name fact then-fact else-fact body-fact scope-limit active-recur-start active-recur-limit))
            (str-eq? k "then")
              (recur (+ i 1) tag op name fact (analyze-local-type-value! r type-denials type-call-arg-rows local-names local-facts scope-limit active-recur-start active-recur-limit) else-fact body-fact scope-limit active-recur-start active-recur-limit)
            (str-eq? k "else")
              (recur (+ i 1) tag op name fact then-fact (analyze-local-type-value! r type-denials type-call-arg-rows local-names local-facts scope-limit active-recur-start active-recur-limit) body-fact scope-limit active-recur-start active-recur-limit)
            (str-eq? k "captures")
              (do (analyze-local-type-array! r type-denials type-call-arg-rows local-names local-facts scope-limit active-recur-start active-recur-limit)
                  (recur (+ i 1) tag op name fact then-fact else-fact body-fact scope-limit active-recur-start active-recur-limit))
            :else
              (do (cbor-skip r)
                  (recur (+ i 1) tag op name fact then-fact else-fact body-fact scope-limit active-recur-start active-recur-limit))))))))

(defn analyze-local-type-value! [r type-denials type-call-arg-rows local-names local-facts local-limit recur-start recur-limit]
  (let [major (cbor-major r)]
    (cond
      (= major 5) (analyze-local-type-map! r type-denials type-call-arg-rows local-names local-facts local-limit recur-start recur-limit)
      (= major 4) (analyze-local-type-array! r type-denials type-call-arg-rows local-names local-facts local-limit recur-start recur-limit)
      :else (do (cbor-skip r) 0))))

(defn analyze-local-type-body! [r type-denials type-call-arg-rows]
  (let [local-names (vec-make 128)
        local-facts (vec-make 128)]
    (analyze-local-type-array! r type-denials type-call-arg-rows local-names local-facts 0 0 0)))

(defn read-ast-resource-target! [r params graph-write-param-targets graph-read-param-targets infer-param-targets op type-denials type-param-reqs type-shadowed-params]
  (if (= (cbor-major r) 5)
    (let [pair-count (cbor-read-arg r)]
      (loop [i 0 tag "" target "" var-name "" fact 0]
        (if (>= i pair-count)
          (do (if (and (str-eq? target "") (not (str-eq? var-name "")))
                (note-param-resource-target! params type-shadowed-params graph-write-param-targets graph-read-param-targets infer-param-targets op var-name))
              (if (not (str-eq? var-name ""))
                (note-param-type-req! params type-param-reqs type-shadowed-params var-name (type-req-for-op-arg op 0)))
              (note-literal-type! type-denials op 0 fact)
              target)
          (let [k (cbor-text r)]
            (cond
              (str-eq? k "tag")
                (recur (+ i 1) (cbor-text r) target var-name fact)
              (str-eq? k "value")
                (cond
                  (str-eq? tag "str")
                    (let [s (cbor-text r)]
                      (recur (+ i 1) tag s var-name (+ 1000000000000 (str-len s))))
                  (or (str-eq? tag "int") (str-eq? tag "float"))
                    (if (str-eq? tag "int")
                      (let [n (read-cbor-signed-int r)]
                        (recur (+ i 1) tag target var-name (+ 3000000000000 n)))
                      (do (cbor-skip r)
                          (recur (+ i 1) tag target var-name 2)))
                  :else
                    (do (cbor-skip r)
                        (recur (+ i 1) tag target var-name fact)))
              (str-eq? k "name")
                (if (str-eq? tag "var")
                  (recur (+ i 1) tag target (cbor-text r) fact)
                  (do (cbor-skip r)
                      (recur (+ i 1) tag target var-name fact)))
              :else
                (do (cbor-skip r)
                    (recur (+ i 1) tag target var-name fact)))))))
    (do (cbor-skip r) "")))

;; Returns 0 unknown/non-literal, 1 string literal, 2 numeric literal while
;; preserving the normal recursive analyzer walk for non-literal arguments.
(defn analyze-ast-typed-array! [r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params]
  (let [n (cbor-read-arg r)]
    (loop [i 0]
      (if (>= i n)
        0
        (do (analyze-ast-typed-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params)
            (recur (+ i 1)))))))

(defn analyze-ast-typed-bindings! [r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params]
  (let [n (cbor-read-arg r)]
    (loop [i 0]
      (if (>= i n)
        0
        (do (if (= (cbor-major r) 5)
              (let [pair-count (cbor-read-arg r)]
                (loop [j 0]
                  (if (>= j pair-count)
                    0
                    (let [k (cbor-text r)]
                      (cond
                        (str-eq? k "value")
                          (do (analyze-ast-typed-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params)
                              (recur (+ j 1)))
                        :else
                          (do (cbor-skip r)
                              (recur (+ j 1))))))))
              (cbor-skip r))
            (recur (+ i 1)))))))

(defn analyze-ast-typed-map! [r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params]
  (let [pair-count (cbor-read-arg r)]
    (loop [i 0 tag "" op "" name "" kind 0]
      (if (>= i pair-count)
        kind
        (let [k (cbor-text r)]
          (cond
            (str-eq? k "tag")
              (recur (+ i 1) (cbor-text r) op name kind)
            (str-eq? k "op")
              (recur (+ i 1) tag (cbor-text r) name kind)
            (str-eq? k "name")
              (recur (+ i 1) tag op (cbor-text r) kind)
            (str-eq? k "value")
              (cond
                (str-eq? tag "str")
                  (let [s (cbor-text r)]
                    (recur (+ i 1) tag op name (+ 1000000000000 (str-len s))))
                (or (str-eq? tag "int") (str-eq? tag "float"))
                  (if (str-eq? tag "int")
                    (let [n (read-cbor-signed-int r)]
                      (recur (+ i 1) tag op name (+ 3000000000000 n)))
                    (do (cbor-skip r)
                        (recur (+ i 1) tag op name 2)))
                :else
                  (do (analyze-ast-typed-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params)
                      (recur (+ i 1) tag op name kind)))
            (str-eq? k "args")
              (if (str-eq? tag "builtin")
                (do (note-subset-denial! subset-denials op)
                    (analyze-ast-builtin-args! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params op)
                    (recur (+ i 1) tag op name 0))
                (if (str-eq? tag "call")
                  (do (note-subset-denial! subset-denials name)
                      (analyze-ast-call-args! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params name)
                      (recur (+ i 1) tag op name 0))
                  (do (analyze-ast-typed-array! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params)
                      (recur (+ i 1) tag op name kind))))
            (str-eq? k "body")
              (do (analyze-ast-typed-array! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params)
                  (recur (+ i 1) tag op name 0))
            (str-eq? k "bindings")
              (do (analyze-ast-typed-bindings! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params)
                  (recur (+ i 1) tag op name 0))
            (or (str-eq? k "cond") (str-eq? k "then") (str-eq? k "else")
                (str-eq? k "f"))
              (do (analyze-ast-typed-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params)
                  (recur (+ i 1) tag op name 0))
            (str-eq? k "captures")
              (do (analyze-ast-typed-array! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params)
                  (recur (+ i 1) tag op name 0))
            :else
              (do (cbor-skip r)
                  (recur (+ i 1) tag op name kind))))))))

(defn analyze-ast-typed-value! [r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params]
  (let [major (cbor-major r)]
    (cond
      (= major 5) (analyze-ast-typed-map! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params)
      (= major 4) (analyze-ast-typed-array! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params)
      :else (do (cbor-skip r) 0))))

(defn analyze-ast-builtin-arg! [r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params op idx]
  (if (= (cbor-major r) 5)
    (let [pair-count (cbor-read-arg r)
          req (type-req-for-op-arg op idx)]
      (loop [i 0 tag "" inner-op "" name "" fact 0 call-arity -1]
        (if (>= i pair-count)
          (do (if (str-eq? tag "var")
                (note-param-type-req! params type-param-reqs type-shadowed-params name req))
              (if (str-eq? tag "call")
                (note-return-call-type-req! type-call-arg-rows op req name call-arity))
              fact)
          (let [k (cbor-text r)]
            (cond
              (str-eq? k "tag")
                (recur (+ i 1) (cbor-text r) inner-op name fact call-arity)
              (str-eq? k "op")
                (recur (+ i 1) tag (cbor-text r) name fact call-arity)
              (str-eq? k "name")
                (recur (+ i 1) tag inner-op (cbor-text r) fact call-arity)
              (str-eq? k "value")
                (cond
                  (str-eq? tag "str")
                    (let [s (cbor-text r)]
                      (recur (+ i 1) tag inner-op name (+ 1000000000000 (str-len s)) call-arity))
                  (or (str-eq? tag "int") (str-eq? tag "float"))
                    (if (str-eq? tag "int")
                      (let [n (read-cbor-signed-int r)]
                        (recur (+ i 1) tag inner-op name (+ 3000000000000 n) call-arity))
                      (do (cbor-skip r)
                          (recur (+ i 1) tag inner-op name 2 call-arity)))
                  :else
                    (do (analyze-ast-typed-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params)
                        (recur (+ i 1) tag inner-op name fact call-arity)))
              (str-eq? k "args")
                (if (str-eq? tag "builtin")
                  (do (note-subset-denial! subset-denials inner-op)
                      (analyze-ast-builtin-args! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params inner-op)
                      (recur (+ i 1) tag inner-op name 0 call-arity))
                  (if (str-eq? tag "call")
                    (do (note-subset-denial! subset-denials name)
                        (let [arity-code (analyze-ast-call-args! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params name)]
                          (recur (+ i 1) tag inner-op name 0
                                 (if (>= arity-code 1000) (- arity-code 1000) call-arity))))
                    (do (analyze-ast-typed-array! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params)
                        (recur (+ i 1) tag inner-op name fact call-arity))))
              (str-eq? k "body")
                (do (analyze-ast-typed-array! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params)
                    (recur (+ i 1) tag inner-op name 0 call-arity))
              (str-eq? k "bindings")
                (do (analyze-ast-typed-bindings! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params)
                    (recur (+ i 1) tag inner-op name 0 call-arity))
              (or (str-eq? k "cond") (str-eq? k "then") (str-eq? k "else")
                  (str-eq? k "f"))
                (do (analyze-ast-typed-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params)
                    (recur (+ i 1) tag inner-op name 0 call-arity))
              :else
                (do (cbor-skip r)
                    (recur (+ i 1) tag inner-op name fact call-arity)))))))
    (do (cbor-skip r) 0)))

(defn analyze-ast-builtin-args! [r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params op]
  (let [n (cbor-read-arg r)]
    (if (and (> n 0) (target-op? op))
      (let [target (read-ast-resource-target! r params graph-write-param-targets graph-read-param-targets infer-param-targets op type-denials type-param-reqs type-shadowed-params)
            known (note-op! effects caps targets op target)]
        (note-resource-target! graph-write-targets graph-read-targets infer-targets op target)
        (loop [i 1 any-known known]
          (if (>= i n)
            any-known
            (let [fact (analyze-ast-builtin-arg! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params op i)]
              (note-literal-type! type-denials op i fact)
              (recur (+ i 1) any-known)))))
      (let [known (note-op! effects caps targets op "")]
        (loop [i 0 any-known known first-fact 0]
          (if (>= i n)
            any-known
            (let [fact (analyze-ast-builtin-arg! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params op i)]
              (note-literal-type! type-denials op i fact)
              (note-literal-value! type-denials op i first-fact fact)
              (recur (+ i 1) any-known (if (= i 0) fact first-fact)))))))))

(defn read-ast-var-name [r]
  (if (= (cbor-major r) 5)
    (let [pair-count (cbor-read-arg r)]
      (loop [i 0 tag "" name ""]
        (if (>= i pair-count)
          (if (str-eq? tag "var") name "")
          (let [k (cbor-text r)]
            (cond
              (str-eq? k "tag")
                (recur (+ i 1) (cbor-text r) name)
              (str-eq? k "name")
                (recur (+ i 1) tag (cbor-text r))
              :else
          (do (cbor-skip r)
              (recur (+ i 1) tag name)))))))
    (do (cbor-skip r) "")))

(defn analyze-ast-call-arg! [r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params row type-row]
  (if (= (cbor-major r) 5)
    (let [pair-count (cbor-read-arg r)]
      (loop [i 0 tag "" op "" name "" target "" fact 0 known 0]
        (if (>= i pair-count)
          (do (if (= (literal-kind fact) 1)
                (vec-conj! row target)
                (vec-conj! row ""))
              (vec-conj! type-row (fact-type-name fact))
              known)
          (let [k (cbor-text r)]
            (cond
              (str-eq? k "tag")
                (recur (+ i 1) (cbor-text r) op name target fact known)
              (str-eq? k "op")
                (recur (+ i 1) tag (cbor-text r) name target fact known)
              (str-eq? k "name")
                (recur (+ i 1) tag op (cbor-text r) target fact known)
              (str-eq? k "value")
                (cond
                  (str-eq? tag "str")
                    (let [s (cbor-text r)]
                      (recur (+ i 1) tag op name s (+ 1000000000000 (str-len s)) known))
                  (or (str-eq? tag "int") (str-eq? tag "float"))
                    (if (str-eq? tag "int")
                      (let [n (read-cbor-signed-int r)]
                        (recur (+ i 1) tag op name target (+ 3000000000000 n) known))
                      (do (cbor-skip r)
                          (recur (+ i 1) tag op name target 2 known)))
                  :else
                    (recur (+ i 1) tag op name target fact
                           (if (analyze-ast-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params) 1 known)))
              (str-eq? k "args")
                (if (str-eq? tag "builtin")
                  (do (note-subset-denial! subset-denials op)
                      (recur (+ i 1) tag op name target 0
                             (if (analyze-ast-builtin-args! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params op) 1 known)))
                  (if (str-eq? tag "call")
                    (do (note-subset-denial! subset-denials name)
                        (recur (+ i 1) tag op name target 0
                               (if (analyze-ast-call-args! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params name) 1 known)))
                    (recur (+ i 1) tag op name target fact
                           (if (analyze-ast-array! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params) 1 known))))
              (str-eq? k "body")
                (recur (+ i 1) tag op name target 0
                       (if (analyze-ast-array! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params) 1 known))
              (str-eq? k "bindings")
                (recur (+ i 1) tag op name target 0
                       (if (analyze-ast-bindings! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params) 1 known))
              (or (str-eq? k "cond") (str-eq? k "then") (str-eq? k "else")
                  (str-eq? k "f"))
                (recur (+ i 1) tag op name target 0
                       (if (analyze-ast-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params) 1 known))
              (str-eq? k "captures")
                (recur (+ i 1) tag op name target 0
                       (if (analyze-ast-array! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params) 1 known))
              :else
                (do (cbor-skip r)
                    (recur (+ i 1) tag op name target fact known)))))))
    (do (vec-conj! row "")
        (vec-conj! type-row "")
        (if (analyze-ast-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params) 1 0))))

(defn analyze-ast-call-args! [r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params name]
  (let [n (cbor-read-arg r)
        row (vec-make 8)
        type-row (vec-make 8)]
    (vec-conj! row name)
    (vec-conj! type-row name)
    (loop [i 0 known 0]
      (if (>= i n)
        (do (note-call-arity! calls name n)
            (vec-conj! call-arg-rows row)
            (vec-conj! type-call-arg-rows type-row)
            (+ 1000 n))
        (recur (+ i 1)
               (if (analyze-ast-call-arg! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params row type-row)
                 1
                 known))))))

(defn analyze-ast-map! [r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params]
  (let [pair-count (cbor-read-arg r)]
    (loop [i 0 tag "" op "" name "" known 0]
      (if (>= i pair-count)
        known
        (let [k (cbor-text r)]
          (cond
            (str-eq? k "tag")
              (recur (+ i 1) (cbor-text r) op name known)
            (str-eq? k "op")
              (recur (+ i 1) tag (cbor-text r) name known)
            (str-eq? k "name")
              (recur (+ i 1) tag op (cbor-text r) known)
            (str-eq? k "args")
              (if (str-eq? tag "builtin")
                (do (note-subset-denial! subset-denials op)
                    (recur (+ i 1) tag op name
                           (if (analyze-ast-builtin-args! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params op) 1 known)))
                (if (str-eq? tag "call")
                  (do (note-subset-denial! subset-denials name)
                      (recur (+ i 1) tag op name
                             (if (analyze-ast-call-args! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params name) 1 known)))
                  (recur (+ i 1) tag op name
                         (if (analyze-ast-array! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params) 1 known))))
            (str-eq? k "body")
              (recur (+ i 1) tag op name
                     (if (analyze-ast-array! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params) 1 known))
            (str-eq? k "bindings")
              (recur (+ i 1) tag op name
                     (if (analyze-ast-bindings! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params) 1 known))
            (or (str-eq? k "cond") (str-eq? k "then") (str-eq? k "else")
                (str-eq? k "value") (str-eq? k "f"))
              (recur (+ i 1) tag op name
                     (if (analyze-ast-value! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params) 1 known))
            (str-eq? k "captures")
              (recur (+ i 1) tag op name
                     (if (analyze-ast-array! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params) 1 known))
            :else
              (do (cbor-skip r)
                  (recur (+ i 1) tag op name known))))))))

(defn analyze-ast-value! [r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params]
  (let [major (cbor-major r)]
    (cond
      (= major 5) (analyze-ast-map! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params)
      (= major 4) (analyze-ast-array! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params)
      :else (do (cbor-skip r) 0))))

(defn find-name-index [names name]
  (loop [i 0]
    (if (>= i (vec-count names))
      -1
      (if (str-eq? (vec-nth names i) name)
        i
        (recur (+ i 1))))))

(defn find-function-index [names params-list name arity]
  (loop [i 0]
    (if (>= i (vec-count names))
      -1
      (if (and (str-eq? (vec-nth names i) name)
               (= (vec-count (vec-nth params-list i)) arity))
        i
        (recur (+ i 1))))))

(defn function-key-index [names params-list key]
  (loop [i 0]
    (if (>= i (vec-count names))
      -1
      (if (str-eq? (function-key (vec-nth names i) (vec-count (vec-nth params-list i))) key)
        i
        (recur (+ i 1))))))

(defn find-call-index [names params-list call]
  (let [idx (function-key-index names params-list call)]
    (if (>= idx 0)
      idx
      (find-name-index names call))))

(defn function-seen-key [names params-list idx]
  (function-key (vec-nth names idx) (vec-count (vec-nth params-list idx))))

(defn merge-vec-strings! [dst src]
  (loop [i 0]
    (if (>= i (vec-count src))
      dst
      (do (vec-add-unique! dst (vec-nth src i))
          (recur (+ i 1))))))

(defn read-text-array-into! [r dst]
  (let [n (cbor-read-arg r)]
    (loop [i 0]
      (if (>= i n)
        dst
        (do (vec-add-unique! dst (cbor-text r))
            (recur (+ i 1)))))))

(defn read-param-targets! [r graph-write-param-targets graph-read-param-targets infer-param-targets]
  (let [n (cbor-read-arg r)]
    (loop [i 0]
      (if (>= i n)
        1
        (let [k (cbor-text r)]
          (cond
            (str-eq? k "graph-write")
              (do (read-text-array-into! r graph-write-param-targets)
                  (recur (+ i 1)))
            (str-eq? k "graph-read")
              (do (read-text-array-into! r graph-read-param-targets)
                  (recur (+ i 1)))
            (str-eq? k "infer")
              (do (read-text-array-into! r infer-param-targets)
                  (recur (+ i 1)))
            :else
              (do (cbor-skip r)
                  (recur (+ i 1)))))))))

(defn read-call-arg-row! [r call-arg-rows]
  (let [n (cbor-read-arg r)
        row (vec-make 8)]
    (loop [i 0 name ""]
      (if (>= i n)
        (do (vec-conj! call-arg-rows row) 1)
        (let [k (cbor-text r)]
          (cond
            (str-eq? k "name")
              (do (vec-conj! row (cbor-text r))
                  (recur (+ i 1) name))
            (str-eq? k "args")
              (do (read-text-array-into! r row)
                  (recur (+ i 1) name))
            :else
              (do (cbor-skip r)
                  (recur (+ i 1) name))))))))

(defn read-call-args! [r call-arg-rows]
  (let [n (cbor-read-arg r)]
    (loop [i 0]
      (if (>= i n)
        1
        (do (if (= (cbor-major r) 5)
              (read-call-arg-row! r call-arg-rows)
              (cbor-skip r))
            (recur (+ i 1)))))))

(defn local-type-kind [local-names local-kinds local-limit name]
  (loop [i (- local-limit 1)]
    (if (< i 0)
      ""
      (if (str-eq? (vec-nth local-names i) name)
        (vec-nth local-kinds i)
        (recur (- i 1))))))

(defn read-ast-direct-body-last-type-name-env [r local-names local-kinds local-limit]
  (if (= (cbor-major r) 4)
    (let [n (cbor-read-arg r)]
      (loop [i 0 out ""]
        (if (>= i n)
          out
          (if (= i (- n 1))
            (recur (+ i 1) (read-ast-direct-type-name-env r local-names local-kinds local-limit))
            (do (cbor-skip r)
                (recur (+ i 1) out))))))
    (do (cbor-skip r) "")))

(defn read-ast-direct-binding! [r local-names local-kinds local-limit]
  (if (= (cbor-major r) 5)
    (let [pair-count (cbor-read-arg r)]
      (loop [i 0 name "" kind ""]
        (if (>= i pair-count)
          (if (str-eq? name "")
            local-limit
            (do (vec-conj! local-names name)
                (vec-conj! local-kinds kind)
                (+ local-limit 1)))
          (let [k (cbor-text r)]
            (cond
              (str-eq? k "name")
                (recur (+ i 1) (cbor-text r) kind)
              (str-eq? k "value")
                (recur (+ i 1) name (read-ast-direct-type-name-env r local-names local-kinds local-limit))
              :else
                (do (cbor-skip r)
                    (recur (+ i 1) name kind)))))))
    (do (cbor-skip r) local-limit)))

(defn read-ast-direct-bindings! [r local-names local-kinds local-limit]
  (if (= (cbor-major r) 4)
    (let [n (cbor-read-arg r)]
      (loop [i 0 limit local-limit]
        (if (>= i n)
          limit
          (recur (+ i 1) (read-ast-direct-binding! r local-names local-kinds limit)))))
    (do (cbor-skip r) local-limit)))

(defn read-ast-direct-type-name-env [r local-names local-kinds local-limit]
  (if (= (cbor-major r) 5)
    (let [pair-count (cbor-read-arg r)]
      (loop [i 0 tag "" op "" out "" then-kind "" else-kind "" body-kind "" var-name "" scope-limit local-limit]
        (if (>= i pair-count)
          (if (and (str-eq? tag "builtin")
                   (or (str-eq? op "bytes-finish")
                       (str-eq? op "llm-infer")))
            "str"
            (if (and (str-eq? tag "if")
                     (str-eq? then-kind "str")
                     (str-eq? else-kind "str"))
              "str"
                (if (and (or (str-eq? tag "do") (str-eq? tag "let") (str-eq? tag "loop"))
                       (str-eq? body-kind "str"))
                "str"
                (if (str-eq? tag "var")
                  (local-type-kind local-names local-kinds scope-limit var-name)
                  out))))
          (let [k (cbor-text r)]
            (cond
              (str-eq? k "tag")
                (recur (+ i 1) (cbor-text r) op out then-kind else-kind body-kind var-name scope-limit)
              (str-eq? k "op")
                (recur (+ i 1) tag (cbor-text r) out then-kind else-kind body-kind var-name scope-limit)
              (str-eq? k "name")
                (recur (+ i 1) tag op out then-kind else-kind body-kind (cbor-text r) scope-limit)
              (str-eq? k "then")
                (recur (+ i 1) tag op out (read-ast-direct-type-name-env r local-names local-kinds scope-limit) else-kind body-kind var-name scope-limit)
              (str-eq? k "else")
                (recur (+ i 1) tag op out then-kind (read-ast-direct-type-name-env r local-names local-kinds scope-limit) body-kind var-name scope-limit)
              (str-eq? k "bindings")
                (if (or (str-eq? tag "let") (str-eq? tag "loop"))
                  (recur (+ i 1) tag op out then-kind else-kind body-kind var-name (read-ast-direct-bindings! r local-names local-kinds scope-limit))
                  (do (cbor-skip r)
                      (recur (+ i 1) tag op out then-kind else-kind body-kind var-name scope-limit)))
              (str-eq? k "body")
                (if (or (str-eq? tag "do") (str-eq? tag "let") (str-eq? tag "loop"))
                  (recur (+ i 1) tag op out then-kind else-kind (read-ast-direct-body-last-type-name-env r local-names local-kinds scope-limit) var-name scope-limit)
                  (do (cbor-skip r)
                      (recur (+ i 1) tag op out then-kind else-kind body-kind var-name scope-limit)))
              (str-eq? k "value")
                (cond
                  (str-eq? tag "str")
                    (do (cbor-skip r) (recur (+ i 1) tag op "str" then-kind else-kind body-kind var-name scope-limit))
                  (or (str-eq? tag "int") (str-eq? tag "float"))
                    (do (cbor-skip r) (recur (+ i 1) tag op out then-kind else-kind body-kind var-name scope-limit))
                  :else
                    (do (cbor-skip r) (recur (+ i 1) tag op out then-kind else-kind body-kind var-name scope-limit)))
              :else
                (do (cbor-skip r)
                    (recur (+ i 1) tag op out then-kind else-kind body-kind var-name scope-limit)))))))
    (do (cbor-skip r) "")))

(defn read-ast-direct-type-name [r]
  (let [local-names (vec-make 64)
        local-kinds (vec-make 64)]
    (read-ast-direct-type-name-env r local-names local-kinds 0)))

(defn read-ast-direct-body-last-call-keys! [r out]
  (if (= (cbor-major r) 4)
    (let [n (cbor-read-arg r)]
      (loop [i 0]
        (if (>= i n)
          out
          (if (= i (- n 1))
            (do (read-ast-direct-call-keys! r out)
                (recur (+ i 1)))
            (do (cbor-skip r)
                (recur (+ i 1)))))))
    (do (cbor-skip r) out)))

(defn read-ast-direct-call-args-arity [r]
  (if (= (cbor-major r) 4)
    (let [n (cbor-read-arg r)]
      (loop [i 0]
        (if (>= i n)
          n
          (do (cbor-skip r)
              (recur (+ i 1))))))
    (do (cbor-skip r) -1)))

(defn read-ast-direct-call-keys! [r out]
  (if (= (cbor-major r) 5)
    (let [pair-count (cbor-read-arg r)]
      (loop [i 0 tag "" name "" arity -1]
        (if (>= i pair-count)
          (do (if (str-eq? tag "call")
                (vec-conj! out (if (>= arity 0) (function-key name arity) name))
                0)
              out)
          (let [k (cbor-text r)]
            (cond
              (str-eq? k "tag")
                (recur (+ i 1) (cbor-text r) name arity)
              (str-eq? k "name")
                (recur (+ i 1) tag (cbor-text r) arity)
              (str-eq? k "args")
                (recur (+ i 1) tag name (read-ast-direct-call-args-arity r))
              (or (str-eq? k "then") (str-eq? k "else"))
                (if (str-eq? tag "if")
                  (do (read-ast-direct-call-keys! r out)
                      (recur (+ i 1) tag name arity))
                  (do (cbor-skip r)
                      (recur (+ i 1) tag name arity)))
              (str-eq? k "body")
                (if (or (str-eq? tag "do") (str-eq? tag "let") (str-eq? tag "loop"))
                  (do (read-ast-direct-body-last-call-keys! r out)
                      (recur (+ i 1) tag name arity))
                  (do (cbor-skip r)
                      (recur (+ i 1) tag name arity)))
              :else
                (do (cbor-skip r)
                    (recur (+ i 1) tag name arity)))))))
    (do (cbor-skip r) out)))

(defn read-function-summary! [r names params-list effects-list caps-list targets-list calls-list graph-write-targets-list graph-read-targets-list infer-targets-list graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list call-arg-rows-list subset-denials-list type-denials-list type-call-arg-rows-list type-param-reqs-list type-shadowed-params-list return-kinds-list return-callees-list return-callee-rights-list declared-list declared-present-list]
  (let [pair-count (cbor-read-arg r)
        effects (vec-make 8)
        caps (vec-make 8)
        targets (vec-make 16)
        calls (vec-make 16)
        graph-write-targets (vec-make 16)
        graph-read-targets (vec-make 16)
        infer-targets (vec-make 16)
        graph-write-param-targets (vec-make 8)
        graph-read-param-targets (vec-make 8)
        infer-param-targets (vec-make 8)
        call-arg-rows (vec-make 16)
        subset-denials (vec-make 16)
        type-denials (vec-make 16)
        type-call-arg-rows (vec-make 16)
        type-param-reqs (vec-make 16)
        type-shadowed-params (vec-make 8)
        declared (vec-make 8)
        params (vec-make 8)]
    (loop [i 0 name "" known 0 return-kind "" return-callee "" return-callee-right "" declared-present "false"]
      (if (>= i pair-count)
        (do (vec-conj! names name)
            (vec-conj! params-list params)
            (vec-conj! effects-list effects)
            (vec-conj! caps-list caps)
            (vec-conj! targets-list targets)
            (vec-conj! calls-list calls)
            (vec-conj! graph-write-targets-list graph-write-targets)
            (vec-conj! graph-read-targets-list graph-read-targets)
            (vec-conj! infer-targets-list infer-targets)
            (vec-conj! graph-write-param-targets-list graph-write-param-targets)
            (vec-conj! graph-read-param-targets-list graph-read-param-targets)
            (vec-conj! infer-param-targets-list infer-param-targets)
            (vec-conj! call-arg-rows-list call-arg-rows)
            (vec-conj! subset-denials-list subset-denials)
            (vec-conj! type-denials-list type-denials)
            (vec-conj! type-call-arg-rows-list type-call-arg-rows)
            (vec-conj! type-param-reqs-list type-param-reqs)
            (vec-conj! type-shadowed-params-list type-shadowed-params)
            (vec-conj! return-kinds-list return-kind)
            (vec-conj! return-callees-list return-callee)
            (vec-conj! return-callee-rights-list return-callee-right)
            (vec-conj! declared-list declared)
            (vec-conj! declared-present-list declared-present)
            known)
        (let [k (cbor-text r)]
          (cond
            (str-eq? k "name")
              (recur (+ i 1) (cbor-text r) known return-kind return-callee return-callee-right declared-present)
            (str-eq? k "params")
              (do (read-text-array-into! r params)
                  (recur (+ i 1) name known return-kind return-callee return-callee-right declared-present))
            (str-eq? k "param-targets")
              (do (read-param-targets! r graph-write-param-targets graph-read-param-targets infer-param-targets)
                  (recur (+ i 1) name known return-kind return-callee return-callee-right declared-present))
            (str-eq? k "call-args")
              (do (read-call-args! r call-arg-rows)
                  (recur (+ i 1) name known return-kind return-callee return-callee-right declared-present))
            (str-eq? k "source-effects")
              (do (read-source-effects! r effects caps targets graph-write-targets graph-read-targets infer-targets)
                  (recur (+ i 1) name 1 return-kind return-callee return-callee-right declared-present))
            (str-eq? k "forms")
              (recur (+ i 1) name
                     (if (analyze-forms-into! r effects caps targets calls graph-write-targets graph-read-targets infer-targets) 1 known)
                     return-kind
                     return-callee
                     return-callee-right
                     declared-present)
            (str-eq? k "body")
              (recur (+ i 1) name
                     (if (analyze-ast-array! r effects caps targets calls graph-write-targets graph-read-targets infer-targets params graph-write-param-targets graph-read-param-targets infer-param-targets call-arg-rows subset-denials type-denials type-call-arg-rows type-param-reqs type-shadowed-params) 1 known)
                     return-kind
                     return-callee
                     return-callee-right
                     declared-present)
            (str-eq? k "type-body")
              (do (analyze-local-type-body! r type-denials type-call-arg-rows)
                  (recur (+ i 1) name known return-kind return-callee return-callee-right declared-present))
            (str-eq? k "ret")
              (recur (+ i 1) name known (read-ast-direct-type-name r) return-callee return-callee-right declared-present)
            (str-eq? k "ret-call-ast")
              (let [ret-calls (vec-make 8)]
                (read-ast-direct-call-keys! r ret-calls)
                (recur (+ i 1) name known return-kind
                       (if (> (vec-count ret-calls) 0) (vec-nth ret-calls 0) return-callee)
                       (if (> (vec-count ret-calls) 1) (vec-nth ret-calls 1) return-callee-right)
                       declared-present))
            (str-eq? k "ret-call")
              (let [legacy-ret-callee (cbor-text r)]
                (recur (+ i 1) name known return-kind
                       (if (str-eq? return-callee "") legacy-ret-callee return-callee)
                       return-callee-right declared-present))
            (str-eq? k "declared")
              (do (read-text-array-into! r declared)
                  (recur (+ i 1) name known return-kind return-callee return-callee-right "true"))
            :else
              (do (cbor-skip r)
                  (recur (+ i 1) name known return-kind return-callee return-callee-right declared-present))))))))

(defn collect-function! [idx names params-list effects-list caps-list targets-list calls-list seen effects caps targets]
  (if (or (< idx 0) (vec-has-str? seen (function-seen-key names params-list idx)))
    0
    (do (vec-add-unique! seen (function-seen-key names params-list idx))
        (merge-vec-strings! effects (vec-nth effects-list idx))
        (merge-vec-strings! caps (vec-nth caps-list idx))
        (merge-vec-strings! targets (vec-nth targets-list idx))
        (let [calls (vec-nth calls-list idx)]
          (loop [i 0]
            (if (>= i (vec-count calls))
              1
              (do (collect-function! (find-call-index names params-list (vec-nth calls i))
                                     names params-list effects-list caps-list targets-list calls-list
                                     seen effects caps targets)
                  (recur (+ i 1)))))))))

(defn encode-program-summaries [names params-list effects-list caps-list targets-list calls-list]
  (let [b (bytes-alloc 2048)]
    (cbor-enc-map-header! b 2)
    (encode-abi! b)
    (cbor-enc-text! b "functions")
    (cbor-enc-array-header! b (vec-count names))
    (loop [i 0]
      (if (>= i (vec-count names))
        (bytes-finish b)
        (let [effects (vec-make 16)
              caps (vec-make 16)
              targets (vec-make 32)
              seen (vec-make 16)]
          (collect-function! i names params-list effects-list caps-list targets-list calls-list
                             seen effects caps targets)
          (cbor-enc-map-header! b 4)
          (cbor-enc-text! b "name")    (cbor-enc-text! b (vec-nth names i))
          (cbor-enc-text! b "effects") (encode-text-array! b effects)
          (cbor-enc-text! b "caps")    (encode-text-array! b caps)
          (cbor-enc-text! b "targets") (encode-text-array! b targets)
          (recur (+ i 1)))))))

(defn collect-unknown-effects! [declared unknown]
  (loop [i 0]
    (if (>= i (vec-count declared))
      unknown
      (do (if (known-effect? (vec-nth declared i))
            unknown
            (vec-add-unique! unknown (vec-nth declared i)))
          (recur (+ i 1))))))

(defn collect-missing-effects! [used declared missing]
  (loop [i 0]
    (if (>= i (vec-count used))
      missing
      (do (if (vec-has-str? declared (vec-nth used i))
            missing
            (vec-add-unique! missing (vec-nth used i)))
          (recur (+ i 1))))))

(defn encode-effect-declarations! [b names params-list effects-list caps-list targets-list calls-list declared-list declared-present-list]
  (do
    (cbor-enc-map-header! b 3)
    (encode-abi! b)
    (cbor-enc-text! b "ok")
    ;; The value is patched logically by computing violations first into a vector
    ;; of encoded fields in the same pass; use a conservative two-pass count.
    (let [violation-count
          (loop [i 0 count 0]
            (if (>= i (vec-count names))
              count
              (let [declared (vec-nth declared-list i)
                    present (vec-nth declared-present-list i)
                    used (vec-make 16)
                    caps (vec-make 16)
                    targets (vec-make 32)
                    seen (vec-make 16)
                    missing (vec-make 8)
                    unknown (vec-make 8)]
                (collect-function! i names params-list effects-list caps-list targets-list calls-list
                                   seen used caps targets)
                (collect-missing-effects! used declared missing)
                (collect-unknown-effects! declared unknown)
                (recur (+ i 1)
                       (if (and (str-eq? present "true")
                                (or (> (vec-count missing) 0)
                                    (> (vec-count unknown) 0)))
                         (+ count 1)
                         count)))))]
      (cbor-enc-text! b (if (> violation-count 0) "false" "true"))
      (cbor-enc-text! b "violations")
      (cbor-enc-array-header! b violation-count)
      (loop [i 0]
        (if (>= i (vec-count names))
          b
          (let [declared (vec-nth declared-list i)
                present (vec-nth declared-present-list i)
                used (vec-make 16)
                caps (vec-make 16)
                targets (vec-make 32)
                seen (vec-make 16)
                missing (vec-make 8)
                unknown (vec-make 8)]
            (collect-function! i names params-list effects-list caps-list targets-list calls-list
                               seen used caps targets)
            (collect-missing-effects! used declared missing)
            (collect-unknown-effects! declared unknown)
            (if (and (str-eq? present "true")
                     (or (> (vec-count missing) 0)
                         (> (vec-count unknown) 0)))
              (do (cbor-enc-map-header! b 5)
                  (cbor-enc-text! b "name")     (cbor-enc-text! b (vec-nth names i))
                  (cbor-enc-text! b "used")     (encode-text-array! b used)
                  (cbor-enc-text! b "declared") (encode-text-array! b declared)
                  (cbor-enc-text! b "missing")  (encode-text-array! b missing)
                  (cbor-enc-text! b "unknown")  (encode-text-array! b unknown)))
            (recur (+ i 1))))))))

(defn analyze-effect-declarations [names params-list effects-list caps-list targets-list calls-list declared-list declared-present-list]
  (let [b (bytes-alloc 2048)]
    (encode-effect-declarations! b names params-list effects-list caps-list targets-list calls-list
                                 declared-list declared-present-list)
    (bytes-finish b)))

(defn collect-all-subset-denials! [subset-denials-list out]
  (loop [i 0]
    (if (>= i (vec-count subset-denials-list))
      out
      (do (merge-vec-strings! out (vec-nth subset-denials-list i))
          (recur (+ i 1))))))

(defn encode-subset-check! [b subset-denials-list]
  (let [denials (vec-make 32)]
    (collect-all-subset-denials! subset-denials-list denials)
    (cbor-enc-map-header! b 3)
    (encode-abi! b)
    (cbor-enc-text! b "ok") (cbor-enc-text! b (if (= (vec-count denials) 0) "true" "false"))
    (cbor-enc-text! b "denials") (encode-text-array! b denials)))

(defn analyze-subset-check [subset-denials-list]
  (let [b (bytes-alloc 512)]
    (encode-subset-check! b subset-denials-list)
    (bytes-finish b)))

(defn memo-return-kind [name memo-names memo-kinds]
  (let [idx (find-name-index memo-names name)]
    (if (< idx 0) "__missing__" (vec-nth memo-kinds idx))))

(defn memo-return-kind! [name kind memo-names memo-kinds]
  (if (< (find-name-index memo-names name) 0)
    (do (vec-conj! memo-names name)
        (vec-conj! memo-kinds kind))
    0))

(defn resolved-return-kind [idx names params-list return-kinds-list return-callees-list return-callee-rights-list seen memo-names memo-kinds]
  (if (or (< idx 0) (vec-has-str? seen (function-seen-key names params-list idx)))
    ""
    (let [key (function-seen-key names params-list idx)
          cached (memo-return-kind key memo-names memo-kinds)]
      (if (not (str-eq? cached "__missing__"))
        cached
        (let [kind (vec-nth return-kinds-list idx)
              resolved
                (if (not (str-eq? kind ""))
                  kind
                  (let [callee (vec-nth return-callees-list idx)
                        right-callee (vec-nth return-callee-rights-list idx)]
                    (cond
                      (str-eq? callee "")
                        ""
                      (str-eq? right-callee "")
                        (do (vec-add-unique! seen key)
                            (resolved-return-kind (find-call-index names params-list callee)
                                                  names params-list return-kinds-list return-callees-list return-callee-rights-list seen memo-names memo-kinds))
                      :else
                        (do (vec-add-unique! seen key)
                            (let [left-kind (resolved-return-kind (find-call-index names params-list callee)
                                                                  names params-list return-kinds-list return-callees-list return-callee-rights-list seen memo-names memo-kinds)
                                  right-kind (resolved-return-kind (find-call-index names params-list right-callee)
                                                                   names params-list return-kinds-list return-callees-list return-callee-rights-list seen memo-names memo-kinds)]
                              (if (and (not (str-eq? left-kind "")) (str-eq? left-kind right-kind))
                                left-kind
                                ""))))))]
          (do (memo-return-kind! key resolved memo-names memo-kinds)
              resolved))))))

(defn collect-call-type-denials-for-row! [row names params-list type-param-reqs-list type-shadowed-params-list return-kinds-list return-callees-list return-callee-rights-list memo-names memo-kinds out]
  (let [callee (vec-nth row 0)
        callee-idx (find-function-index names params-list callee (- (vec-count row) 1))]
    (if (str-eq? callee "$ret")
      (let [req (vec-nth row 1)
            ret-callee (vec-nth row 2)
            op (vec-nth row 3)
            ret-arity (if (> (vec-count row) 4) (vec-nth row 4) -1)
            ret-idx (if (>= ret-arity 0)
                      (find-function-index names params-list ret-callee ret-arity)
                      (find-name-index names ret-callee))]
        (if (< ret-idx 0)
          out
          (let [seen (vec-make 16)
                actual (resolved-return-kind ret-idx names params-list return-kinds-list return-callees-list return-callee-rights-list seen memo-names memo-kinds)]
            (do (if (call-literal-type-denies? req actual)
                  (vec-add-unique! out op))
                out))))
      (if (< callee-idx 0)
        out
        (let [params (vec-nth params-list callee-idx)
              reqs (vec-nth type-param-reqs-list callee-idx)
              shadowed (vec-nth type-shadowed-params-list callee-idx)]
          (loop [i 1]
            (if (or (>= i (vec-count row)) (> i (vec-count params)))
              out
              (let [actual (vec-nth row i)
                    param (vec-nth params (- i 1))
                    required (param-type-req params reqs shadowed param)]
                (do (if (call-literal-type-denies? required actual)
                      (vec-add-unique! out callee))
                    (recur (+ i 1)))))))))))

(defn collect-call-type-denials! [names params-list type-call-arg-rows-list type-param-reqs-list type-shadowed-params-list return-kinds-list return-callees-list return-callee-rights-list memo-names memo-kinds out]
  (loop [i 0]
    (if (>= i (vec-count type-call-arg-rows-list))
      out
      (let [rows (vec-nth type-call-arg-rows-list i)]
        (do (loop [j 0]
              (if (>= j (vec-count rows))
                0
                (do (collect-call-type-denials-for-row! (vec-nth rows j)
                                                        names params-list
                                                        type-param-reqs-list
                                                        type-shadowed-params-list
                                                        return-kinds-list
                                                        return-callees-list
                                                        return-callee-rights-list
                                                        memo-names
                                                        memo-kinds
                                                        out)
                    (recur (+ j 1)))))
            (recur (+ i 1)))))))

(defn encode-type-check! [b names params-list type-denials-list type-call-arg-rows-list type-param-reqs-list type-shadowed-params-list return-kinds-list return-callees-list return-callee-rights-list]
  (let [denials (vec-make 32)
        memo-names (vec-make 16)
        memo-kinds (vec-make 16)]
    (collect-all-subset-denials! type-denials-list denials)
    (collect-call-type-denials! names params-list type-call-arg-rows-list
                                type-param-reqs-list type-shadowed-params-list
                                return-kinds-list
                                return-callees-list
                                return-callee-rights-list
                                memo-names
                                memo-kinds
                                denials)
    (cbor-enc-map-header! b 3)
    (encode-abi! b)
    (cbor-enc-text! b "ok") (cbor-enc-text! b (if (= (vec-count denials) 0) "true" "false"))
    (cbor-enc-text! b "denials") (encode-text-array! b denials)))

(defn analyze-type-check [names params-list type-denials-list type-call-arg-rows-list type-param-reqs-list type-shadowed-params-list return-kinds-list return-callees-list return-callee-rights-list]
  (let [b (bytes-alloc 512)]
    (encode-type-check! b names params-list type-denials-list type-call-arg-rows-list
                        type-param-reqs-list type-shadowed-params-list
                        return-kinds-list return-callees-list return-callee-rights-list)
    (bytes-finish b)))

(defn read-grant-array! [r grants cap allow]
  (let [n (cbor-read-arg r)]
    (if (> n 0)
      (vec-add-unique! grants cap))
    (loop [i 0]
      (if (>= i n)
        grants
        (do (if (= (cbor-major r) 3)
              (vec-add-unique! allow (cbor-text r))
              (cbor-skip r))
            (recur (+ i 1)))))))

(defn read-auth-grant! [r grants]
  (if (= (cbor-major r) 3)
    (let [v (cbor-text r)]
      (if (str-eq? v "true")
        (vec-add-unique! grants "auth")
        grants))
    (do (cbor-skip r) grants)))

(defn read-policy-grants! [r grants graph-read-allow graph-write-allow infer-allow]
  (if r
    (let [n (cbor-read-arg r)]
      (loop [i 0]
        (if (>= i n)
          grants
          (let [k (cbor-text r)]
            (cond
              (str-eq? k "graph-read")
                (do (if (= (cbor-major r) 4)
                      (read-grant-array! r grants "graph-read" graph-read-allow)
                      (cbor-skip r))
                    (recur (+ i 1)))
              (str-eq? k "graph-write")
                (do (if (= (cbor-major r) 4)
                      (read-grant-array! r grants "graph-write" graph-write-allow)
                      (cbor-skip r))
                    (recur (+ i 1)))
              (str-eq? k "infer")
                (do (if (= (cbor-major r) 4)
                      (read-grant-array! r grants "infer" infer-allow)
                      (cbor-skip r))
                    (recur (+ i 1)))
              (str-eq? k "auth")
                (do (read-auth-grant! r grants)
                    (recur (+ i 1)))
              :else
                (do (cbor-skip r)
                    (recur (+ i 1))))))))
    grants))

(defn collect-all-caps! [names params-list effects-list caps-list targets-list calls-list out]
  (loop [i 0]
    (if (>= i (vec-count names))
      out
      (let [effects (vec-make 16)
            caps (vec-make 16)
            targets (vec-make 32)
            seen (vec-make 16)]
        (collect-function! i names params-list effects-list caps-list targets-list calls-list
                           seen effects caps targets)
        (merge-vec-strings! out caps)
        (recur (+ i 1))))))

(defn collect-function-resource-targets! [idx names params-list calls-list graph-write-targets-list graph-read-targets-list infer-targets-list seen graph-write-out graph-read-out infer-out]
  (if (or (< idx 0) (vec-has-str? seen (function-seen-key names params-list idx)))
    0
    (do (vec-add-unique! seen (function-seen-key names params-list idx))
        (merge-vec-strings! graph-write-out (vec-nth graph-write-targets-list idx))
        (merge-vec-strings! graph-read-out (vec-nth graph-read-targets-list idx))
        (merge-vec-strings! infer-out (vec-nth infer-targets-list idx))
        (let [calls (vec-nth calls-list idx)]
          (loop [i 0]
            (if (>= i (vec-count calls))
              1
              (do (collect-function-resource-targets!
                    (find-call-index names params-list (vec-nth calls i))
                    names params-list calls-list graph-write-targets-list graph-read-targets-list infer-targets-list
                    seen graph-write-out graph-read-out infer-out)
                  (recur (+ i 1)))))))))

(defn collect-all-resource-targets! [names params-list calls-list graph-write-targets-list graph-read-targets-list infer-targets-list graph-write-out graph-read-out infer-out]
  (loop [i 0]
    (if (>= i (vec-count names))
      1
      (do (let [seen (vec-make 16)]
            (collect-function-resource-targets! i names params-list calls-list
                                                graph-write-targets-list graph-read-targets-list infer-targets-list
                                                seen graph-write-out graph-read-out infer-out))
          (recur (+ i 1))))))

(defn grant-allows? [allow target]
  (if (vec-has-str? allow "*")
    1
    (vec-has-str? allow target)))

(defn collect-missing-targets! [cap targets allow out]
  (loop [i 0]
    (if (>= i (vec-count targets))
      out
      (let [target (vec-nth targets i)]
        (do (if (grant-allows? allow target)
              out
              (vec-add-unique! out (str cap ":" target)))
            (recur (+ i 1)))))))

(defn collect-missing-caps! [used granted missing]
  (loop [i 0]
    (if (>= i (vec-count used))
      missing
      (do (if (vec-has-str? granted (vec-nth used i))
            missing
            (vec-add-unique! missing (vec-nth used i)))
          (recur (+ i 1))))))

(defn find-param-index [params name]
  (loop [i 0]
    (if (>= i (vec-count params))
      -1
      (if (str-eq? (vec-nth params i) name)
        i
        (recur (+ i 1))))))

(defn collect-call-param-targets-for-cap! [cap row params param-targets allow out]
  (loop [i 0]
    (if (>= i (vec-count param-targets))
      out
      (let [param-name (vec-nth param-targets i)
            param-idx (find-param-index params param-name)
            arg-idx (+ param-idx 1)]
        (do (if (and (>= param-idx 0) (< arg-idx (vec-count row)))
              (let [target (vec-nth row arg-idx)]
                (if (and (not (str-eq? target ""))
                         (= (grant-allows? allow target) 0))
                  (vec-add-unique! out (str cap ":" target))
                  out))
              out)
            (recur (+ i 1)))))))

(defn collect-call-param-targets-for-row! [row names params-list graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list graph-write-allow graph-read-allow infer-allow out]
  (if (= (vec-count row) 0)
    out
    (let [callee-idx (find-function-index names params-list (vec-nth row 0) (- (vec-count row) 1))]
      (if (< callee-idx 0)
        out
        (let [params (vec-nth params-list callee-idx)]
          (collect-call-param-targets-for-cap! "graph-write" row params
                                               (vec-nth graph-write-param-targets-list callee-idx)
                                               graph-write-allow out)
          (collect-call-param-targets-for-cap! "graph-read" row params
                                               (vec-nth graph-read-param-targets-list callee-idx)
                                               graph-read-allow out)
          (collect-call-param-targets-for-cap! "infer" row params
                                               (vec-nth infer-param-targets-list callee-idx)
                                               infer-allow out))))))

(defn collect-call-param-target-denials! [names params-list call-arg-rows-list graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list graph-write-allow graph-read-allow infer-allow out]
  (loop [i 0]
    (if (>= i (vec-count call-arg-rows-list))
      out
      (let [rows (vec-nth call-arg-rows-list i)]
        (do (loop [j 0]
              (if (>= j (vec-count rows))
                1
                (do (collect-call-param-targets-for-row! (vec-nth rows j)
                                                         names params-list
                                                         graph-write-param-targets-list
                                                         graph-read-param-targets-list
                                                         infer-param-targets-list
                                                         graph-write-allow graph-read-allow infer-allow
                                                         out)
                    (recur (+ j 1)))))
            (recur (+ i 1)))))))

(defn collect-call-param-needed-for-cap! [row params param-targets out]
  (loop [i 0]
    (if (>= i (vec-count param-targets))
      out
      (let [param-name (vec-nth param-targets i)
            param-idx (find-param-index params param-name)
            arg-idx (+ param-idx 1)]
        (do (if (and (>= param-idx 0) (< arg-idx (vec-count row)))
              (let [target (vec-nth row arg-idx)]
                (if (str-eq? target "")
                  (vec-add-unique! out "*")
                  (vec-add-unique! out target)))
              out)
            (recur (+ i 1)))))))

(defn collect-call-param-needed-for-row! [row names params-list graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list graph-write-out graph-read-out infer-out]
  (if (= (vec-count row) 0)
    0
    (let [callee-idx (find-function-index names params-list (vec-nth row 0) (- (vec-count row) 1))]
      (if (< callee-idx 0)
        0
        (let [params (vec-nth params-list callee-idx)]
          (collect-call-param-needed-for-cap! row params
                                             (vec-nth graph-write-param-targets-list callee-idx)
                                             graph-write-out)
          (collect-call-param-needed-for-cap! row params
                                             (vec-nth graph-read-param-targets-list callee-idx)
                                             graph-read-out)
          (collect-call-param-needed-for-cap! row params
                                             (vec-nth infer-param-targets-list callee-idx)
                                             infer-out))))))

(defn collect-call-param-needed! [names params-list call-arg-rows-list graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list graph-write-out graph-read-out infer-out]
  (loop [i 0]
    (if (>= i (vec-count call-arg-rows-list))
      1
      (let [rows (vec-nth call-arg-rows-list i)]
        (do (loop [j 0]
              (if (>= j (vec-count rows))
                1
                (do (collect-call-param-needed-for-row! (vec-nth rows j)
                                                        names params-list
                                                        graph-write-param-targets-list
                                                        graph-read-param-targets-list
                                                        infer-param-targets-list
                                                        graph-write-out graph-read-out infer-out)
                    (recur (+ j 1)))))
            (recur (+ i 1)))))))

(defn encode-policy-check! [b policy-r names params-list effects-list caps-list targets-list calls-list graph-write-targets-list graph-read-targets-list infer-targets-list graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list call-arg-rows-list]
  (let [used (vec-make 16)
        granted (vec-make 16)
        denials (vec-make 16)
        graph-read-allow (vec-make 16)
        graph-write-allow (vec-make 16)
        infer-allow (vec-make 16)
        graph-read-targets (vec-make 16)
        graph-write-targets (vec-make 16)
        infer-targets (vec-make 16)
        target-denials (vec-make 32)]
    (collect-all-caps! names params-list effects-list caps-list targets-list calls-list used)
    (collect-all-resource-targets! names params-list calls-list
                                   graph-write-targets-list graph-read-targets-list infer-targets-list
                                   graph-write-targets graph-read-targets infer-targets)
    (read-policy-grants! policy-r granted graph-read-allow graph-write-allow infer-allow)
    (collect-missing-caps! used granted denials)
    (collect-missing-targets! "graph-write" graph-write-targets graph-write-allow target-denials)
    (collect-missing-targets! "graph-read" graph-read-targets graph-read-allow target-denials)
    (collect-missing-targets! "infer" infer-targets infer-allow target-denials)
    (collect-call-param-target-denials! names params-list call-arg-rows-list
                                        graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list
                                        graph-write-allow graph-read-allow infer-allow
                                        target-denials)
    (cbor-enc-map-header! b 6)
    (encode-abi! b)
    (cbor-enc-text! b "ok")       (cbor-enc-text! b (if (or (> (vec-count denials) 0)
                                                           (> (vec-count target-denials) 0))
                                                       "false"
                                                       "true"))
    (cbor-enc-text! b "used")     (encode-text-array! b used)
    (cbor-enc-text! b "granted")  (encode-text-array! b granted)
    (cbor-enc-text! b "denials")  (encode-text-array! b denials)
    (cbor-enc-text! b "target-denials") (encode-text-array! b target-denials)
    b))

(defn analyze-policy-check [policy-r names params-list effects-list caps-list targets-list calls-list graph-write-targets-list graph-read-targets-list infer-targets-list graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list call-arg-rows-list]
  (let [b (bytes-alloc 1024)]
    (encode-policy-check! b policy-r names params-list effects-list caps-list targets-list calls-list
                          graph-write-targets-list graph-read-targets-list infer-targets-list
                          graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list
                          call-arg-rows-list)
    (bytes-finish b)))

(defn analyze-admission-check [policy-r names params-list effects-list caps-list targets-list calls-list graph-write-targets-list graph-read-targets-list infer-targets-list graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list call-arg-rows-list declared-list declared-present-list]
  (let [b (bytes-alloc 4096)]
    (cbor-enc-map-header! b 3)
    (encode-abi! b)
    (cbor-enc-text! b "effects")
    (encode-effect-declarations! b names params-list effects-list caps-list targets-list calls-list
                                 declared-list declared-present-list)
    (cbor-enc-text! b "policy")
    (encode-policy-check! b policy-r names params-list effects-list caps-list targets-list calls-list
                          graph-write-targets-list graph-read-targets-list infer-targets-list
                          graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list
                          call-arg-rows-list)
    (bytes-finish b)))

(defn analyze-compile-gate [policy-r names params-list effects-list caps-list targets-list calls-list graph-write-targets-list graph-read-targets-list infer-targets-list graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list call-arg-rows-list subset-denials-list type-denials-list type-call-arg-rows-list type-param-reqs-list type-shadowed-params-list return-kinds-list return-callees-list return-callee-rights-list declared-list declared-present-list]
  (let [b (bytes-alloc 8192)]
    (cbor-enc-map-header! b 5)
    (encode-abi! b)
    (cbor-enc-text! b "subset")
    (encode-subset-check! b subset-denials-list)
    (cbor-enc-text! b "types")
    (encode-type-check! b names params-list type-denials-list type-call-arg-rows-list
                        type-param-reqs-list type-shadowed-params-list
                        return-kinds-list return-callees-list return-callee-rights-list)
    (cbor-enc-text! b "effects")
    (encode-effect-declarations! b names params-list effects-list caps-list targets-list calls-list
                                 declared-list declared-present-list)
    (cbor-enc-text! b "policy")
    (encode-policy-check! b policy-r names params-list effects-list caps-list targets-list calls-list
                          graph-write-targets-list graph-read-targets-list infer-targets-list
                          graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list
                          call-arg-rows-list)
    (bytes-finish b)))

(defn encode-needed-targets! [b targets]
  (if (vec-has-str? targets "*")
    (do (cbor-enc-array-header! b 1) (cbor-enc-text! b "*"))
    (encode-text-array! b targets)))

(defn analyze-minimal-policy [names params-list effects-list caps-list targets-list calls-list graph-write-targets-list graph-read-targets-list infer-targets-list graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list call-arg-rows-list]
  (let [used (vec-make 16)
        graph-read-targets (vec-make 16)
        graph-write-targets (vec-make 16)
        infer-targets (vec-make 16)
        b (bytes-alloc 512)]
    (collect-all-caps! names params-list effects-list caps-list targets-list calls-list used)
    (collect-all-resource-targets! names params-list calls-list
                                   graph-write-targets-list graph-read-targets-list infer-targets-list
                                   graph-write-targets graph-read-targets infer-targets)
    (collect-call-param-needed! names params-list call-arg-rows-list
                                graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list
                                graph-write-targets graph-read-targets infer-targets)
    (cbor-enc-map-header! b 5)
    (encode-abi! b)
    (cbor-enc-text! b "graph-read")
    (if (and (vec-has-str? used "graph-read") (= (vec-count graph-read-targets) 0))
      (do (cbor-enc-array-header! b 1) (cbor-enc-text! b "*"))
      (encode-needed-targets! b graph-read-targets))
    (cbor-enc-text! b "graph-write")
    (if (and (vec-has-str? used "graph-write") (= (vec-count graph-write-targets) 0))
      (do (cbor-enc-array-header! b 1) (cbor-enc-text! b "*"))
      (encode-needed-targets! b graph-write-targets))
    (cbor-enc-text! b "infer")
    (if (and (vec-has-str? used "infer") (= (vec-count infer-targets) 0))
      (do (cbor-enc-array-header! b 1) (cbor-enc-text! b "*"))
      (encode-needed-targets! b infer-targets))
    (cbor-enc-text! b "auth")
    (cbor-enc-text! b (if (vec-has-str? used "auth") "true" "false"))
    (bytes-finish b)))

(defn synth-needed-allow! [used cap targets out]
  (do (if (vec-has-str? targets "*")
        (vec-add-unique! out "*")
        (merge-vec-strings! out targets))
      (if (and (vec-has-str? used cap) (= (vec-count out) 0))
        (vec-add-unique! out "*"))
      out))

(defn collect-unused-grants-class! [cap granted needed out]
  (cond
    (= (vec-count granted) 0) out
    (= (vec-count needed) 0) (vec-add-unique! out (str cap ":*"))
    (or (vec-has-str? granted "*") (vec-has-str? needed "*")) out
    :else
      (loop [i 0]
        (if (>= i (vec-count granted))
          out
          (let [cid (vec-nth granted i)]
            (do (if (vec-has-str? needed cid)
                  out
                  (vec-add-unique! out (str cap ":" cid)))
                (recur (+ i 1))))))))

(defn analyze-unused-grants [policy-r names params-list effects-list caps-list targets-list calls-list graph-write-targets-list graph-read-targets-list infer-targets-list graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list call-arg-rows-list]
  (let [used (vec-make 16)
        granted (vec-make 16)
        graph-read-allow (vec-make 16)
        graph-write-allow (vec-make 16)
        infer-allow (vec-make 16)
        graph-read-targets (vec-make 16)
        graph-write-targets (vec-make 16)
        infer-targets (vec-make 16)
        needed-graph-read (vec-make 16)
        needed-graph-write (vec-make 16)
        needed-infer (vec-make 16)
        unused (vec-make 32)
        b (bytes-alloc 512)]
    (collect-all-caps! names params-list effects-list caps-list targets-list calls-list used)
    (collect-all-resource-targets! names params-list calls-list
                                   graph-write-targets-list graph-read-targets-list infer-targets-list
                                   graph-write-targets graph-read-targets infer-targets)
    (collect-call-param-needed! names params-list call-arg-rows-list
                                graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list
                                graph-write-targets graph-read-targets infer-targets)
    (read-policy-grants! policy-r granted graph-read-allow graph-write-allow infer-allow)
    (synth-needed-allow! used "graph-read" graph-read-targets needed-graph-read)
    (synth-needed-allow! used "graph-write" graph-write-targets needed-graph-write)
    (synth-needed-allow! used "infer" infer-targets needed-infer)
    (collect-unused-grants-class! "graph-read" graph-read-allow needed-graph-read unused)
    (collect-unused-grants-class! "graph-write" graph-write-allow needed-graph-write unused)
    (collect-unused-grants-class! "infer" infer-allow needed-infer unused)
    (if (and (vec-has-str? granted "auth") (= (vec-has-str? used "auth") 0))
      (vec-add-unique! unused "auth"))
    (cbor-enc-map-header! b 2)
    (encode-abi! b)
    (cbor-enc-text! b "unused") (encode-text-array! b unused)
    (bytes-finish b)))

(defn analyze-program [r entry check policy-r source-subset-r source-types-r source-effects-r]
  (let [n (cbor-read-arg r)
        names (vec-make 16)
        params-list (vec-make 16)
        effects-list (vec-make 16)
        caps-list (vec-make 16)
        targets-list (vec-make 16)
        calls-list (vec-make 16)
        graph-write-targets-list (vec-make 16)
        graph-read-targets-list (vec-make 16)
        infer-targets-list (vec-make 16)
        graph-write-param-targets-list (vec-make 16)
        graph-read-param-targets-list (vec-make 16)
        infer-param-targets-list (vec-make 16)
        call-arg-rows-list (vec-make 16)
        subset-denials-list (vec-make 16)
        type-denials-list (vec-make 16)
        type-call-arg-rows-list (vec-make 16)
        type-param-reqs-list (vec-make 16)
        type-shadowed-params-list (vec-make 16)
        return-kinds-list (vec-make 16)
        return-callees-list (vec-make 16)
        return-callee-rights-list (vec-make 16)
        declared-list (vec-make 16)
        declared-present-list (vec-make 16)
        source-subset-denials (vec-make 16)
        source-type-denials (vec-make 16)]
    (if source-subset-r
      (do (read-source-subset! source-subset-r source-subset-denials)
          (vec-conj! subset-denials-list source-subset-denials))
      0)
    (if source-types-r
      (do (read-source-types! source-types-r source-type-denials)
          (vec-conj! type-denials-list source-type-denials))
      0)
    (if source-effects-r
      (let [source-effects (vec-make 8)
            source-caps (vec-make 8)
            source-targets (vec-make 16)
            source-calls (vec-make 1)
            source-graph-write-targets (vec-make 8)
            source-graph-read-targets (vec-make 8)
            source-infer-targets (vec-make 8)]
        (do (read-source-effects! source-effects-r source-effects source-caps source-targets
                                  source-graph-write-targets source-graph-read-targets source-infer-targets)
            (vec-conj! names "$source")
            (vec-conj! params-list (vec-make 1))
            (vec-conj! effects-list source-effects)
            (vec-conj! caps-list source-caps)
            (vec-conj! targets-list source-targets)
            (vec-conj! calls-list source-calls)
            (vec-conj! graph-write-targets-list source-graph-write-targets)
            (vec-conj! graph-read-targets-list source-graph-read-targets)
            (vec-conj! infer-targets-list source-infer-targets)
            (vec-conj! graph-write-param-targets-list (vec-make 1))
            (vec-conj! graph-read-param-targets-list (vec-make 1))
            (vec-conj! infer-param-targets-list (vec-make 1))
            (vec-conj! call-arg-rows-list (vec-make 1))
            (vec-conj! subset-denials-list (vec-make 1))
            (vec-conj! type-denials-list (vec-make 1))
            (vec-conj! type-call-arg-rows-list (vec-make 1))
            (vec-conj! type-param-reqs-list (vec-make 1))
            (vec-conj! type-shadowed-params-list (vec-make 1))
            (vec-conj! return-kinds-list "")
            (vec-conj! return-callees-list "")
            (vec-conj! return-callee-rights-list "")
            (vec-conj! declared-list (vec-make 1))
            (vec-conj! declared-present-list "false")))
      0)
    (loop [i 0]
      (if (>= i n)
        (if (str-eq? check "subset")
          (analyze-subset-check subset-denials-list)
          (if (str-eq? check "types")
            (analyze-type-check names params-list type-denials-list
                                type-call-arg-rows-list type-param-reqs-list type-shadowed-params-list
                                return-kinds-list return-callees-list return-callee-rights-list)
            (if (str-eq? check "effects")
              (analyze-effect-declarations names params-list effects-list caps-list targets-list calls-list
                                           declared-list declared-present-list)
              (if (str-eq? check "admission")
                (analyze-admission-check policy-r names params-list effects-list caps-list targets-list calls-list
                                         graph-write-targets-list graph-read-targets-list infer-targets-list
                                         graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list
                                         call-arg-rows-list
                                         declared-list declared-present-list)
                (if (str-eq? check "compile-gate")
                  (analyze-compile-gate policy-r names params-list effects-list caps-list targets-list calls-list
                                        graph-write-targets-list graph-read-targets-list infer-targets-list
                                        graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list
                                        call-arg-rows-list
                                        subset-denials-list type-denials-list type-call-arg-rows-list
                                        type-param-reqs-list type-shadowed-params-list
                                        return-kinds-list return-callees-list return-callee-rights-list
                                        declared-list declared-present-list)
                  (if (str-eq? check "policy")
                  (analyze-policy-check policy-r names params-list effects-list caps-list targets-list calls-list
                                        graph-write-targets-list graph-read-targets-list infer-targets-list
                                        graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list
                                        call-arg-rows-list)
                  (if (str-eq? check "minimal-policy")
                    (analyze-minimal-policy names params-list effects-list caps-list targets-list calls-list
                                            graph-write-targets-list graph-read-targets-list infer-targets-list
                                            graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list
                                            call-arg-rows-list)
                    (if (str-eq? check "unused-grants")
                      (analyze-unused-grants policy-r names params-list effects-list caps-list targets-list calls-list
                                             graph-write-targets-list graph-read-targets-list infer-targets-list
                                             graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list
                                             call-arg-rows-list)
                      (if (str-eq? entry "")
                        (encode-program-summaries names params-list effects-list caps-list targets-list calls-list)
                        (let [effects (vec-make 16)
                              caps (vec-make 16)
                              targets (vec-make 32)
                              seen (vec-make 16)
                              idx (find-name-index names entry)]
                          (collect-function! idx names params-list effects-list caps-list targets-list calls-list
                                             seen effects caps targets)
                          (encode-summary effects caps targets (> (vec-count effects) 0))))))))))))
        (do (read-function-summary! r names params-list effects-list caps-list targets-list calls-list
                                    graph-write-targets-list graph-read-targets-list infer-targets-list
                                    graph-write-param-targets-list graph-read-param-targets-list infer-param-targets-list
                                    call-arg-rows-list subset-denials-list type-denials-list
                                type-call-arg-rows-list type-param-reqs-list type-shadowed-params-list
                                return-kinds-list
                                return-callees-list
                                return-callee-rights-list
                                declared-list declared-present-list)
            (recur (+ i 1)))))))

(defn analyze-one [ctx]
  (let [op (map-text ctx "op")
        target (map-text ctx "target")
        effect (classify-effect op)
        cap (classify-cap op)
        b (bytes-alloc 192)]
    (cbor-enc-map-header! b 5)
    (encode-abi! b)
    (cbor-enc-text! b "effect") (cbor-enc-text! b effect)
    (cbor-enc-text! b "cap")    (cbor-enc-text! b cap)
    (cbor-enc-text! b "target") (cbor-enc-text! b target)
    (cbor-enc-text! b "known")  (cbor-enc-text! b (known-op? op))
    (bytes-finish b)))

(defn run [ctx]
  (if (= (input-abi-ok? ctx) 0)
    (encode-input-abi-error ctx)
    (let [calls (map-seek-reader ctx "calls")]
      (if calls
        (analyze-calls calls)
        (let [forms (map-seek-reader ctx "forms")]
          (if forms
            (analyze-forms forms)
            (let [program (map-seek-reader ctx "program")]
              (if program
                (analyze-program program (map-text ctx "entry") (map-text ctx "check")
                                 (map-seek-reader ctx "policy")
                                 (map-seek-reader ctx "source-subset")
                                 (map-seek-reader ctx "source-types")
                                 (map-seek-reader ctx "source-effects"))
                (analyze-one ctx)))))))))
