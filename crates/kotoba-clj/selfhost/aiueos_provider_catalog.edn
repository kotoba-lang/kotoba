{:schema "aiueos.provider-catalog.v0"
 :owner "kotoba-clj/selfhost"
 :canonical-format :edn
 :json-role :interop
 :providers [{:id "aiueos/ledger-audit"
              :capability "ledger/append"
              :matches ["ledger/append"]
              :commands ["ledger/append"]
              :status "aiueos-audit-provider"}
             {:id "shell/fs-app-data"
              :capability "fs/app-data"
              :matches ["fs/app-data"]
              :commands ["fs/read-text" "fs/write-text" "fs/append-text"]
              :status "implemented-shell-provider"}
             {:id "shell/notification"
              :capability "notify/show"
              :matches ["notify/show"]
              :commands ["notify/show"]
              :status "implemented-shell-provider"}
             {:id "shell/clipboard"
              :capability "clipboard/text"
              :matches ["clipboard/read" "clipboard/write" "clipboard/read-text" "clipboard/write-text" "clipboard/*"]
              :commands ["clipboard/read-text" "clipboard/write-text"]
              :status "implemented-shell-provider"}
             {:id "shell/http-fetch"
              :capability "http/fetch"
              :matches ["http/fetch" "net/fetch" "http/*"]
              :commands ["http/fetch"]
              :status "implemented-shell-provider"}
             {:id "shell/keychain"
              :capability "keychain/text"
              :matches ["keychain/read" "keychain/write" "keychain/read-text" "keychain/write-text" "keychain/*"]
              :commands ["keychain/read-text" "keychain/write-text" "keychain/delete"]
              :status "implemented-shell-provider"}
             {:id "shell/contacts"
              :capability "contacts/read"
              :matches ["contacts/read" "contacts/list" "contacts/*"]
              :commands ["contacts/list"]
              :status "implemented-shell-provider"}
             {:id "shell/calendar"
              :capability "calendar/read"
              :matches ["calendar/read" "calendar/list-events" "calendar/*"]
              :commands ["calendar/list-events"]
              :status "implemented-shell-provider"}]}
