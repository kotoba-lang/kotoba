;; Example safe Kotoba capability policy (deny-by-default).
;;
;; Loaded by `kotoba_clj::Policy::parse_edn`. Anything not listed here is
;; denied: a module compiled against this policy may read+write ONLY the named
;; graph, and may do nothing else (no inference, no auth introspection, no
;; egress, no clock, no randomness). See docs/ADR-safe-capability-language.md §4.
;;
;; Capability classes with a live host import today: :graph-read :graph-write
;; :infer :auth. The rest (:egress :topic-pub :chain-read :secrets :clock
;; :random) are parsed and reserved for the phases that wire their imports.
{:exports
 [{:name "run" :params [:bytes] :result :result}]

 :imports
 {:graph-read   ["bafyGraphReportsA"]   ; graph cids this module may read
  :graph-write  ["bafyGraphReportsA"]   ; …and write (separate grant)
  :infer        []                       ; no model inference
  :auth         false                    ; no CACAO self-introspection
  :egress       []                       ; HTTP egress deny-by-default (reserved)
  :secrets      []                       ; no secret access (reserved)
  :clock        false                    ; no wall-clock (timing-channel) (reserved)
  :random       false}                   ; deterministic — no RNG (reserved)

 :limits
 {:memory-pages     4         ; 256 KiB linear memory ceiling
  :fuel             1000000   ; gas ceiling (wired to runtime gas accounting)
  :max-call-depth   128
  :max-output-bytes 65536}}
