LESCE(sc.follower_count, 0) AS follower_count,   COALESCE(sc.following_count, 0) AS following_count,   COALESCE(sc.post_count, 0) AS post_count,   COALESCE(g.governance_count, 0) AS governance_count,   COALESCE(t.tool_count, 0) AS tool_count FROM canonical_keys k LEFT JOIN social_counts sc ON sc.canonical_actor_did = k.canonical_actor_did LEFT JOIN governance_counts g ON g.canonical_actor_did = k.canonical_actor_did LEFT JOIN tool_counts t ON t.canonical_actor_did = k.canonical_actor_did"
