  {
   :view/name "mv_attractor_stability"
   :view/kind :full
   :view/tags ["wellbecoming" "belief" "attractor" "sbge" "adr_0098"]
   :view/description "Global SBGE attractor stability: entropy_spread + floor_violation_rate + attractor_status."
   :view/sources ["vertex.wellbecoming-event"]
   :view/translation :manual
   :view/manual-reason "single-source aggregate with computed/distinct/where expr — kqe rule"
   :view/sql-source "-- ADR-0098 Repo-as-Attractor: global belief convergence status (ρ(J) < 1 proxy). -- entropy_spread = manual STDDEV via E[X²] - E[X]² (RW lacks STDDEV aggregate in MVs).   SELECT   COUNT(*)                                                                     AS total_events,   SUM(CASE WHEN scored = true THEN 1 ELSE 0 END)                              AS scored_events,   COUNT(DISTINCT agent_did)                                                    AS n_agents,   COUNT(DISTINCT case_id)                                                      AS n_callers,    SQRT(GREATEST(     AVG(CASE WHEN scored = true THEN score_total * score_total ELSE NULL END)     - AVG(CASE WHEN scored = true THEN score_total ELSE NULL END)     * AVG(CASE WHEN scored = true THEN score_total ELSE NULL END),     0.0   ))                                                                           AS entropy_spread,    AVG(CASE WHEN scored = true THEN score_total        ELSE NULL END)          AS mean_score_total,   AVG(CASE WHEN scored = true THEN score_spirit       ELSE NULL END)          AS mean_spirit,   AVG(CASE WHEN scored = true THEN score_wellbecoming ELSE NULL END)          AS mean_wellbecoming,   AVG(CASE WHEN scored = true THEN score_feeling      ELSE NULL END)          AS mean_feeling,   AVG(CASE WHEN scored = true THEN score_buffer       ELSE NULL END)          AS mean_buffer,   AVG(CASE WHEN separation_delta IS NOT NULL THEN separation_delta ELSE NULL END) AS mean_separation_delta,    CAST(SUM(CASE WHEN floor_violated = true THEN 1 ELSE 0 END) AS FLOAT) /     NULLIF(SUM(CASE WHEN scored = true THEN 1 ELSE 0 END), 0)                AS floor_violation_rate,    CASE     WHEN SQRT(GREATEST(            AVG(CASE WHEN scored = true THEN score_total * score_total ELSE NULL END)            - AVG(CASE WHEN scored = true THEN score_total ELSE NULL END)            * AVG(CASE WHEN scored = true THEN score_total ELSE NULL END),            0.0          )) < 0.05 THEN 'stable'     WHEN SQRT(GREATEST(            AVG(CASE WHEN scored = true THEN score_total * score_total ELSE NULL END)            - AVG(CASE WHEN scored = true THEN score_total ELSE NULL END)            * AVG(CASE WHEN scored = true THEN score_total ELSE NULL END),            0.0          )) < 0.15 THEN 'converging'     ELSE 'diverging'   END                                                                          AS attractor_status,    MAX(created_at)                                                              AS last_event_at FROM vertex_wellbecoming_event"
  }

  {
   :view/name "mv_attractor_stability_by_agent"
   :view/kind :full
   :view/grain ["agent_did"]
   :view/tags ["wellbecoming" "belief" "attractor" "sbge" "adr_0098"]
   :view/description "Per-agent SBGE attractor stability: entropy_spread + floor_violations + attractor_status."
   :view/sources ["vertex.wellbecoming-event"]
   :view/translation :manual
   :view/manual-reason "single-source aggregate with computed/distinct/where expr — kqe rule"
   :view/sql-source "-- ADR-0098 Repo-as-Attractor: per-agent belief convergence status. -- Agent-level entropy_spread and floor_violations for W_ij trust-weight diagnostics.   SELECT   agent_did,   SUM(CASE WHEN scored = true THEN 1 ELSE 0 END)                              AS scored_events,    SQRT(GREATEST(     AVG(CASE WHEN scored = true THEN score_total * score_total ELSE NULL END)     - AVG(CASE WHEN scored = true THEN score_total ELSE NULL END)     * AVG(CASE WHEN scored = true THEN score_total ELSE NULL END),     0.0   ))                                                                           AS entropy_spread,    AVG(CASE WHEN scored = true THEN score_total ELSE NULL END)                 AS mean_score_total,   AVG(CASE WHEN separation_delta IS NOT NULL THEN separation_delta ELSE NULL END) AS mean_separation_delta,   SUM(CASE WHEN floor_violated = true THEN 1 ELSE 0 END)                      AS floor_violations,    CASE     WHEN SQRT(GREATEST(            AVG(CASE WHEN scored = true THEN score_total * score_total ELSE NULL END)            - AVG(CASE WHEN scored = true THEN score_total ELSE NULL END)            * AVG(CASE WHEN scored = true THEN score_total ELSE NULL END),            0.0          )) < 0.05 THEN 'stable'     WHEN SQRT(GREATEST(            AVG(CASE WHEN scored = true THEN score_total * score_total ELSE NULL END)            - AVG(CASE WHEN scored = true THEN score_total ELSE NULL END)            * AVG(CASE WHEN scored = true THEN score_total ELSE NULL END),            0.0          )) < 0.15 THEN 'converging'     ELSE 'diverging'   END                                                                          AS attractor_status,    MAX(created_at)                                                              AS last_event_at FROM vertex_wellbecoming_event GROUP BY agent_did"
  }

