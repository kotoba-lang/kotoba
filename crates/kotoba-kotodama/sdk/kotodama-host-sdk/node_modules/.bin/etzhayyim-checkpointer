else
  export NODE_PATH="/Users/junkawasaki/github/etzhayyim-root/20-actors/etzhayyim-sdk/dist/node_modules:/Users/junkawasaki/github/etzhayyim-root/20-actors/etzhayyim-sdk/node_modules:/Users/junkawasaki/github/etzhayyim-root/20-actors/node_modules:/Users/junkawasaki/github/etzhayyim-root/node_modules:/Users/junkawasaki/github/node_modules:/Users/junkawasaki/node_modules:/Users/node_modules:/node_modules:/Users/junkawasaki/github/etzhayyim-root/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@etzhayyim/sdk/dist/checkpointer-bin.js" "$@"
else
  exec node  "$basedir/../@etzhayyim/sdk/dist/checkpointer-bin.js" "$@"
fi
