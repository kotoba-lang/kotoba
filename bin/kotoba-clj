#!/usr/bin/env sh
set -eu
PRG="$0"
while [ -L "$PRG" ]; do
  LINK=$(readlink "$PRG")
  case "$LINK" in
    /*) PRG="$LINK" ;;
    *) PRG="$(dirname -- "$PRG")/$LINK" ;;
  esac
done
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$PRG")" && pwd)
KOTOBA_CLJ_HOME=${KOTOBA_CLJ_HOME:-"$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"}
cd "$KOTOBA_CLJ_HOME"
exec clojure -Sdeps '{:deps {org.clojure/data.json {:mvn/version "2.5.1"} org.clojure/tools.reader {:mvn/version "1.5.2"} kotoba-lang/kotoba-lang {:git/url "https://github.com/kotoba-lang/kotoba-lang.git" :git/sha "f967a9b0a9a72247912e530d2fd1b5a61dd0f6d8"}} :paths ["src" "resources"]}' -M -m kotoba.launcher "$@"
