#!/usr/bin/env sh
set -eu
PRG="$0"
while [ -L "$PRG" ]; do
  LINK=$(readlink "$PRG")
  case "$LINK" in
    /*) PRG="$LINK" ;;
    *) PRG="$(dirname -- "$PRG")/$LINK" ;;
  esac
done
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$PRG")" && pwd)
KOTOBA_CLJ_HOME=${KOTOBA_CLJ_HOME:-"$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"}
cd "$KOTOBA_CLJ_HOME"
exec clojure -M -m kotoba.launcher "$@"
